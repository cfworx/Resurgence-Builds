---
/**
 * RelatedHub — contextual internal links shown above the footer.
 * Renders 3 hub links (excluding the current page) to boost interlinking
 * between high-value pages: codes, safe codes, tier list, build planner, error codes.
 */
export interface Props {
  current?: string;
}

const { current = '' } = Astro.props;

const hubs = [
  { href: '/guides/division-resurgence-codes/', label: 'Redeem Codes', icon: '🎁', desc: 'All active codes' },
  { href: '/guides/division-resurgence-safe-codes/', label: 'Safe Codes', icon: '🔐', desc: 'Every safe location' },
  { href: '/tier-list/', label: 'Build Tier List', icon: '🏆', desc: 'Meta rankings' },
  { href: '/builder/', label: 'Build Planner', icon: '🔧', desc: 'Plan your loadout' },
  { href: '/guides/division-resurgence-error-codes/', label: 'Error Codes', icon: '⚠️', desc: 'Fixes & workarounds' },
];

// Filter out the current page and pick 3
const links = hubs
  .filter(h => !current.includes(h.href.replace(/\/$/, '')))
  .slice(0, 3);
---

{links.length > 0 && (
  <nav class="related-hubs" aria-label="Related resources">
    <span class="related-hubs__label">Quick Links</span>
    <div class="related-hubs__links">
      {links.map(link => (
        <a href={link.href} class="related-hubs__link">
          <span class="related-hubs__icon">{link.icon}</span>
          <span class="related-hubs__text">
            <strong>{link.label}</strong>
            <small>{link.desc}</small>
          </span>
        </a>
      ))}
    </div>
  </nav>
)}

<style>
  .related-hubs {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-4) var(--sp-4);
  }
  @media (min-width: 768px) {
    .related-hubs { padding: var(--sp-6) var(--sp-8) var(--sp-4); }
  }
  .related-hubs__label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: var(--sp-3);
  }
  .related-hubs__links {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .related-hubs__link {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    background: var(--surface-alt, rgba(255,255,255,0.03));
    border: 1px solid var(--border);
    border-radius: var(--radius, 8px);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    flex: 1 1 auto;
    min-width: 180px;
    max-width: 280px;
  }
  .related-hubs__link:hover {
    border-color: var(--accent);
    background: rgba(242, 104, 34, 0.05);
  }
  .related-hubs__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .related-hubs__text {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .related-hubs__text strong {
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .related-hubs__text small {
    font-size: var(--text-xs);
    color: var(--ink-muted);
  }
</style>
