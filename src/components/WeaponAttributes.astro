---
interface Props {
  accuracy?: string;
  reloadSpeed?: string;
  optimalRange?: string;
  movementSpeed?: string;
  stability?: string;
  isCard?: boolean;
}

const { accuracy, reloadSpeed, optimalRange, movementSpeed, stability, isCard = false } = Astro.props;

// Helper to extract number from string like "3.7s" or "14m" or "53"
const parseNum = (val: string | undefined): number => {
  if (!val) return 0;
  const match = val.match(/[\d.]+/);
  return match ? parseFloat(match[0]) : 0;
};

// Max values for calculating progress bar widths
const MAX_ACCURACY = 100;
const MAX_RELOAD = 10; // e.g. 10 seconds max
const MAX_RANGE = 100; // e.g. 100 meters max
const MAX_MOVEMENT = 100;
const MAX_STABILITY = 100;

const getPct = (val: number, max: number) => Math.min(100, Math.max(0, (val / max) * 100));

const attributes = [
  { label: 'Accuracy', value: accuracy, pct: getPct(parseNum(accuracy), MAX_ACCURACY) },
  { label: 'Reload Speed', value: reloadSpeed, pct: getPct(parseNum(reloadSpeed), MAX_RELOAD) },
  { label: 'Optimal Range', value: optimalRange, pct: getPct(parseNum(optimalRange), MAX_RANGE) },
  { label: 'Movement Speed', value: movementSpeed, pct: getPct(parseNum(movementSpeed), MAX_MOVEMENT) },
  { label: 'Stability', value: stability, pct: getPct(parseNum(stability), MAX_STABILITY) }
].filter(a => a.value); // Only show attributes that exist
---

{attributes.length > 0 && (
  <div class={isCard ? 'weapon-attributes-card' : 'weapon-attributes'}>
    {!isCard && <h2 class="wa-heading">Weapon Attributes</h2>}
    <div class="wa-list">
      {attributes.map(attr => (
        <div class="wa-row">
          <span class="wa-label">{attr.label}</span>
          <div class="wa-bar-container">
            <div class="wa-bar-bg">
              <div class="wa-bar-fill" style={`width: ${attr.pct}%;`}></div>
            </div>
            <div class="wa-bar-track-end"></div>
          </div>
          <span class="wa-value">{attr.value}</span>
        </div>
      ))}
    </div>
  </div>
)}

  <style>
  .weapon-attributes {
    background: #111111;
    border-radius: 8px;
    padding: var(--sp-5);
    border: 1px solid rgba(255,255,255,0.05);
    margin-bottom: var(--sp-8);
  }
  
  .weapon-attributes-card {
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .wa-heading {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 500;
    color: #fff;
    margin: 0 0 var(--sp-4) 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: var(--sp-2);
  }

  .wa-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .wa-row {
    display: grid;
    grid-template-columns: 140px 1fr 40px;
    align-items: center;
    gap: var(--sp-4);
  }

  .wa-label {
    font-size: var(--text-base);
    color: #b8b8c0;
  }

  .wa-bar-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .wa-bar-bg {
    width: 100%;
    height: 8px;
    background: rgba(255,255,255,0.1);
    position: relative;
  }

  .wa-bar-fill {
    height: 100%;
    background: #fff;
    box-shadow: 0 0 5px rgba(255,255,255,0.5);
  }

  /* Right boundary line from screenshot */
  .wa-bar-track-end {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 12px;
    background: rgba(255,255,255,0.3);
  }

  .wa-value {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: #ff851b; /* Orange color from screenshot */
    text-align: right;
  }
</style>
