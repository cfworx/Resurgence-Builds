---
/**
 * SocialBar — official follow/join buttons for all Resurgence Builds socials.
 * Uses brand-accurate SVG icons and official brand colors.
 * Each page gets a unique, funny, keyword-rich heading based on the URL path.
 */

interface Props {
  pathname?: string;
}

const { pathname = '/' } = Astro.props;

// --- Funny, keyword-rich headings by content category ---
const buildHeadings = [
  "Your build is mid. Our Discord will fix that.",
  "Stop running random gear. We have a Discord for that.",
  "You didn't farm 47 Legendary runs to NOT share your drops.",
  "Your DPS is lacking and so is your friend list.",
  "This build slaps harder with a squad. Find one.",
  "Solo queue is just suffering with extra steps.",
  "Your loadout is ready. Your squad isn't. Fix that.",
  "Nobody cares about your Power Score. We care about your vibes.",
  "LFG posts are cringe. Discord lobbies are not.",
  "You read the whole build guide. You're one of us now.",
  "Your Warlord deserves better teammates than matchmaking randoms.",
  "Don't let your god roll rot in solo queue.",
  "The real endgame is the friends you farm Legendaries with.",
  "Your build is optimized. Your social life isn't.",
  "Matchmaking gave you 4 DPS players and zero heals. We can help.",
  "Your recalibration bench can't fix loneliness. Discord can.",
  "This build melts. Your squad should too. Not literally.",
  "Ubisoft made the game. We made it make sense. Join us.",
  "Dark Zone extractions are easier with friends who won't betray you. Probably.",
  "You just min-maxed a mobile game. You belong here.",
  "Destiny died so we could thrive. Come thrive with us.",
  "Your gear score is temporary. Our community is forever.",
  "Congrats, you can read stat sheets. Now read our Discord.",
  "The DZ rogues have a squad. You should too.",
  "Your build didn't get you killed. Your lack of callouts did.",
  "Even Ubisoft's QA team couldn't optimize like you just did.",
  "Your K/D ratio needs friends, not just better gear.",
  "The inventory bug took your gear. We'll help you rebuild.",
  "This build guide is free. Therapy for your RNG luck is not.",
  "Four randoms in Legendary is a war crime. Squad up.",
  "Your talent synergies are chef's kiss. Your Discord activity is not.",
  "If you're reading footnotes on a build guide, you're our people.",
  "The meta changes every patch. The homies are forever.",
  "You theorycrafted a build at work. Don't pretend you didn't.",
  "Your Engineering stat is maxed. Your networking stat is zero.",
  "Still using the recommended loadout? We need to talk.",
  "The small indie company won't help you. We will.",
];

const guideHeadings = [
  "You just read a 2,000 word guide. You're already in too deep.",
  "Knowledge is power. Discord is where the knowledge lives.",
  "You learned something. Now argue about it with strangers.",
  "This guide was free. So is joining our Discord.",
  "Ubisoft won't explain their own game. We will. Join us.",
  "The real hidden mechanic is having friends who play this game.",
  "You scrolled past the FAQ. You're basically family now.",
  "Still confused? Our Discord has people even more confused than you.",
  "The game won't teach you this. Neither will Ubisoft. We gotchu.",
  "You now know more than 90% of matchmaking randoms. Celebrate with us.",
  "Free knowledge, zero microtransactions. Unlike some small indie companies.",
  "Your brain grew three sizes reading this. Your friend list should too.",
];

const newsHeadings = [
  "Stay ahead of the patch notes. Follow us before Ubisoft breaks something.",
  "Breaking news travels fast. Our Discord travels faster.",
  "Ubisoft tweets. We translate. Follow along.",
  "The next balance patch will ruin your build. We'll warn you first.",
  "Patch notes are love letters from a small indie company.",
  "Get the news before your clanmates. Be the smart one for once.",
  "Server maintenance is when we post the best memes. Don't miss them.",
  "Your Reddit feed is mid. Our content is not.",
];

const patchHeadings = [
  "Your build just got patched. Our Discord is already theorycrafting the fix.",
  "Ubisoft giveth and Ubisoft taketh away. We document both.",
  "RIP to whatever got nerfed. Pour one out in our Discord.",
  "Every patch breaks something new. We find it first.",
  "Patch notes: the scariest content drop in any live service game.",
  "Another patch, another reason to check if your build still works.",
];

const tierListHeadings = [
  "Disagree with our tier list? Argue about it in Discord.",
  "Your favorite weapon is B-tier. Cope with us.",
  "S-tier builds. S-tier community. D-tier reflexes.",
  "The meta shifts. Our tier list shifts. Your copium shouldn't.",
  "If your main weapon isn't on this list, we need to talk.",
];

const homeHeadings = [
  "Join the Discord. We can't promise we're right, but we're loud.",
  "The Division Resurgence community that actually explains the game.",
  "Builds, guides, and shitposts. The holy trinity.",
  "Where endgame players go when matchmaking lets them down.",
  "Free builds. Free guides. Free entry. Ubisoft could never.",
  "We're the community wiki Ubisoft was too busy to make.",
];

const fallbackHeadings = [
  "You're still here? Might as well follow us.",
  "The algorithm brought you here. Free will keeps you.",
  "If you read this far, you legally have to join our Discord.",
  "Follow us or don't. But you'll be back.",
  "Our content is free. Our Discord is free. Your excuses aren't.",
  "You miss 100% of the builds you don't see. Follow us.",
];

// All known page slugs per category, sorted alphabetically.
// Each slug maps to its index position, which picks from the heading pool.
// New pages added later just get appended and pick the next heading.
const buildSlugs = [
  'geneva-suggestion-field-medic-12',
  'vanguard-scout-recon-support-15',
];

const guideSlugs = [
  'center-ads-release-cover-peek-guide',
  'damage-types-color-bar-weakness-guide',
  'hidden-mechanics-build-optimization',
  'shd-manual-stop-sucking-at-progression-13',
  'which-specialization-to-pick',
];

const newsSlugs = [
  'april-developer-stream-summary',
  'community-sentiment-phase-2',
  'division-resurgence-news-may-20-2026',
  'inventory-bug-fixed-may-21-2026',
  'pc-early-access-launch',
  'phase-2-season-1-live',
  'reddit-weekly-highlights-may-18',
  'season-1-2-3-roadmap',
];

const patchSlugs = [
  'hotfix-1-1-1',
  'patch-1-1-2',
  'patch-1-2-1',
  'phase-2-patch-notes',
];

const tierSlugs = [
  'weapon-tier-list-s1',
];

// Extract slug from pathname
const slug = pathname.replace(/^\/[^/]+\//, '').replace(/\/$/, '');

let headings: string[];
let index = 0;

if (pathname.startsWith('/builds/')) {
  headings = buildHeadings;
  const pos = buildSlugs.indexOf(slug);
  index = pos >= 0 ? pos : buildSlugs.length;
} else if (pathname.startsWith('/guides/')) {
  headings = guideHeadings;
  const pos = guideSlugs.indexOf(slug);
  index = pos >= 0 ? pos : guideSlugs.length;
} else if (pathname.startsWith('/news/')) {
  headings = newsHeadings;
  const pos = newsSlugs.indexOf(slug);
  index = pos >= 0 ? pos : newsSlugs.length;
} else if (pathname.startsWith('/patch-notes/')) {
  headings = patchHeadings;
  const pos = patchSlugs.indexOf(slug);
  index = pos >= 0 ? pos : patchSlugs.length;
} else if (pathname.startsWith('/tier-lists/')) {
  headings = tierListHeadings;
  const pos = tierSlugs.indexOf(slug);
  index = pos >= 0 ? pos : tierSlugs.length;
} else if (pathname === '/' || pathname === '/index.html') {
  headings = homeHeadings;
  index = 0;
} else {
  headings = fallbackHeadings;
  index = 0;
}

const heading = headings[index % headings.length];
---

<div class="social-bar" role="navigation" aria-label="Follow Resurgence Builds">
  <p class="social-bar__heading">{heading}</p>
  <div class="social-bar__links">

    <a href="https://discord.gg/t6GTR6tpd" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--discord" aria-label="Join our Discord server">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M13.545 2.907a13.2 13.2 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.2 12.2 0 0 0-3.658 0 8 8 0 0 0-.412-.833.05.05 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.04.04 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032q.003.022.021.037a13.3 13.3 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019q.463-.63.818-1.329a.05.05 0 0 0-.01-.053.1.1 0 0 0-.027-.016 8.8 8.8 0 0 1-1.249-.595.05.05 0 0 1-.004-.083q.124-.093.248-.19a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.05.05 0 0 1 .053.007q.121.1.248.19a.05.05 0 0 1-.004.083 8.3 8.3 0 0 1-1.249.594.05.05 0 0 0-.03.053.1.1 0 0 0 .004.016q.36.698.818 1.329a.05.05 0 0 0 .056.019 13.2 13.2 0 0 0 4-2.02.05.05 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.03.03 0 0 0-.02-.019m-8.198 7.307c-.789 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612m5.316 0c-.788 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612"/>
      </svg>
      <span>Discord</span>
    </a>

    <a href="https://x.com/ResurgenceBuild" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--x" aria-label="Follow us on X">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
      </svg>
      <span>Follow on X</span>
    </a>

    <a href="https://www.reddit.com/user/ResurgenceBuilds/" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--reddit" aria-label="Follow us on Reddit">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M15.586 8.26a2.108 2.108 0 0 0-2.1-2.095c-.83 0-1.554.48-1.87 1.178-1.428-.865-3.235-1.405-5.228-1.455l1.096-5.158 4.394 1c.026.832.716 1.498 1.555 1.498a1.55 1.55 0 0 0 0-3.099 1.547 1.547 0 0 0-1.488 1.106l-4.81-1.096a.513.513 0 0 0-.616.4l-1.2 5.645c-2.062.032-3.926.578-5.385 1.464a2.108 2.108 0 0 0-1.89-1.2A2.108 2.108 0 0 0 0 8.261c0 1.05.772 1.93 1.782 2.072A5.3 5.3 0 0 0 1.6 11.2c0 2.535 2.87 4.6 6.4 4.6 3.529 0 6.399-2.065 6.399-4.6 0-.31-.035-.615-.102-.912.986-.159 1.737-1.042 1.737-2.094a2.1 2.1 0 0 0-.448-1.233ZM3.7 10.155a1.442 1.442 0 1 1 0-2.885 1.442 1.442 0 0 1 0 2.885Zm4.872 3.197c-1.579 0-3.003-.541-3.606-1.127a.512.512 0 0 1 .715-.734c.484.471 1.705.867 2.891.867 1.186 0 2.408-.396 2.892-.867a.512.512 0 0 1 .715.734c-.604.586-2.028 1.127-3.607 1.127Zm3.27-2.07a1.442 1.442 0 1 1 0-2.884 1.442 1.442 0 0 1 0 2.884Z"/>
