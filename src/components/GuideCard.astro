---
export interface Props {
  title: string;
  href: string;
  category: string;
  description: string;
  lastUpdated: Date;
  tags?: string[];
  featuredImage?: string;
  imageAlt?: string;
}

const { title, href, category, description, lastUpdated, tags = [], featuredImage, imageAlt } = Astro.props;
const formattedDate = lastUpdated.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<article class={`card ${featuredImage ? 'card--has-image' : ''}`} style="position: relative;">
  {featuredImage && (
    <div class="build-card__image">
      <img
        src={featuredImage}
        alt={imageAlt || `${title} - Division Resurgence Guide`}
        loading="lazy"
        decoding="async"
        width="600"
        height="315"
      />
    </div>
  )}
  <div class={featuredImage ? 'build-card__body' : ''}>
    <div style="display:flex;gap:var(--sp-1);flex-wrap:wrap;">
      <span class="tag">{category}</span>
      {tags
        .filter(tag => tag.toLowerCase() !== category.toLowerCase())
        .slice(0, 3)
        .map(tag => <span class="tag">{tag}</span>)
      }
    </div>
    <p class="card__title" style="margin-top:var(--sp-2);">
      <a href={href} class="card__link">{title}</a>
    </p>
    <p class="card__meta">Updated {formattedDate}</p>
    <p class="card__description">{description}</p>
  </div>
</article>

<style>
  .build-card__image {
    margin: calc(-1 * var(--sp-4));
    margin-bottom: 0;
    overflow: hidden;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .build-card__image img {
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .build-card__image img {
    transform: scale(1.03);
  }

  .card--has-image .build-card__body {
    padding-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card__link {
    text-decoration: none;
    color: inherit;
  }
  .card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
