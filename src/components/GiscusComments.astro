---
/**
 * GiscusComments.astro — GitHub-backed comments via giscus.
 * Auto-repositions above Related Reading / Sources sections if present in the markdown.
 */
---

<section class="giscus-wrapper" id="giscus-comments" aria-label="Comments">
  <div class="giscus"></div>
</section>

<script is:inline>
  (function() {
    var d = document, s = d.createElement('script');
    s.src = 'https://giscus.app/client.js';
    s.setAttribute('data-repo', 'cfworx/Resurgence-Builds');
    s.setAttribute('data-repo-id', 'R_kgDOSgFl1w');
    s.setAttribute('data-category', 'Announcements');
    s.setAttribute('data-category-id', 'DIC_kwDOSgFl184C-FVG');
    s.setAttribute('data-mapping', 'pathname');
    s.setAttribute('data-strict', '0');
    s.setAttribute('data-reactions-enabled', '1');
    s.setAttribute('data-emit-metadata', '0');
    s.setAttribute('data-input-position', 'top');
    s.setAttribute('data-theme', 'dark');
    s.setAttribute('data-lang', 'en');
    s.setAttribute('data-loading', 'lazy');
    s.setAttribute('crossorigin', 'anonymous');
    s.async = true;
    var target = d.querySelector('.giscus');
    if (target) target.appendChild(s);

    // Reposition: move comments above "Related Reading" or "Sources" if they exist in the markdown
    var wrapper = d.getElementById('giscus-comments');
    if (wrapper) {
      var prose = wrapper.closest('.prose') || wrapper.parentElement;
      if (prose) {
        var headings = prose.querySelectorAll('h2, h3, p > strong');
        for (var i = 0; i < headings.length; i++) {
          var txt = headings[i].textContent.trim().toLowerCase();
          if (txt === 'related reading:' || txt === 'related reading' || txt === 'sources:' || txt === 'sources') {
            // Find the parent element to insert before
            var anchor = headings[i].tagName === 'STRONG' ? headings[i].closest('p') : headings[i];
            // Also grab the <hr> above if present
            var prev = anchor.previousElementSibling;
            if (prev && prev.tagName === 'HR') anchor = prev;
            anchor.parentNode.insertBefore(wrapper, anchor);
            break;
          }
        }
      }
    }
  })();
</script>

<style is:global>
  .giscus-wrapper {
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }
  .giscus-wrapper .giscus {
    width: 100%;
  }
  .giscus-wrapper .giscus > iframe {
    width: 100% !important;
    min-height: 400px !important;
    border: none;
    display: block;
  }
</style>
