---
/**
 * GiscusComments.astro — GitHub-backed comments via giscus.
 * 
 * To configure:
 * 1. Enable GitHub Discussions on your repo
 * 2. Install the giscus app: https://github.com/apps/giscus
 * 3. Visit https://giscus.app to generate your config
 * 4. Replace the placeholder values below
 */
---

<section class="giscus-wrapper" aria-label="Comments">
  <h2 style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Comments</h2>
  <p style="color: var(--ink-muted); font-size: var(--text-sm); margin-bottom: var(--sp-4);">Join the discussion — powered by GitHub Discussions. No tracking, no ads.</p>
  <div class="giscus"></div>
</section>

<script
  src="https://giscus.app/client.js"
  data-repo="cfworx/Resurgence-Builds"
  data-repo-id="R_kgDOSgFl1w"
  data-category="Announcements"
  data-category-id="DIC_kwDOSgFl184C-FVG"
  data-mapping="pathname"
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="bottom"
  data-theme="dark"
  data-lang="en"
  data-loading="lazy"
  crossorigin="anonymous"
  async
></script>

<style>
  .giscus-wrapper {
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }
</style>
