---
interface Props {
  attributes: {
    "Piercing Damage"?: string;
    "Firepower"?: string;
    "Toughness"?: string;
    "Engineering"?: string;
    [key: string]: string | undefined;
  };
}

const { attributes } = Astro.props;

const attributeIcons: Record<string, string> = {
  "Piercing Damage": `<img src="/images/ui/attributes/piercing-damage.webp" alt="Piercing Damage icon" width="20" height="20" loading="lazy" decoding="async" style="display:block" />`,
  "Firepower": `<img src="/images/ui/attributes/firepower.webp" alt="Firepower icon" width="20" height="20" loading="lazy" decoding="async" style="display:block" />`,
  "Toughness": `<img src="/images/ui/attributes/toughness.webp" alt="Toughness icon" width="20" height="20" loading="lazy" decoding="async" style="display:block" />`,
  "Engineering": `<img src="/images/ui/attributes/engineering.webp" alt="Engineering icon" width="20" height="20" loading="lazy" decoding="async" style="display:block" />`
};
---

<div class="random-attr-container">
  <div class="ra-header">
    <h2 class="ra-title">Randomized Attributes</h2>
    <svg class="ra-info" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
  </div>
  <div class="ra-list">
    {Object.entries(attributes).map(([key, value]) => (
      <div class="ra-row">
        <div class="ra-label">
          <span class="ra-icon" set:html={attributeIcons[key] || ''} />
          {key}
        </div>
        <div class={key === 'Piercing Damage' ? 'ra-value highlight' : 'ra-value'}>
          {value}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .random-attr-container {
    background: #1a1a1a;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
    margin-bottom: var(--sp-8);
    overflow: hidden;
  }
  .ra-header {
    background: #2a2a2a;
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .ra-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 500;
    color: #fff;
    margin: 0;
  }
  .ra-info {
    color: #a0a0a0;
  }
  .ra-list {
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .ra-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ra-label {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    color: #c8c8d0;
    font-size: var(--text-base);
  }
  .ra-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ra-value {
    color: #a0a0a0;
    font-size: var(--text-base);
    font-family: var(--font-mono);
  }
  .ra-value.highlight {
    color: #60a5fa;
  }
</style>
