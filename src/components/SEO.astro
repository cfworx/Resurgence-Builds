---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  article?: {
    publishDate: string;
    modifiedDate?: string;
    author: string;
    tags?: string[];
  };
  keywords?: string[];
  breadcrumbs?: { name: string; url: string }[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  faqs?: { question: string; answer: string }[];
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage = '/images/resurgence-builds-official-logo.png',
  article,
  keywords = [],
  breadcrumbs = [],
  jsonLd,
  faqs = [],
} = Astro.props;

const siteName = 'Resurgence Builds';
const fullTitle = title.includes(siteName) ? title : `${title} · ${siteName}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://resurgencebuilds.com';
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const isDefaultOgImage = ogImage === '/images/resurgence-builds-official-logo.png';

const graph: any[] = [];

// 1. Organization
graph.push({
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: siteName,
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/images/resurgence-builds-official-logo.png`,
    width: 800,
    height: 800
  },
  sameAs: [
    'https://x.com/ResurgenceBuild',
    'https://www.youtube.com/@ResurgenceBuilds',
    'https://www.reddit.com/user/ResurgenceBuilds/',
    'https://discord.gg/t6GTR6tpd'
  ]
});

// 2. WebSite
const isHome = Astro.url.pathname === '/';
graph.push({
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: siteName,
  publisher: { '@id': `${siteUrl}/#organization` },
  potentialAction: isHome ? {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/?q={search_term_string}`
    },
    'query-input': 'required name=search_term_string'
  } : undefined
});

// 3. VideoGame
graph.push({
  '@type': 'VideoGame',
  '@id': `${siteUrl}/#division-resurgence`,
  name: "Tom Clancy's The Division Resurgence",
  alternateName: ["Division Resurgence", "The Division Resurgence"],
  publisher: { '@type': 'Organization', name: 'Ubisoft' },
  gamePlatform: ['iOS', 'Android'],
  applicationCategory: 'Game',
  operatingSystem: ['iOS 13+', 'Android 8+'],
  sameAs: [
    'https://en.wikipedia.org/wiki/Tom_Clancy%27s_The_Division_Resurgence',
    'https://www.ubisoft.com/en-us/game/the-division/resurgence'
  ]
});

// 4. WebPage
graph.push({
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/#division-resurgence` },
  breadcrumb: breadcrumbs.length > 0 ? { '@id': `${canonicalURL}#breadcrumb` } : undefined
});

// 5. BreadcrumbList
if (breadcrumbs.length > 0) {
  const itemListElement = [];
  
  // Ensure Home is always position 1
  if (breadcrumbs[0].name !== 'Home') {
    itemListElement.push({
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteUrl}/`
    });
  }

  breadcrumbs.forEach((crumb, idx) => {
    itemListElement.push({
      '@type': 'ListItem',
      position: itemListElement.length + 1,
      name: crumb.name,
      item: crumb.url === '#' ? canonicalURL : `${siteUrl}${crumb.url}`,
    });
  });

  graph.push({
    '@type': 'BreadcrumbList',
    '@id': `${canonicalURL}#breadcrumb`,
    itemListElement
  });
}

// 6. Article
if (article) {
  const isPatchNote = Astro.url.pathname.includes('/patch-notes/');
  const articleType = isPatchNote ? 'TechArticle' : 'Article';
  
  const articleNode: any = {
    '@type': articleType,
    '@id': `${canonicalURL}#article`,
    isPartOf: { '@id': `${canonicalURL}#webpage` },
    mainEntityOfPage: { '@id': `${canonicalURL}#webpage` },
    headline: title,
    description,
    image: {
      '@type': 'ImageObject',
      url: ogImageUrl,
      width: 1200,
      height: 630
    },
    datePublished: article.publishDate,
    dateModified: article.modifiedDate || article.publishDate,
    author: {
      '@type': 'Person',
      name: article.author,
      '@id': `${siteUrl}/author/${article.author.toLowerCase().replace(/\s+/g, '-')}/#person`,
      url: `${siteUrl}/author/${article.author.toLowerCase().replace(/\s+/g, '-')}/`,
    },
    publisher: { '@id': `${siteUrl}/#organization` },
    about: { '@id': `${siteUrl}/#division-resurgence` }
  };

  if (isPatchNote) {
    articleNode.proficiencyLevel = "Intermediate";
    articleNode.dependencies = "Tom Clancy's The Division Resurgence";
  }

  graph.push(articleNode);
}

// 7. FAQs
if (faqs.length > 0) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${canonicalURL}#faq`,
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  });
}

// 8. Custom JSON-LD from Pages/Layouts
if (jsonLd) {
  const customNodes = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
  customNodes.forEach((node: any) => {
    // If it's passed as a full block with @context, delete context so it merges cleanly into @graph
    delete node['@context'];
    
    // Auto-link to VideoGame if it makes sense (like WebApplication or ItemList)
    if (!node.about && !node.subjectOf && node['@type'] !== 'HowTo') {
       if (node['@type'] === 'WebApplication') {
         node.about = { '@id': `${siteUrl}/#division-resurgence` };
       }
    }
    graph.push(node);
  });
}

const finalJsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph
};
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content={isDefaultOgImage ? "800" : "1200"} />
<meta property="og:image:height" content={isDefaultOgImage ? "800" : "630"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_US" />
{article && <meta property="article:published_time" content={article.publishDate} />}
{article && article.modifiedDate && <meta property="article:modified_time" content={article.modifiedDate} />}
{article && <meta property="article:author" content={article.author} />}
{article && article.tags && article.tags.map(tag => <meta property="article:tag" content={tag} />)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:site" content="@ResurgenceBuild" />
{article && <meta name="author" content={article.author} />}

<script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />
