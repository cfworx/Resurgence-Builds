---
export interface Props {
  title: string;
  href: string;
  specialization: string;
  playstyle: string;
  description: string;
  patch: string;
  pve: boolean;
  pvp: boolean;
  tags?: string[];
  featuredImage?: string;
  imageAlt?: string;
}

const { title, href, specialization, playstyle, description, patch, pve, pvp, tags = [], featuredImage, imageAlt } = Astro.props;

const getSpecClass = (spec: string) => {
  switch (spec) {
    case 'Field Medic': return 'tag--medic';
    case 'Vanguard': return 'tag--vanguard';
    case 'Bulwark': return 'tag--bulwark';
    case 'Tech Operator': return 'tag--tech';
    case 'Demolitionist': return 'tag--demo';
    default: return 'tag--accent';
  }
};
---

<article class={`card ${featuredImage ? 'card--has-image' : ''}`} style="position: relative;">

    {featuredImage && (
      <div class="build-card__image">
        <img
          src={featuredImage}
          alt={imageAlt || `${title} - ${specialization} ${playstyle} build for Division Resurgence`}
          loading="lazy"
          decoding="async"
          width="600"
          height="315"
        />
      </div>
    )}
    <div class="build-card__body">
      <div style="display:flex;gap:var(--sp-1);margin-bottom:var(--sp-2);flex-wrap:wrap;">
        <span class={`tag ${getSpecClass(specialization)}`}>{specialization}</span>
        <span class="tag">{playstyle}</span>
        {pve && <span class="tag">PvE</span>}
        {pvp && <span class="tag">PvP</span>}
        {tags
          .filter(tag => {
            const t = tag.toLowerCase();
            return t !== specialization.toLowerCase()
              && t !== playstyle.toLowerCase()
              && t !== 'pve'
              && t !== 'pvp';
          })
          .slice(0, 3)
          .map(tag => <span class="tag">{tag}</span>)
        }
      </div>
      <h3 class="card__title">
        <a href={href} class="card__link">{title}</a>
      </h3>
      <p class="card__meta">Patch {patch}</p>
      <p class="card__description">{description}</p>
    </div>

</article>

<style>
  .build-card__image {
    margin: calc(-1 * var(--sp-4));
    margin-bottom: 0;
    overflow: hidden;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .build-card__image img {
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .build-card__image img {
    transform: scale(1.03);
  }

  .card--has-image .build-card__body {
    padding-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card__link {
    text-decoration: none;
    color: inherit;
  }

  .card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
