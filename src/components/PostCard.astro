---
import { getAuthorUrl } from '../utils/author';

export interface Props {
  title: string;
  href: string;
  date: Date;
  author: string;
  description: string;
  type: 'news' | 'patch-notes' | 'guide' | 'build' | 'alert';
  tags?: string[];
  featuredImage?: string;
  imageAlt?: string;
}

const { title, href, date, author, description, type, tags = [], featuredImage, imageAlt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const typeLabels: Record<string, string> = {
  'news': 'News',
  'patch-notes': 'Patch Notes',
  'guide': 'Guide',
  'build': 'Build',
  'alert': '⚠ Alert',
};

const typeLabel = typeLabels[type] || type;
---

<article class={`card post-card ${featuredImage ? 'post-card--has-image' : ''}`} data-type={type} data-tags={JSON.stringify(tags)} style="position: relative;">
    {featuredImage && (
      <div class="post-card__image" data-bg={featuredImage}>
        <div class="post-card__image-blur"></div>
        <img
          src={featuredImage}
          alt={imageAlt || `Featured image for ${title}`}
          loading="lazy"
          decoding="async"
          width="600"
          height="315"
        />
      </div>
    )}
    <div class="post-card__body">
      <div class="post-card__header">
        <span class={`post-type-badge post-type-badge--${type}`}>{typeLabel}</span>
        <span class="post-card__date">{formattedDate}</span>
      </div>
      <p class="card__title"><a href={href} class="card__link">{title}</a></p>
      <p class="card__meta">By <a href={getAuthorUrl(author)} class="card__author-link">{author}</a></p>
      <p class="card__description">{description}</p>
      {tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 4).map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="tag" style="text-decoration:none;">{tag}</a>)}
        </div>
      )}
    </div>
</article>

<style>
  .post-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-3);
  }

  .post-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-muted);
  }

  .post-type-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--border-radius);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-type-badge--news {
    background: rgba(242, 104, 34, 0.15);
    color: #F28C50;
    border: 1px solid var(--accent-dim);
  }

  .post-type-badge--patch-notes {
    background: rgba(93, 154, 239, 0.15);
    color: #5B9AEF;
    border: 1px solid #3A7BD5;
  }

  .post-type-badge--guide {
    background: rgba(109, 170, 69, 0.15);
    color: var(--success);
    border: 1px solid #4A9A4A;
  }

  .post-type-badge--build {
    background: rgba(212, 165, 52, 0.15);
    color: #F5CC45;
    border: 1px solid #D4A534;
  }

  .post-type-badge--alert {
    background: rgba(220, 38, 38, 0.15);
    color: #F87171;
    border: 1px solid #DC2626;
    animation: pulse-alert 2s ease-in-out infinite;
  }

  @keyframes pulse-alert {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .post-card__tags {
    display: flex;
    gap: var(--sp-1);
    flex-wrap: wrap;
    margin-top: var(--sp-3);
  }

  .post-card__image {
    margin: calc(-1 * var(--sp-4));
    margin-bottom: 0;
    overflow: hidden;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
    position: relative;
    background-size: cover;
    background-position: center;
    background-color: var(--surface);
    max-height: 280px;
  }

  .post-card__image-blur {
    position: absolute;
    inset: -20px; /* Oversize to hide blur edges */
    background: inherit;
    filter: blur(12px) brightness(0.4);
    z-index: 0;
  }

  .post-card__image img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: saturate(0.92) brightness(0.96);
    transform: scale(1) translateZ(0);
    will-change: transform;
  }

  .post-card:hover .post-card__image img {
    transform: scale(1.03) translateZ(0);
    filter: saturate(1) brightness(1);
  }

  .post-card--has-image .post-card__body {
    padding-top: var(--sp-4);
  }

  .card__link {
    text-decoration: none;
    color: inherit;
  }

  .card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card__author-link {
    color: var(--accent);
    text-decoration: none;
    position: relative;
    z-index: 2;
  }

  .card__author-link:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Lazy-load background images used for the blur effect
  const bgEls = document.querySelectorAll<HTMLElement>('.post-card__image[data-bg]');
  if (bgEls.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.backgroundImage = `url('${el.dataset.bg}')`;
          io.unobserve(el);
        }
      });
    }, { rootMargin: '200px' });
    bgEls.forEach((el) => io.observe(el));
  }
</script>
