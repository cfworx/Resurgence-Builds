---
export interface Props {
  slotId?: string;
  className?: string;
  format?: 'auto' | 'fluid' | 'rectangle';
}

// Default placeholder for development/testing
const clientID = "ca-pub-5813932024666862";
const { slotId = "8102223000", className = '', format = 'auto' } = Astro.props;
---

<div class={`ad-slot ${className}`} aria-label="Advertisement">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client={clientID}
       data-ad-slot={slotId}
       data-ad-format={format}
       data-full-width-responsive="true"></ins>
  <script is:inline>
    // Only push to adsbygoogle if it's available, catching potential adblocker errors
    try {
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    } catch (e) {
      console.warn("AdSense failed to load:", e);
    }
  </script>
</div>
