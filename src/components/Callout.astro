---
export interface Props {
  type?: 'info' | 'warning' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const defaults: Record<string, string> = {
  info: 'Info',
  warning: 'Warning',
  danger: 'Danger',
};

const displayTitle = title || defaults[type];
---

<div class={`callout callout--${type}`} role="note">
  <div class="callout__header">
    {type === 'info' && (
      <svg class="callout__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
    )}
    {type === 'warning' && (
      <svg class="callout__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
        <line x1="12" y1="9" x2="12" y2="13"></line>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
    )}
    {type === 'danger' && (
      <svg class="callout__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"></polygon>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    )}
    <strong class="callout__title">{displayTitle}</strong>
  </div>
  <div class="callout__body">
    <slot />
  </div>
</div>

<style>
  .callout {
    margin: var(--sp-6) 0;
    padding: var(--sp-4);
    border-left: 3px solid var(--callout-accent);
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    background: var(--callout-bg);
  }

  .callout--info {
    --callout-accent: #3b82f6;
    --callout-bg: rgba(59, 130, 246, 0.08);
  }

  .callout--warning {
    --callout-accent: #f59e0b;
    --callout-bg: rgba(245, 158, 11, 0.08);
  }

  .callout--danger {
    --callout-accent: #ef4444;
    --callout-bg: rgba(239, 68, 68, 0.08);
  }

  .callout__header {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-bottom: var(--sp-2);
  }

  .callout__icon {
    flex-shrink: 0;
    color: var(--callout-accent);
  }

  .callout__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--callout-accent);
  }

  .callout__body {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.7;
  }

  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .callout {
      padding: var(--sp-3);
      margin: var(--sp-4) 0;
    }

    .callout__header {
      gap: var(--sp-1);
    }

    .callout__title {
      font-size: var(--text-sm);
    }

    .callout__body {
      font-size: var(--text-xs);
    }
  }
</style>
