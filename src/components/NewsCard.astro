---
export interface Props {
  title: string;
  href: string;
  publishDate: Date;
  author: string;
  description: string;
  tags?: string[];
}

const { title, href, publishDate, author, description, tags = [] } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<article class="card" style="position: relative;">
  <p class="card__meta">{formattedDate} · <a href={`/author/${author.toLowerCase().replace(/\s+/g, '-')}/`} class="card__author-link">{author}</a></p>
  <p class="card__title">
    <a href={href} class="card__link">{title}</a>
  </p>
  <p class="card__description">{description}</p>
  {tags.length > 0 && (
    <div style="display:flex;gap:var(--sp-1);flex-wrap:wrap;margin-top:var(--sp-3);">
      {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>

<style>
  .card__link {
    text-decoration: none;
    color: inherit;
  }
  .card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card__author-link {
    color: var(--accent);
    text-decoration: none;
    position: relative;
    z-index: 2;
  }
  .card__author-link:hover {
    text-decoration: underline;
  }
</style>
