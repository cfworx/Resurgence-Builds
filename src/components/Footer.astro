---
import SocialBar from './SocialBar.astro';
export interface Props {
  title?: string;
}

const { title } = Astro.props;
const year = new Date().getFullYear();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo">Resurgence<span>Builds</span></a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">&copy; {year}</span>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">CC BY-SA 4.0</span>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="/dmca/">DMCA</a>
      <a href="/sitemap/">Sitemap</a>
      <a href="/rss.xml">RSS</a>
      <a href="https://x.com/ResurgenceBuild" target="_blank" rel="noopener noreferrer">X / Twitter</a>
      <a href="https://www.youtube.com/@ResurgenceBuilds" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="https://www.reddit.com/user/ResurgenceBuilds/" target="_blank" rel="noopener noreferrer">Reddit</a>
      <a href="https://discord.gg/t6GTR6tpd" target="_blank" rel="noopener noreferrer">Discord</a>
    </nav>
  </div>

  <SocialBar pathname={Astro.url.pathname} />

  <p class="footer-disclaimer" style="margin-top: 1rem; color: var(--ink-muted); font-size: 0.85rem; line-height: 1.5;">
    Resurgence Builds covers The Division Resurgence, <a href="https://www.ubisoft.com/en-us/game/the-division/resurgence" target="_blank" rel="noopener noreferrer" style="color: var(--accent); text-decoration: none;">Ubisoft's</a> free-to-play RPG shooter on PC, iOS, and Android. We write build guides, gear set breakdowns, weapon tier lists, class guides, and patch notes for people who actually want to understand why their build works (or doesn't). PvE, Dark Zone PvP, Conflict, Legendary missions, exotic weapons, brand sets, SHD tech, OS Protocols, the Cleaners, the Rikers, the Freemen, solo builds, team builds, meme builds that shouldn't work but somehow do. If it's in the game, we've probably argued about it in Discord and then written it up here. Updated every patch because the meta waits for nobody.
  </p>
  <p class="footer-disclaimer" style="margin-top: 0.5rem; color: var(--ink-muted); font-size: 0.75rem;">
    Resurgence Builds is an independent fan site. We are not affiliated with, endorsed by, or sponsored by Ubisoft Entertainment SA. Tom Clancy's The Division, The Division Resurgence, and all related characters, logos, and game assets are trademarks and copyrights of Ubisoft Entertainment SA. Game screenshots and footage are used under fair use for commentary, criticism, and news reporting.
  </p>
</footer>

<style>
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    margin-top: var(--sp-16);
    padding: var(--sp-4) 0 var(--sp-3);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--sp-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  @media (min-width: 768px) {
    .footer-inner { padding: 0 var(--sp-8); }
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .footer-logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .footer-logo:hover { color: var(--ink); }
  .footer-logo span { color: var(--accent); }
  .footer-sep { color: var(--border); }
  .footer-copy {
    font-size: var(--text-xs);
    color: var(--ink-muted);
  }

  .footer-nav {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: var(--text-xs);
    color: var(--ink-muted);
    transition: color var(--transition-fast);
    padding: var(--sp-2) 0;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .footer-nav a:hover { color: var(--accent); }

  .footer-disclaimer {
    max-width: var(--max-width);
    margin: var(--sp-3) auto 0;
    padding: var(--sp-2) var(--sp-4) 0;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-align: center;
    opacity: 0.7;
  }
  @media (min-width: 768px) {
    .footer-disclaimer { padding: var(--sp-2) var(--sp-8) 0; }
  }
</style>
