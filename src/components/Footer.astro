---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
const year = new Date().getFullYear();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const isBuildPost = Astro.url.pathname.startsWith('/builds/') && Astro.url.pathname.length > 9;

let calloutText = "Did I just save your K/D ratio?";
const path = Astro.url.pathname.replace(/\/$/, "");

if (path === "" || path === "/index.html") {
  calloutText = "Still breathing? Good. You owe me a beer.";
} else if (path === "/builds") {
  calloutText = "Stop copying my homework and buy me a pizza.";
} else if (path.startsWith("/guides")) {
  calloutText = "I spoon-fed you this strategy. The least you can do is feed me.";
} else if (path.startsWith("/database")) {
  calloutText = "I stared at spreadsheets until my eyes bled for this data.";
} else if (path.startsWith("/news") || path.startsWith("/patch-notes")) {
  calloutText = "Translating Ubisoft's dev-speak into English makes me violently hungry.";
} else if (path === "/privacy" || path === "/terms" || path === "/dmca") {
  calloutText = "You're actually reading the legal pages? What are you, a cop? Buy me a pizza.";
} else if (title && title.length < 50 && !title.includes('Resurgence Builds')) {
  calloutText = `Did "${title}" carry your dead weight?`;
}
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo">Resurgence<span>Builds</span></a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">&copy; {year}</span>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">CC BY-SA 4.0</span>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="/dmca/">DMCA</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>

  {!isBuildPost && (
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; margin-top: var(--sp-6);">
      <p style="color: var(--accent); font-weight: 700; margin-bottom: var(--sp-2); font-size: var(--text-sm);">{calloutText}</p>
      {isHome ? (
        <a href="https://buymeacoffee.com/resurgencebuilds" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; justify-content: center; background-color: #ff6d10; color: #000000; font-family: 'Comic Sans MS', 'Comic Sans', cursive; font-size: 24px; text-decoration: none; padding: 5px 15px; border-radius: 5px; font-weight: bold; box-shadow: 0px 1px 2px rgba(0,0,0,0.2); transition: transform 0.2s;">
          <span style="margin-right: 8px; font-size: 24px;">🍺</span> No pizza? How about a beer?
        </a>
      ) : (
        <a href="https://buymeacoffee.com/resurgencebuilds" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; justify-content: center; background-color: #ff6d10; color: #000000; font-family: 'Cookie', cursive, sans-serif; font-size: 24px; text-decoration: none; padding: 5px 15px; border-radius: 5px; font-weight: bold; box-shadow: 0px 1px 2px rgba(0,0,0,0.2); transition: transform 0.2s;">
          <span style="margin-right: 8px; font-size: 24px;">🍕</span> Buy me a pizza
        </a>
      )}
    </div>
  )}
  <p class="footer-disclaimer" style="margin-top: 1rem; color: var(--ink-muted); font-size: 0.85rem; line-height: 1.5;">
    Welcome to Resurgence Builds, your premier hub for The Division Resurgence builds, weapons, and top-tier gear sets. The Division Resurgence is a free-to-play RPG shooter from Ubisoft, bringing the acclaimed franchise to PC, iOS, and Android. Whether you are choosing the best specialization for your playstyle, exploring the open world of Manhattan, or stepping foot into post-crisis New York for the first time, we are here to help you level fast and optimize your setup. Study our class guides, and party up with a clan for co-op multiplayer. Ready for the endgame? Our site is updated every patch with the latest meta strategies, from endgame solo builds to Dark Zone PvP extraction tactics. Master exotic weapons, brand sets, and SHD tech to defeat enemy factions including the Cleaners, Rikers, and the new Freemen. Stay ahead of the shifting meta with real-time patch notes, updates, and breaking news.
  </p>
  <p class="footer-disclaimer" style="margin-top: 0.5rem; color: var(--ink-muted); font-size: 0.75rem;">
    Not affiliated with, endorsed by, or sponsored by Ubisoft Entertainment SA. All game trademarks and copyrights belong to Ubisoft.
  </p>
</footer>

<style>
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    margin-top: var(--sp-16);
    padding: var(--sp-4) 0 var(--sp-3);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--sp-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  @media (min-width: 768px) {
    .footer-inner { padding: 0 var(--sp-8); }
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .footer-logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .footer-logo:hover { color: var(--ink); }
  .footer-logo span { color: var(--accent); }
  .footer-sep { color: var(--border); }
  .footer-copy {
    font-size: var(--text-xs);
    color: var(--ink-muted);
  }

  .footer-nav {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: var(--text-xs);
    color: var(--ink-muted);
    transition: color var(--transition-fast);
  }
  .footer-nav a:hover { color: var(--accent); }

  .footer-disclaimer {
    max-width: var(--max-width);
    margin: var(--sp-3) auto 0;
    padding: var(--sp-2) var(--sp-4) 0;
    border-top: 1px solid var(--border);
    font-size: 0.65rem;
    color: var(--ink-muted);
    text-align: center;
    opacity: 0.7;
  }
  @media (min-width: 768px) {
    .footer-disclaimer { padding: var(--sp-2) var(--sp-8) 0; }
  }
</style>
