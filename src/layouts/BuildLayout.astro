---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';

export interface Props {
  title: string;
  description: string;
  specialization: string;
  playstyle: string;
  patch: string;
  lastUpdated: Date;
  pve: boolean;
  pvp: boolean;
  tags: string[];
  author: string;
}

const { title, description, specialization, playstyle, patch, lastUpdated, pve, pvp, tags, author } = Astro.props;

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: 'Builds', url: '/builds/' },
  { name: title, url: '#' },
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  article={{
    publishDate: lastUpdated.toISOString(),
    author,
    tags,
  }}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="layout-sidebar">
      <article class="prose">
        <SectionTag label="Build Guide" />
        <h1 class="heading-accent">{title}</h1>

        <div class="article-meta">
          <span>By {author}</span>
          <span>·</span>
          <span>Patch {patch}</span>
          <span>·</span>
          <time datetime={lastUpdated.toISOString()}>{formattedDate}</time>
        </div>

        <slot />
      </article>

      <aside>
        <div class="card build-info" style="position:sticky;top:calc(var(--nav-height) + var(--sp-4));">
          <SectionTag label="Build Info" />
          <dl class="info-list">
            <div class="info-row"><dt>Specialization</dt><dd>{specialization}</dd></div>
            <div class="info-row"><dt>Playstyle</dt><dd>{playstyle}</dd></div>
            <div class="info-row"><dt>PvE</dt><dd>{pve ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>PvP</dt><dd>{pvp ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>Patch</dt><dd class="stat stat--accent">{patch}</dd></div>
            <div class="info-row"><dt>Updated</dt><dd>{formattedDate}</dd></div>
          </dl>
          {tags.length > 0 && (
            <div style="display:flex;flex-wrap:wrap;gap:var(--sp-1);margin-top:var(--sp-3);">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--border);
  }
  .info-row:last-child {
    border-bottom: none;
  }
  .info-row dt {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .info-row dd {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-align: right;
  }
</style>
