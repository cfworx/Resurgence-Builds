---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  specialization: string;
  playstyle: string;
  patch: string;
  lastUpdated: Date;
  pve: boolean;
  pvp: boolean;
  tags: string[];
  author: string;
  featuredImage?: string;
  headings?: import('astro').MarkdownHeading[];
}

const { title, description, specialization, playstyle, patch, lastUpdated, pve, pvp, tags, author, featuredImage, headings = [] } = Astro.props;

const tocItems = headings.filter(h => h.depth <= 3);

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: 'Builds', url: '/builds/' },
  { name: title, url: '#' },
];

// Dynamic Explore More: get other builds, exclude current page
const allBuilds = await getCollection('builds');
const otherBuilds = allBuilds
  .filter(b => b.data.title !== title)
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  article={{
    publishDate: lastUpdated.toISOString(),
    author,
    tags,
  }}
  ogImage={featuredImage}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="layout-sidebar">
      <!-- Build info sidebar: appears first in DOM for mobile, reordered via CSS -->
      <aside class="build-sidebar">
        <div class="card build-info">
          <SectionTag label="Build Info" />
          <dl class="info-list">
            <div class="info-row"><dt>Specialization</dt><dd>{specialization}</dd></div>
            <div class="info-row"><dt>Playstyle</dt><dd>{playstyle}</dd></div>
            <div class="info-row"><dt>PvE</dt><dd>{pve ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>PvP</dt><dd>{pvp ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>Patch</dt><dd class="stat stat--accent">{patch}</dd></div>
            <div class="info-row"><dt>Updated</dt><dd>{formattedDate}</dd></div>
          </dl>
          {tags.length > 0 && (
            <div style="display:flex;flex-wrap:wrap;gap:var(--sp-1);margin-top:var(--sp-3);">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </aside>

      <article class="prose build-article">
        <SectionTag label="Build Guide" />
        <h1 class="heading-accent">{title}</h1>

        <div class="article-meta">
          <span>By {author}</span>
          <span>&middot;</span>
          <span>Patch {patch}</span>
          <span>&middot;</span>
          <time datetime={lastUpdated.toISOString()}>{formattedDate}</time>
        </div>

        {featuredImage && (
          <div class="build-hero">
            <img
              src={featuredImage}
              alt={`${title} - ${specialization} ${playstyle} build guide for Division Resurgence`}
              width="1200"
              height="630"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

        {tocItems.length > 0 && (
          <nav class="toc" aria-label="Table of contents" style="margin-bottom: var(--sp-6);">
            <p class="toc__title">Contents</p>
            {tocItems.map(h => (
              <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 2) * 1}rem;`}>
                {h.text}
              </a>
            ))}
          </nav>
        )}

        <slot />

        <hr style="margin: var(--sp-6) 0; border: none; border-top: 1px solid var(--border);" />
        
        {otherBuilds.length > 0 && (
          <nav class="explore-more" aria-label="Related Guides">
            <h2 style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Explore More</h2>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--sp-2);">
              {otherBuilds.map(build => (
                <li><a href={`/builds/${build.id}/`}>Check out the <strong>{build.data.title}</strong></a></li>
              ))}
            </ul>
          </nav>
        )}
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--border);
  }
  .info-row:last-child {
    border-bottom: none;
  }
  .info-row dt {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .info-row dd {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-align: right;
  }
  .build-hero {
    margin: var(--sp-6) 0;
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--surface);
  }
  .build-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }

  /* Mobile: sidebar on top, article below */
  .layout-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .build-sidebar {
    order: -1;
  }

  .build-article {
    order: 1;
  }

  /* Desktop: restore sidebar layout */
  @media (min-width: 1024px) {
    .layout-sidebar {
      display: grid;
      grid-template-columns: 1fr var(--sidebar-width);
      gap: var(--sp-8);
    }

    .build-sidebar {
      order: 1;
    }

    .build-article {
      order: 0;
    }

    .build-info {
      position: sticky;
      top: calc(var(--nav-height) + var(--sp-4));
    }
  }
</style>
