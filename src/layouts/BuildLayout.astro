---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  specialization: string;
  playstyle: string;
  patch: string;
  lastUpdated: Date;
  pve: boolean;
  pvp: boolean;
  tags: string[];
  author: string;
  featuredImage?: string;
  imageAlt?: string;
  pizzaTitle?: string;
  pizzaText?: string;
  shareTitle?: string;
  shareText?: string;
  faqs?: { question: string; answer: string }[];
  plannerHash?: string;
}

const { title, description, specialization, playstyle, patch, lastUpdated, pve, pvp, tags, author, featuredImage, imageAlt, pizzaTitle, pizzaText, shareTitle, shareText, headings = [], faqs = [], plannerHash } = Astro.props;

const tocItems = headings.filter(h => h.depth <= 3);

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: 'Builds', url: '/builds/' },
  { name: title, url: '#' },
];

// Dynamic Explore More: get other builds, exclude current page
const allBuilds = await getCollection('builds');
const otherBuilds = allBuilds
  .filter(b => b.data.title !== title)
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);

const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(`Check out the ${title} build guide on Resurgence Builds!`)}&url=${encodeURIComponent(Astro.url.toString())}`;
const redditShareUrl = `https://reddit.com/submit?url=${encodeURIComponent(Astro.url.toString())}&title=${encodeURIComponent(title)}`;
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  article={{
    publishDate: lastUpdated.toISOString(),
    author,
    tags,
  }}
  ogImage={featuredImage}
  keywords={[specialization, playstyle, ...(pve ? ['PVE'] : []), ...(pvp ? ['PVP'] : []), 'Division Resurgence', 'build guide', ...tags.slice(0, 5)]}
  faqs={faqs}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="layout-sidebar">
      <!-- Build info sidebar: appears first in DOM for mobile, reordered via CSS -->
      <aside class="build-sidebar">
        <div class="card build-info">
          <SectionTag label="Build Info" />
          <dl class="info-list">
            <div class="info-row"><dt>Specialization</dt><dd>{specialization}</dd></div>
            <div class="info-row"><dt>Playstyle</dt><dd>{playstyle}</dd></div>
            <div class="info-row"><dt>PvE</dt><dd>{pve ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>PvP</dt><dd>{pvp ? 'Yes' : 'No'}</dd></div>
            <div class="info-row"><dt>Patch</dt><dd class="stat stat--accent">{patch}</dd></div>
            <div class="info-row"><dt>Last updated</dt><dd>{formattedDate}</dd></div>
          </dl>
          {plannerHash && (
            <div style="margin-top: var(--sp-4); margin-bottom: var(--sp-2);">
              <a href={`/builder/#${plannerHash}`} class="btn btn--accent" style="width: 100%; text-align: center; justify-content: center; display: flex; font-weight: bold; font-size: 0.9em; padding: 10px; text-transform: uppercase; letter-spacing: 0.05em; background-color: var(--accent); color: #000; border-radius: 4px; box-shadow: 0 4px 12px rgba(255, 109, 16, 0.25); text-decoration: none;">
                🛠️ Open in Build Planner
              </a>
            </div>
          )}
          {tags.length > 0 && (
            <div style="display:flex;flex-wrap:wrap;gap:var(--sp-1);margin-top:var(--sp-3);">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </aside>

      <article class="prose build-article">
        <SectionTag label="Build Guide" />
        <h1 class="heading-accent">{title}</h1>

        <div class="article-meta">
          <span>By {author}</span>
          <span>&middot;</span>
          <span>Patch {patch}</span>
          <span>&middot;</span>
          <time datetime={lastUpdated.toISOString()}><strong>Last updated:</strong> {formattedDate}</time>
        </div>

        {featuredImage && (
          <div class="build-hero">
            <img
              src={featuredImage}
              alt={imageAlt || `${title} - ${specialization} ${playstyle} build guide for Division Resurgence`}
              width="1200"
              height="630"
              loading="eager"
              decoding="sync"
              fetchpriority="high"
            />
          </div>
        )}

        {tocItems.length > 0 && (
          <nav class="toc" aria-label="Table of contents" style="margin-bottom: var(--sp-6);">
            <p class="toc__title">Contents</p>
            {tocItems.map(h => (
              <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 2) * 1}rem;`}>
                {h.text}
              </a>
            ))}
          </nav>
        )}

        <slot />

        <div style="margin-top: var(--sp-8); padding: var(--sp-5); background: rgba(0,0,0,0.2); border-radius: var(--border-radius); border: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--sp-4);">
          <div>
            <h3 style="margin: 0 0 var(--sp-1) 0; font-size: var(--text-lg);">{shareTitle || "Share this guide"}</h3>
            <p style="margin: 0; color: var(--ink-muted); font-size: var(--text-sm);">{shareText || "Help other agents drop bodies in the Dark Zone."}</p>
          </div>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <a href={twitterShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #000; color: #fff; border: 1px solid #333;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
              </svg>
              Share on X
            </a>
            <a href={redditShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #ff4500; color: #fff; border: 1px solid #ff4500;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M15.586 8.26a2.108 2.108 0 0 0-2.1-2.095c-.83 0-1.554.48-1.87 1.178-1.428-.865-3.235-1.405-5.228-1.455l1.096-5.158 4.394 1c.026.832.716 1.498 1.555 1.498a1.55 1.55 0 0 0 0-3.099 1.547 1.547 0 0 0-1.488 1.106l-4.81-1.096a.513.513 0 0 0-.616.4l-1.2 5.645c-2.062.032-3.926.578-5.385 1.464a2.108 2.108 0 0 0-1.89-1.2A2.108 2.108 0 0 0 0 8.261c0 1.05.772 1.93 1.782 2.072A5.3 5.3 0 0 0 1.6 11.2c0 2.535 2.87 4.6 6.4 4.6 3.529 0 6.399-2.065 6.399-4.6 0-.31-.035-.615-.102-.912.986-.159 1.737-1.042 1.737-2.094a2.1 2.1 0 0 0-.448-1.233ZM3.7 10.155a1.442 1.442 0 1 1 0-2.885 1.442 1.442 0 0 1 0 2.885Zm4.872 3.197c-1.579 0-3.003-.541-3.606-1.127a.512.512 0 0 1 .715-.734c.484.471 1.705.867 2.891.867 1.186 0 2.408-.396 2.892-.867a.512.512 0 0 1 .715.734c-.604.586-2.028 1.127-3.607 1.127Zm3.27-2.07a1.442 1.442 0 1 1 0-2.884 1.442 1.442 0 0 1 0 2.884Z"/></svg>
              Reddit
            </a>
            <a href={facebookShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #1877F2; color: #fff; border: 1px solid #1877F2;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/></svg>
              Facebook
            </a>
          </div>
        </div>

        {pizzaTitle && pizzaText && (
          <div class="bmc-callout" style="margin: 2rem 0; padding: 1.5rem; background: var(--surface); border: 1px solid var(--accent); border-radius: 8px; text-align: center;">
            <h3 style="margin-top: 0; margin-bottom: 0.5rem; color: var(--accent);">{pizzaTitle}</h3>
            <p style="margin: 0 auto 1rem; font-size: 0.875rem; color: var(--ink-muted);">{pizzaText}</p>
            <div style="display: flex; justify-content: center;">
              <a href="https://buymeacoffee.com/resurgencebuilds" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; justify-content: center; background-color: #ff6d10; color: #000000; font-family: 'Cookie', cursive, sans-serif; font-size: 24px; text-decoration: none; padding: 5px 15px; border-radius: 5px; font-weight: bold; box-shadow: 0px 1px 2px rgba(0,0,0,0.2); transition: transform 0.2s;">
                <span style="margin-right: 8px; font-size: 24px;">🍕</span> Buy me a pizza
              </a>
            </div>
          </div>
        )}

        <hr style="margin: var(--sp-6) 0; border: none; border-top: 1px solid var(--border);" />
        
        {otherBuilds.length > 0 && (
          <nav class="explore-more" aria-label="Related Builds">
            <h2 style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Related Builds</h2>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--sp-2);">
              {otherBuilds.map(build => (
                <li><a href={`/builds/${build.id}/`}>{build.data.title}</a> <span style="color: var(--ink-muted); font-weight: 400;">— {build.data.specialization} {build.data.playstyle}</span></li>
              ))}
            </ul>
          </nav>
        )}
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--border);
  }
  .info-row:last-child {
    border-bottom: none;
  }
  .info-row dt {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .info-row dd {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-align: right;
  }
  .build-hero {
    margin: var(--sp-6) 0;
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--surface);
  }
  .build-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }

  /* Mobile: sidebar on top, article below */
  .layout-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .build-sidebar {
    order: -1;
  }

  .build-info {
    height: fit-content;
  }

  .build-article {
    order: 1;
  }

  /* Desktop: restore sidebar layout */
  @media (min-width: 1024px) {
    .layout-sidebar {
      display: grid;
      grid-template-columns: 1fr var(--sidebar-width);
      gap: var(--sp-8);
    }

    .build-sidebar {
      order: 1;
      align-self: start;
    }

    .build-article {
      order: 0;
    }

    .build-info {
      position: sticky;
      top: calc(var(--nav-height) + var(--sp-4));
    }
  }
</style>
