---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSenseUnit from '../components/AdSenseUnit.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  article?: {
    publishDate: string;
    modifiedDate?: string;
    author: string;
    tags?: string[];
  };
  keywords?: string[];
  breadcrumbs?: { name: string; url: string }[];
  jsonLd?: Record<string, unknown>;
  faqs?: { question: string; answer: string }[];
  noAds?: boolean;
}

const { title, description, ogType, ogImage, article, keywords, breadcrumbs, jsonLd, faqs, noAds } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, shrink-to-fit=no" />
  <meta name="theme-color" content="#0D0D0F" />
  <meta name="color-scheme" content="dark" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/og-default.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="alternate" type="application/rss+xml" title="Resurgence Builds RSS" href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />


  <!-- Google Fonts — preload for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
    />
  </noscript>

  <SEO
    title={title}
    description={description}
    ogType={ogType}
    ogImage={ogImage}
    article={article}
    keywords={keywords}
    breadcrumbs={breadcrumbs}
    jsonLd={jsonLd}
    faqs={faqs}
  />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <Header />
  <main id="main-content">
    <slot />
    {!noAds && (
      <div class="container" style="padding-top: var(--sp-6); padding-bottom: var(--sp-4);">
        <AdSenseUnit />
      </div>
    )}
  </main>
<Footer title={title} />
  <script>
    // Wrap all prose/content tables in a scrollable div for mobile
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.prose table, main table').forEach(table => {
        if (table.parentElement?.classList.contains('table-scroll')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-scroll';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });
    });
  </script>
</body>
</html>
