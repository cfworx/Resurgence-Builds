---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSenseUnit from '../components/AdSenseUnit.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  article?: {
    publishDate: string;
    modifiedDate?: string;
    author: string;
    tags?: string[];
    wordCount?: number;
  };
  keywords?: string[];
  breadcrumbs?: { name: string; url: string }[];
  jsonLd?: Record<string, unknown>;
  faqs?: { question: string; answer: string }[];
  noAds?: boolean;
  noindex?: boolean;
}

const { title, description, ogType, ogImage, article, keywords, breadcrumbs, jsonLd, faqs, noAds, noindex } = Astro.props;
const suppressAds = noAds || noindex;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="msvalidate.01" content="BE91A714DA465B973961FB903E416D0B" />
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, shrink-to-fit=no" />
  <meta name="theme-color" content="#0D0D0F" />
  <meta name="color-scheme" content="dark" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="alternate" type="application/rss+xml" title="Resurgence Builds RSS" href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />


  <!-- Self-hosted fonts (removes cross-origin latency) -->
  <link rel="stylesheet" href="/fonts/fonts.css" />

  <SEO
    title={title}
    description={description}
    ogType={ogType}
    ogImage={ogImage}
    article={article}
    keywords={keywords}
    breadcrumbs={breadcrumbs}
    jsonLd={jsonLd}
    faqs={faqs}
    noindex={noindex}
  />

  <slot name="head" />

  {!suppressAds && (
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5813932024666862" crossorigin="anonymous"></script>
  )}
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <Header />
  <main id="main-content">
    <slot />
    {!suppressAds && (
      <div class="container" style="padding-top: var(--sp-6); padding-bottom: var(--sp-4);">
        <AdSenseUnit label="Advertisement — footer" />
      </div>
    )}
  </main>
<Footer title={title} />
  <script>
    // Wrap all prose/content tables in a scrollable div for mobile
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.prose table, main table').forEach(table => {
        if (table.parentElement?.classList.contains('table-scroll')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-scroll';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });
    });
  </script>
  <!-- Ad reveal observer: watches for AdSense to fill slots, then shows them -->
  <script is:inline>
    (function() {
      var obs = new MutationObserver(function(mutations) {
        mutations.forEach(function(m) {
          if (m.type === 'attributes' && m.attributeName === 'data-ad-status') {
            var ins = m.target;
            if (ins.getAttribute('data-ad-status') === 'filled') {
              var slot = ins.closest('.ad-slot');
              if (slot) slot.classList.add('ad-filled');
            }
          }
        });
      });
      document.querySelectorAll('.adsbygoogle').forEach(function(ins) {
        obs.observe(ins, { attributes: true, attributeFilter: ['data-ad-status'] });
        // Check if already filled (race condition)
        if (ins.getAttribute('data-ad-status') === 'filled') {
          var slot = ins.closest('.ad-slot');
          if (slot) slot.classList.add('ad-filled');
        }
      });
    })();
  </script>
</body>
</html>
