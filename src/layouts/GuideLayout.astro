---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';
import AdSenseUnit from '../components/AdSenseUnit.astro';
import { getAuthorUrl } from '../utils/author';
export interface Props {
  title: string;
  description: string;
  category: string;
  lastUpdated: Date;
  tags: string[];
  author?: string;
  featuredImage?: string;
  imageAlt?: string;
  shareTitle?: string;
  shareText?: string;
  headings?: { depth: number; slug: string; text: string }[];
  faqs?: { question: string; answer: string }[];
  sources?: string[];
  howTo?: {
    name: string;
    description: string;
    totalTime: string;
    tool: string[];
    steps: { name: string; text: string; }[];
  };
}

const {
  title,
  description,
  category,
  lastUpdated,
  tags,
  author = 'RapidF5',
  featuredImage,
  imageAlt,
  shareTitle,
  shareText,
  headings = [],
  faqs = [],
  sources = [],
  howTo,
} = Astro.props;

const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText || `Check out this Division Resurgence guide: ${title}`)}&url=${encodeURIComponent(Astro.url.toString())}`;
const redditShareUrl = `https://reddit.com/submit?url=${encodeURIComponent(Astro.url.toString())}&title=${encodeURIComponent(title)}`;

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: 'Guides', url: '/guides/' },
  { name: title, url: '#' },
];

const tocItems = headings.filter(h => h.depth <= 3);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://resurgencebuilds.com';
const howToLd = howTo ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${siteUrl}${Astro.url.pathname}#howto`,
  name: howTo.name,
  description: howTo.description,
  totalTime: howTo.totalTime,
  tool: howTo.tool.map(t => ({ '@type': 'HowToTool', name: t })),
  step: howTo.steps.map((s, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: s.name,
    text: s.text,
  }))
} : null;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  ogImage={featuredImage}
  article={{
    publishDate: lastUpdated.toISOString(),
    modifiedDate: lastUpdated.toISOString(),
    author,
    tags,
  }}
  jsonLd={howToLd ? howToLd : undefined}
  faqs={faqs}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <SectionTag label="Guide" />
    <h1 class="heading-accent">{title}</h1>

    <div class="article-meta">
      <span class="tag">{category}</span>
      <span>By <a href={getAuthorUrl(author)} style="color: var(--accent); text-decoration: none;">{author}</a></span>
      <span>·</span>
      <time datetime={lastUpdated.toISOString()}><strong>Last updated:</strong> {formattedDate}</time>
    </div>

    {featuredImage && (
      <div class="guide-hero">
        <img
          src={featuredImage}
          alt={imageAlt || `${title} - The Division Resurgence`}
          width="1200"
          height="630"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
      </div>
    )}

    {tocItems.length > 0 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc__title">Contents</p>
        {tocItems.map(h => (
          <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 2) * 1}rem;`}>
            {h.text}
          </a>
        ))}
      </nav>
    )}

    <article class="prose content-width">
      <slot />

      <AdSenseUnit slotId="8102223000" />

      <!-- 1. Share -->
      <div style="margin-top: var(--sp-8); padding: var(--sp-5); background: rgba(0,0,0,0.2); border-radius: var(--border-radius); border: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--sp-4);">
        <div>
          <h3 style="margin: 0 0 var(--sp-1) 0; font-size: var(--text-lg);">{shareTitle || "Share this guide"}</h3>
          <p style="margin: 0; color: var(--ink-muted); font-size: var(--text-sm);">{shareText || "Help other agents git gud."}</p>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <a href={twitterShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #000; color: #fff; border: 1px solid #333;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
            </svg>
            Share on X
          </a>
          <a href={redditShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #ff4500; color: #fff; border: 1px solid #ff4500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M15.586 8.26a2.108 2.108 0 0 0-2.1-2.095c-.83 0-1.554.48-1.87 1.178-1.428-.865-3.235-1.405-5.228-1.455l1.096-5.158 4.394 1c.026.832.716 1.498 1.555 1.498a1.55 1.55 0 0 0 0-3.099 1.547 1.547 0 0 0-1.488 1.106l-4.81-1.096a.513.513 0 0 0-.616.4l-1.2 5.645c-2.062.032-3.926.578-5.385 1.464a2.108 2.108 0 0 0-1.89-1.2A2.108 2.108 0 0 0 0 8.261c0 1.05.772 1.93 1.782 2.072A5.3 5.3 0 0 0 1.6 11.2c0 2.535 2.87 4.6 6.4 4.6 3.529 0 6.399-2.065 6.399-4.6 0-.31-.035-.615-.102-.912.986-.159 1.737-1.042 1.737-2.094a2.1 2.1 0 0 0-.448-1.233ZM3.7 10.155a1.442 1.442 0 1 1 0-2.885 1.442 1.442 0 0 1 0 2.885Zm4.872 3.197c-1.579 0-3.003-.541-3.606-1.127a.512.512 0 0 1 .715-.734c.484.471 1.705.867 2.891.867 1.186 0 2.408-.396 2.892-.867a.512.512 0 0 1 .715.734c-.604.586-2.028 1.127-3.607 1.127Zm3.27-2.07a1.442 1.442 0 1 1 0-2.884 1.442 1.442 0 0 1 0 2.884Z"/></svg>
            Reddit
          </a>
        </div>
      </div>

      <!-- 2. FAQ -->
      {faqs && faqs.length > 0 && (
        <div class="faq-section" style="margin-top: var(--sp-8);">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list" style="display: flex; flex-direction: column; gap: var(--sp-2);">
            {faqs.map(faq => (
              <details class="faq-item">
                <summary class="faq-question">{faq.question}</summary>
                <p class="faq-answer">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      <!-- 3. Explore More -->
      <hr style="margin: var(--sp-6) 0; border: none; border-top: 1px solid var(--border);" />
      <nav class="explore-more" aria-label="Related Guides">
        <h2 style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Explore More</h2>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--sp-2);">
          <li>Discover top-tier meta loadouts in our <a href="/builds/"><strong>Best Builds Tier List</strong></a></li>
          <li>Browse every gear set bonus in the <a href="/database/gear-set-effects/"><strong>Gear Set Effects Database</strong></a></li>
          <li>Stay updated with the latest <a href="/news/"><strong>Patch Notes and Breaking News</strong></a></li>
        </ul>
      </nav>

      <!-- 4. Sources -->
      {sources.length > 0 && (
        <section class="build-sources" style="margin-top: var(--sp-8); background: rgba(0,0,0,0.15); border-radius: var(--border-radius); padding: var(--sp-6);">
          <h2 id="sources" style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Sources</h2>
          <ul style="color: var(--ink-muted); padding-left: var(--sp-5); font-size: var(--text-sm);">
            {sources.map(source => (
              <li style="margin-bottom: var(--sp-2);" set:html={source}></li>
            ))}
          </ul>
        </section>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .guide-hero {
    margin: var(--sp-6) 0;
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--surface);
  }
  .guide-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }

  /* --- FAQ Dropdowns --- */
  .faq-list { margin: var(--sp-4) 0 }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: var(--sp-2);
    overflow: hidden;
    transition: border-color 200ms ease;
  }
  .faq-item:hover { border-color: rgba(242,104,34,0.3) }
  .faq-item[open] { border-color: var(--accent) }
  .faq-question {
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 48px;
  }
  .faq-question::-webkit-details-marker { display: none }
  .faq-question::after { content: '＋'; font-size: var(--text-lg); color: var(--accent); transition: transform .2s }
  .faq-item[open] .faq-question::after { content: '－' }
  .faq-answer {
    padding: 0 var(--sp-4) var(--sp-4);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.6;
  }
</style>
