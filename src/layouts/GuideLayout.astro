---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  lastUpdated: Date;
  tags: string[];
  author?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, category, lastUpdated, tags, author = 'Resurgence Builds', headings = [] } = Astro.props;

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: 'Guides', url: '/guides/' },
  { name: title, url: '#' },
];

const tocItems = headings.filter(h => h.depth <= 3);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://resurgencebuilds.com';
const howToLd = headings.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: title,
  description: description,
  step: headings.filter(h => h.depth === 2 || h.depth === 3).map((h, index) => ({
    '@type': 'HowToStep',
    text: h.text,
    url: `${siteUrl}${Astro.url.pathname}#${h.slug}`,
  }))
} : null;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  article={{
    publishDate: lastUpdated.toISOString(),
    author,
    tags,
  }}
  jsonLd={howToLd ? howToLd : undefined}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <SectionTag label="Guide" />
    <h1 class="heading-accent">{title}</h1>

    <div class="article-meta">
      <span class="tag">{category}</span>
      <span>By {author}</span>
      <span>·</span>
      <time datetime={lastUpdated.toISOString()}>{formattedDate}</time>
    </div>

    {tocItems.length > 0 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc__title">Contents</p>
        {tocItems.map(h => (
          <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 2) * 1}rem;`}>
            {h.text}
          </a>
        ))}
      </nav>
    )}

    <article class="prose content-width">
      <slot />
    </article>
  </div>
</BaseLayout>
