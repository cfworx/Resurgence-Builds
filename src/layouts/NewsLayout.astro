---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionTag from '../components/SectionTag.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { getAuthorUrl } from '../utils/author';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  author: string;
  tags: string[];
  parentPath: string;
  parentLabel: string;
  image?: string;
  imageAlt?: string;
  headings?: { depth: number; slug: string; text: string }[];
  shareTitle?: string;
  shareText?: string;
  faqs?: { question: string; answer: string }[];
}

const { title, description, publishDate, author, tags, parentPath, parentLabel, image, imageAlt, shareTitle, shareText, headings = [], faqs = [] } = Astro.props;

const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`;
const redditShareUrl = `https://reddit.com/submit?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`;

const tocItems = headings.filter(h => h.depth <= 3);

const formattedDate = publishDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbItems = [
  { name: parentLabel, url: parentPath },
  { name: title, url: '#' },
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  ogType="article"
  ogImage={image}
  article={{
    publishDate: publishDate.toISOString(),
    modifiedDate: publishDate.toISOString(),
    author,
    tags,
  }}
  faqs={faqs}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />

    <article class="content-width">
      <SectionTag label={parentLabel} />
      <h1 class="heading-accent">{title}</h1>

      <div class="article-meta">
        <span>By <a href={getAuthorUrl(author)} style="color: var(--accent); text-decoration: none;">{author}</a></span>
        <span>·</span>
        <time datetime={publishDate.toISOString()}><strong>Last updated:</strong> {formattedDate}</time>
      </div>

      {image && (
        <img src={image} alt={imageAlt || title} style="width: 100%; height: auto; margin-top: var(--sp-4); margin-bottom: var(--sp-6); border-radius: 4px;" loading="eager" fetchpriority="high" decoding="sync" />
      )}

      {tocItems.length > 0 && (
        <nav class="toc" aria-label="Table of contents">
          <p class="toc__title">Contents</p>
          {tocItems.map(h => (
            <a href={`#${h.slug}`} style={`padding-left:${(h.depth - 2) * 1}rem;`}>
              {h.text}
            </a>
          ))}
        </nav>
      )}

      {tags.length > 0 && (
        <div style="display:flex;gap:var(--sp-1);flex-wrap:wrap;margin-bottom:var(--sp-6);">
          {tags.map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="tag">{tag}</a>)}
        </div>
      )}

      <div class="prose">
        <slot />
      </div>

      {faqs && faqs.length > 0 && (
        <div class="faq-section" style="margin-top: var(--sp-8);">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list" style="display: flex; flex-direction: column; gap: var(--sp-2);">
            {faqs.map(faq => (
              <details class="faq-item">
                <summary class="faq-question">{faq.question}</summary>
                <p class="faq-answer">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      <GiscusComments />

      <div style="margin-top: var(--sp-8); padding: var(--sp-5); background: rgba(0,0,0,0.2); border-radius: var(--border-radius); border: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--sp-4);">
        <div>
          <h3 style="margin: 0 0 var(--sp-1) 0; font-size: var(--text-lg);">{shareTitle || "Share this article"}</h3>
          <p style="margin: 0; color: var(--ink-muted); font-size: var(--text-sm);">{shareText || "Share the latest news with other agents."}</p>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <a href={twitterShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #000; color: #fff; border: 1px solid #333;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
            </svg>
            Share on X
          </a>
          <a href={redditShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 8px; background-color: #ff4500; color: #fff; border: 1px solid #ff4500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M15.586 8.26a2.108 2.108 0 0 0-2.1-2.095c-.83 0-1.554.48-1.87 1.178-1.428-.865-3.235-1.405-5.228-1.455l1.096-5.158 4.394 1c.026.832.716 1.498 1.555 1.498a1.55 1.55 0 0 0 0-3.099 1.547 1.547 0 0 0-1.488 1.106l-4.81-1.096a.513.513 0 0 0-.616.4l-1.2 5.645c-2.062.032-3.926.578-5.385 1.464a2.108 2.108 0 0 0-1.89-1.2A2.108 2.108 0 0 0 0 8.261c0 1.05.772 1.93 1.782 2.072A5.3 5.3 0 0 0 1.6 11.2c0 2.535 2.87 4.6 6.4 4.6 3.529 0 6.399-2.065 6.399-4.6 0-.31-.035-.615-.102-.912.986-.159 1.737-1.042 1.737-2.094a2.1 2.1 0 0 0-.448-1.233ZM3.7 10.155a1.442 1.442 0 1 1 0-2.885 1.442 1.442 0 0 1 0 2.885Zm4.872 3.197c-1.579 0-3.003-.541-3.606-1.127a.512.512 0 0 1 .715-.734c.484.471 1.705.867 2.891.867 1.186 0 2.408-.396 2.892-.867a.512.512 0 0 1 .715.734c-.604.586-2.028 1.127-3.607 1.127Zm3.27-2.07a1.442 1.442 0 1 1 0-2.884 1.442 1.442 0 0 1 0 2.884Z"/></svg>
            Reddit
          </a>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  /* --- FAQ Dropdowns --- */
  .faq-list { margin: var(--sp-4) 0 }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: var(--sp-2);
    overflow: hidden;
    transition: border-color 200ms ease;
  }
  .faq-item:hover { border-color: rgba(242,104,34,0.3) }
  .faq-item[open] { border-color: var(--accent) }
  .faq-question {
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 48px;
  }
  .faq-question::-webkit-details-marker { display: none }
  .faq-question::after { content: '＋'; font-size: var(--text-lg); color: var(--accent); transition: transform .2s }
  .faq-item[open] .faq-question::after { content: '－' }
  .faq-answer {
    padding: 0 var(--sp-4) var(--sp-4);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.6;
  }
</style>
