---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';
import skillMods from '../../../data/skill-mod-combos.json';

export function getStaticPaths() {
  return skillMods.map((mod: any) => ({
    params: {
      slug: mod.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
    },
    props: { mod }
  }));
}

const { mod } = Astro.props;

const slug = mod.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = 'https://resurgencebuilds.com';

const title = `${mod.name} — ${mod.specialization} Skill Mod`;
const description = `${mod.name} is a ${mod.specialization} Skill Mod Combo in Division Resurgence. 2pc: ${mod.bonus2}. 3pc: ${mod.bonus3.substring(0, 120)}…`;

const breadcrumbs = [
  { name: 'Skill Mods', url: '/database/skill-mod-combos/' },
  { name: mod.name, url: '#' }
];

const specColor: Record<string, string> = {
  'Demolitionist': '#F26822',
  'Tech Operator': '#F5CC45',
  'Bulwark': '#3a7bd5',
  'Vanguard': '#22c55e',
  'Field Medic': '#a855f7',
};

const specBadgeColor = specColor[mod.specialization] || '#888';

const specClassId: Record<string, string> = {
  'Demolitionist': 'demolitionist',
  'Tech Operator': 'tech-operator',
  'Bulwark': 'bulwark',
  'Vanguard': 'vanguard',
  'Field Medic': 'field-medic',
};

const classHubSlug = specClassId[mod.specialization] || mod.specialization.toLowerCase().replace(/\s+/g, '-');

// Determine which skills this mod is for based on the 3pc description
const getSkillsFromBonus = (bonus3: string, spec: string): string => {
  const b = bonus3.toLowerCase();
  if (b.includes('artillery turret')) return 'Artillery Turret';
  if (b.includes('explosive seeker mine')) return 'Explosive Seeker Mine';
  if (b.includes('m32a1') || b.includes('grenade launcher')) return 'M32A1 Grenade Launcher';
  if (b.includes('striker drone')) return 'Striker Drone';
  if (b.includes('drone lock') || b.includes('drone overload')) return 'Striker Drone';
  if (b.includes('ballistic shield') || b.includes('phalanx shield')) return 'Ballistic Shield';
  if (b.includes('shield bash')) return 'Ballistic Shield';
  if (b.includes('shockwave spike')) return 'Shockwave Spike';
  if (b.includes('chemical trap')) return 'Chemical Trap';
  if (b.includes('oxidizing hive') || b.includes('oxidizing swarm')) return 'Oxidizing Hive';
  if (b.includes('support station')) return 'Support Station';
  if (b.includes('healing hive') || b.includes('healing swarm')) return 'Healing Hive';
  if (b.includes('smart cover')) return 'Smart Cover';
  if (b.includes('scanning pulse')) return 'Scanning Pulse';
  if (b.includes('tactical link')) return 'Tactical Link';
  if (spec === 'Demolitionist') return 'Demolitionist Skills';
  if (spec === 'Tech Operator') return 'Striker Drone';
  if (spec === 'Bulwark') return 'Ballistic Shield';
  if (spec === 'Vanguard') return 'Vanguard Skills';
  if (spec === 'Field Medic') return 'Field Medic Skills';
  return 'Specialization Skills';
};

const targetSkill = getSkillsFromBonus(mod.bonus3, mod.specialization);

// Build context based on specialization
const specOverview: Record<string, string> = {
  'Demolitionist': 'Demolitionist builds revolve around explosive AoE damage — Artillery Turrets, Seeker Mines, and the M32A1 Grenade Launcher. This spec stacks Engineering and Skill Crit to turn skills into room-clearing nukes. Pair the right mod combo with Jackpot or Fire Cycle gear sets and the numbers get silly fast.',
  'Tech Operator': 'Tech Operator builds live and die by the Striker Drone. Your drone is your primary damage source, your utility tool, and sometimes your healer all at once. Stack Engineering, Skill Crit, and drone-specific bonuses and watch it shred everything in the room before you finish reloading.',
  'Bulwark': 'Bulwark is the wall. Your entire kit revolves around the Ballistic Shield — absorbing hits, face-tanking bosses, and making your team feel safe enough to actually play the game. Toughness stacking is king, but the right mod combo can turn a pure tank into a surprisingly punchy brawler.',
  'Vanguard': 'Vanguard runs the show with Smart Cover, Scanning Pulse, and Tactical Link. You\'re the team\'s intel officer and force multiplier rolled into one. The best Vanguard builds balance personal firepower with team-wide buffs that make everyone hit harder and die less.',
  'Field Medic': 'Field Medic has two focuses: Combat Medicine (Healing Swarm, Healing Hive, Support Station) and Tactical Pharma (Oxidizing Swarm, Oxidizing Hive, Chemical Trap). The Combat Medicine path can also deal serious damage by stacking Toughness with Defensive Measures. These mod combos determine whether you are a pure healer or a corrosive area-pressure dealer.',
};

const specBuildGuide: Record<string, string> = {
  'Demolitionist': `For Demolitionist, this mod combo pairs well with Engineering-stacking gear sets like Jackpot (Skill Crit) and Fire Cycle (Skill Damage loops). Running Pressing Matter or Brains Over Brawn as your OS Protocol gives you multiplicative bonuses on top of whatever the 3-piece talent is doing. The Demolitionist Glass Cannon archetype — running all-in on Engineering with zero survivability — is the highest DPS ceiling in the game for skill builds.`,
  'Tech Operator': `Tech Operator builds want Long-term Effect (4pc) for Skill Duration and Engineering, plus Jackpot (2pc) for Skill Crit. Brains Over Brawn OS Protocol is the gold standard here. Stack Engineering on every piece and let your Striker Drone become an autonomous killing machine. The EMCAT and Thermite Charge mods are particularly nasty for PvP.`,
  'Bulwark': `Bulwark builds run Fury Strike (4pc) for Crit stacking or Self-Propelled Shield (4pc) for pure tankiness. Pair with Death From Afar or Fearless Warrior OS Protocol depending on whether you want to deal damage or absorb it. Saiynergy's 334k DPS Breacher build proves that tanks don't have to be boring — the right mod combo makes you both unkillable and dangerous.`,
  'Vanguard': `Vanguard builds typically run Phalanx Attack (4pc) for sustained DPS or Fury Strike (4pc) for burst. Dominating Presence OS Protocol is the premium pick. Smart Cover and Scanning Pulse mods give you team-wide buffs that stack with your gear set bonuses — that multiplicative scaling is how top squads push Legendary content.`,
  'Field Medic': `Field Medic builds have two paths: Combat Medicine with Captain Cow (4pc) and Toughness stacking for healing + Defensive Measures damage, or Tactical Pharma with Jackpot (4pc) and Engineering for Oxidizing Swarm corrosive pressure. The mod combo you choose determines which path hits harder. Chemical Trap mods with Corrosive application are strong in PvP.`,
};

// Generate synergies text based on specialization
const specSynergy: Record<string, string> = {
  'Demolitionist': 'Gear sets: Jackpot (Skill Crit stacking), Fire Cycle (skill damage loops), Boom-Shakalaka (explosive radius). OS Protocols: Pressing Matter, Brains Over Brawn, any Engineering protocol. Weapon talents: In Sync (skill+weapon damage loop), Spike (skill damage on headshot).',
  'Tech Operator': 'Gear sets: Long-term Effect (Skill Duration/Engineering), Jackpot (Skill Crit). OS Protocols: Brains Over Brawn, Tech Supremacy. Weapon talents: In Sync, Spike. The Striker Drone benefits massively from Skill Crit Chance stacking — 50%+ Crit Chance on your drone turns every attack into a potential proc.',
  'Bulwark': 'Gear sets: Fury Strike (Crit stacking), Self-Propelled Shield (Armor/Toughness), Phalanx Attack (sustained DPS). OS Protocols: Death From Afar, Fearless Warrior. Weapon talents: Optimist, Killer. Toughness-stacked Bulwark with the right mod combo makes you the last person standing in every wipe scenario.',
  'Vanguard': 'Gear sets: Phalanx Attack (Rate of Fire/Multi-Shot), Fury Strike (Crit), Double Agent (hybrid). OS Protocols: Dominating Presence, Death From Afar. Weapon talents: Killer, Concentrated Fire. Smart Cover mods stack multiplicatively with cover-based gear set bonuses.',
  'Field Medic': 'Gear sets: Captain Cow (Support Station duration), Healing Elites (T2 exclusive), Jackpot (for Tactical Pharma DPS). OS Protocols: Medical Excellence (Combat Medicine cornerstone), Pressing Matter (Tactical Pharma CDR). The Defensive Measures mod combo turns your Healing Hive into an offensive weapon based on your Toughness.',
};

const faqs = [
  {
    question: `What does the ${mod.name} skill mod combo do in Division Resurgence?`,
    answer: `${mod.name} is a ${mod.specialization} skill mod combo focused on ${targetSkill}. Equip 2 matching mods for the 2-piece bonus (${mod.bonus2}), or slot all 3 for the 3-piece: "${mod.bonus3}" — that 3-piece is where the real power is.`
  },
  {
    question: `Which builds use ${mod.name} in Division Resurgence?`,
    answer: `${mod.name} belongs on ${mod.specialization} builds that run ${targetSkill}. ${specBuildGuide[mod.specialization]?.split('.')[0] || 'Pair it with the right gear set and OS Protocol for maximum synergy'}.`
  },
  {
    question: `How do I get ${mod.name} skill mods in Division Resurgence?`,
    answer: `Skill mods drop from endgame activities — missions, Dark Zone, Summit, and open world events. Higher difficulty means better quality rolls. You can also craft them at the Crafting Station if you have the blueprint. Farm ${mod.specialization}-targeted loot zones for the best odds of getting this specific combo.`
  }
];

const modLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: `${siteUrl}/database/skill-mod-combos/${slug}/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/skill-mod-combos/${slug}/` },
  datePublished: '2026-05-30',
  dateModified: '2026-05-30',
};

// Find related mods (same specialization, different mod)
const relatedMods = skillMods
  .filter((m: any) => m.specialization === mod.specialization && m.id !== mod.id)
  .slice(0, 4);

const toModSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} jsonLd={modLd} faqs={faqs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Skill Mod" />

    <div class="smc-detail">
      <!-- Header -->
      <div class="smc-header">
        <div class="smc-header__top">
          <h1 class="smc-title">{mod.name}</h1>
          <div class="smc-badges">
            <span class="smc-badge" style={`border-color: ${specBadgeColor}; color: ${specBadgeColor};`}>{mod.specialization}</span>
            <span class="smc-badge smc-badge--skill" style="border-color: #b8b8c0; color: #b8b8c0;">{targetSkill}</span>
          </div>
        </div>
        <div style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: #6DAA45; background: rgba(109, 170, 69, 0.1); border: 1px solid rgba(109, 170, 69, 0.25); padding: 6px 14px; border-radius: 999px; margin-top: var(--sp-4); letter-spacing: 0.02em;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>Last verified for <strong>Patch 1.2.1</strong></span>
        </div>
      </div>

      <!-- Overview -->
      <div class="smc-section">
        <h2 class="smc-section__title">Overview</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p><strong style="color: #fff;">{mod.name}</strong> is a <strong style="color: #fff;">{mod.specialization}</strong> Skill Mod Combo in Division Resurgence that buffs your <strong style="color: var(--accent);">{targetSkill}</strong>. Equip 2 mods from this set for a stat bump, or commit to all 3 for the real payoff — a talent-grade bonus that changes how your skill performs in combat.</p>
          <p>{specOverview[mod.specialization] || `This mod combo is tied to the ${mod.specialization} specialization and enhances your skill builds when fully equipped.`}</p>
        </div>
      </div>

      <!-- Set Bonuses -->
      <div class="smc-section">
        <h2 class="smc-section__title">Set Bonuses</h2>

        <div class="smc-bonus-card smc-bonus-card--2pc">
          <div class="smc-bonus-card__header">
            <span class="smc-bonus-badge smc-bonus-badge--2">2</span>
            <span class="smc-bonus-card__label">Piece Bonus</span>
          </div>
          <p class="smc-bonus-card__text">{mod.bonus2}</p>
          <p class="smc-bonus-card__note">A flat stat bump. Not exciting, but it adds up across your loadout. This kicks in just from equipping 2 mods from the {mod.name} set — no effort required.</p>
        </div>

        <div class="smc-bonus-card smc-bonus-card--3pc">
          <div class="smc-bonus-card__header">
            <span class="smc-bonus-badge smc-bonus-badge--3">3</span>
            <span class="smc-bonus-card__label">Piece Bonus</span>
          </div>
          <p class="smc-bonus-card__text">{mod.bonus3}</p>
          <p class="smc-bonus-card__note">This is the money shot. The 3-piece bonus is what you're farming for — it fundamentally changes how {targetSkill} interacts with your build and stacks with your gear set bonuses for multiplicative gains.</p>
        </div>
      </div>

      <!-- Best Builds -->
      <div class="smc-section">
        <h2 class="smc-section__title">Best Builds</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{specBuildGuide[mod.specialization] || `This mod combo fits into ${mod.specialization} builds that focus on ${targetSkill} performance. Match it with compatible gear sets and OS Protocols for the best results.`}</p>
          <p>The 2-piece bonus (<strong style="color: #fff;">{mod.bonus2}</strong>) is a nice baseline stat, but the real build-defining synergy comes from the 3-piece. When you're theory-crafting, treat the 3-piece as a talent slot — if it doesn't synergize with your gear set 4-piece bonus, you're leaving damage on the table.</p>
        </div>
      </div>

      <!-- Synergies -->
      <div class="smc-section">
        <h2 class="smc-section__title">Synergies</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{specSynergy[mod.specialization] || `Look for gear sets and OS Protocols that stack ${mod.specialization} bonuses. The multiplicative interaction between mod combos and gear set bonuses is where endgame builds get their power.`}</p>
          <p>Remember: skill mod combo bonuses are a separate layer from gear sets, brand sets, and OS Protocols. They all stack. That's how you go from "decent" to "everything dies before the animation finishes."</p>
        </div>
      </div>

      <!-- Related Mods -->
      {relatedMods.length > 0 && (
        <div class="smc-section">
          <h2 class="smc-section__title">Other {mod.specialization} Skill Mods</h2>
          <div class="smc-related-grid">
            {relatedMods.map((related: any) => (
              <a href={`/database/skill-mod-combos/${toModSlug(related.name)}/`} class="smc-related-card">
                <strong style="color: #fff;">{related.name}</strong>
                <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">2pc: {related.bonus2}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Related Links -->
      <div class="smc-related-links">
        <a href="/database/skill-mod-combos/" class="smc-link">&larr; All Skill Mods</a>
        <a href="/database/os-protocols/" class="smc-link">OS Protocols</a>
        <a href="/database/gear-set-effects/" class="smc-link">Gear Sets</a>
        <a href={`/class/${classHubSlug}/`} class="smc-link">{mod.specialization} Builds</a>
      </div>
    </div>

    <AdSenseUnit />
  </div>
</BaseLayout>

<style>
  .smc-detail {
    max-width: 700px;
  }

  .smc-header {
    margin-bottom: var(--sp-8);
  }

  .smc-header__top {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .smc-title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(135deg, #fff 60%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .smc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .smc-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 5px 14px;
    border: 1px solid;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Sections */
  .smc-section {
    margin-bottom: var(--sp-8);
  }

  .smc-section__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 800;
    color: #fff;
    margin: 0 0 var(--sp-4) 0;
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* Bonus Cards */
  .smc-bonus-card {
    padding: var(--sp-5);
    background: rgba(0,0,0,0.25);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: var(--sp-4);
  }

  .smc-bonus-card--2pc {
    border-left: 3px solid #60a5fa;
  }

  .smc-bonus-card--3pc {
    border-left: 3px solid var(--accent);
  }

  .smc-bonus-card__header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .smc-bonus-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 800;
    color: #fff;
  }

  .smc-bonus-badge--2 {
    background: rgba(96, 165, 250, 0.25);
    border: 1px solid rgba(96, 165, 250, 0.5);
  }

  .smc-bonus-badge--3 {
    background: rgba(242, 104, 34, 0.25);
    border: 1px solid rgba(242, 104, 34, 0.5);
  }

  .smc-bonus-card__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #b8b8c0;
  }

  .smc-bonus-card__text {
    color: #fff;
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.6;
    margin: 0 0 var(--sp-3) 0;
  }

  .smc-bonus-card__note {
    color: #8888a0;
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
  }

  /* Related mods grid */
  .smc-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-3);
  }

  .smc-related-card {
    display: block;
    padding: var(--sp-4);
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .smc-related-card:hover {
    border-color: var(--accent);
    background: rgba(242,104,34,0.06);
  }

  /* Related links */
  .smc-related-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    padding-top: var(--sp-6);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .smc-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    padding: var(--sp-2) var(--sp-4);
    background: rgba(242,104,34,0.08);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .smc-link:hover {
    background: rgba(242,104,34,0.15);
    border-color: var(--accent);
  }
</style>
