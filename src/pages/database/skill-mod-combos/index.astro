---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import skillMods from '../../../data/skill-mod-combos.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Division Resurgence Skill Mod Combos & Mods Guide";
const description = "Every Skill Mod Combo in Division Resurgence and their 2-piece and 3-piece set bonuses. Pair them wrong and your build is a participation trophy.";
const breadcrumbs = [
  { name: 'Skill Mod Combos', url: '/database/skill-mod-combos/' }
];

const specializations = [...new Set(skillMods.map(m => m.specialization))];

const getSpecClass = (spec: string) => {
  const s = spec.toLowerCase();
  if (s.includes('demolitionist')) return 'tag--demo';
  if (s.includes('tech operator')) return 'tag--tech';
  if (s.includes('bulwark')) return 'tag--bulwark';
  if (s.includes('vanguard')) return 'tag--vanguard';
  if (s.includes('medic')) return 'tag--medic';
  return '';
};

const toSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const faqs = [
  { question: "What are skill mod combos in Division Resurgence?", answer: "Skill mod combos are set bonuses you get from equipping matching skill mods. Slot 2 mods from the same combo set for a 2-piece bonus, or go all-in with 3 matching mods for the full 3-piece bonus. They're tied to specific specializations, so make sure you're matching mods that work with your class." },
  { question: "How do I get skill mods in Division Resurgence?", answer: "Skill mods drop from endgame activities - missions, open world events, Dark Zone, and weekly bounties. Higher difficulty means better mod quality. You can also craft them at the Crafting Station once you've unlocked the blueprints. Farm targeted loot areas if you're chasing a specific combo set." },
  { question: "Do skill mod combo bonuses stack with gear set bonuses?", answer: "Yes, they stack. Skill mod combo bonuses are completely separate from gear set bonuses and brand set bonuses. You can run a full 4-piece gear set and a 3-piece skill mod combo at the same time. This is how endgame skill builds get absurd — layering every bonus source the game gives you." },
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Skill Mod Combos',
  description: description,
  numberOfItems: skillMods.length,
  itemListElement: skillMods.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://resurgencebuilds.com/database/skill-mod-combos/${toSlug(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `https://resurgencebuilds.com/database/skill-mod-combos/${toSlug(item.name)}/`,
      name: item.name,
      description: `${item.name} — ${item.specialization} Skill Mod Combo. 2pc: ${item.bonus2}. 3pc: ${item.bonus3}`,
      url: `https://resurgencebuilds.com/database/skill-mod-combos/${toSlug(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Skill Mod Combos"
  subheading="Pairing the right skill mods unlocks powerful synergy bonuses. Two pieces or three — know which combo fits your chaos."
  jsonLd={itemListLd}
  lastVerified="Patch 1.1.2.2"
  {faqs}
>
  <div class="db-filters">
    <div class="filter-group" id="filter-spec">
      <span class="filter-label">Specialization:</span>
      <div class="filter-bar">
        <button class="filter-btn is-active" data-filter="all">All</button>
        {specializations.map(s => <button class="filter-btn" data-filter={s}>{s}</button>)}
      </div>
    </div>
  </div>

  <div class="db-grid" id="combos-grid">
    {skillMods.map((mod) => (
      <a href={`/database/skill-mod-combos/${toSlug(mod.name)}/`} class="db-card-link" data-spec={mod.specialization} style="text-decoration:none;color:inherit;display:block;">
        <article class="db-card" style="height:100%;">
          <div class="db-card__header">
            <div>
              <h2 class="db-card__title">{mod.name}</h2>
              <span class={`tag ${getSpecClass(mod.specialization)}`} style="margin-top:var(--sp-2);display:inline-block;">{mod.specialization}</span>
            </div>
          </div>
          
          <div class="db-card__body">
            <div class="bonus-block">
              <div class="bonus-group">
                <span class="bonus-label bonus-label-2">
                  <span class="bonus-badge bonus-badge-2">2</span>
                  Piece Bonus
                </span>
                <p class="bonus-text">{mod.bonus2}</p>
              </div>
            </div>

            <div class="bonus-block">
              <div class="bonus-group">
                <span class="bonus-label bonus-label-3">
                  <span class="bonus-badge bonus-badge-3">3</span>
                  Piece Bonus
                </span>
                <p class="bonus-text">{mod.bonus3}</p>
              </div>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
<AdSenseUnit />
</DatabaseLayout>

<script>
  let currentSpec = 'all';

  const filterSpecBar = document.getElementById('filter-spec');
  const grid = document.getElementById('combos-grid');

  const updateFilters = () => {
    requestAnimationFrame(() => {
      grid?.querySelectorAll('.db-card-link').forEach(link => {
        const el = link as HTMLElement;
        const matchesSpec = currentSpec === 'all' || el.dataset.spec === currentSpec;
        el.style.display = matchesSpec ? '' : 'none';
      });
    });
  };

  if (filterSpecBar && grid) {
    filterSpecBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn');
      if (!btn) return;
      filterSpecBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      currentSpec = btn.getAttribute('data-filter') || 'all';
      updateFilters();
    });
  }
</script>
