---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';

import osProtocols from '../../data/os-protocols.json';
import skillModCombos from '../../data/skill-mod-combos.json';
import weaponTalents from '../../data/weapon-talents.json';
import standardWeapons from '../../data/standard-weapons.json';
import backpackTalents from '../../data/backpack-talents.json';
import bodyArmorTalents from '../../data/body-armor-talents.json';
import bonusAttributes from '../../data/bonus-attributes.json';
import gearSetEffects from '../../data/gear-set-effects.json';
import exoticWeapons from '../../data/exotic-weapons.json';

const title = "The Division Resurgence Database";
const description = "Complete Division Resurgence database - OS Protocols, weapons, gear sets, talents, skill mods, and bonus attributes. Every stat verified in-game for Patch 1.2.1.";

const breadcrumbs = [
  { name: 'Database', url: '/database/' }
];

const sections = [
  {
    title: 'OS Protocols',
    href: '/database/os-protocols/',
    count: osProtocols.length,
    description: 'Every OS Protocol in the game with stats, talents, and build recommendations. Your sixth gear slot.',
    icon: '⬡',
    color: '#F5CC45',
  },
  {
    title: 'Skill Mod Combos',
    href: '/database/skill-mod-combos/',
    count: skillModCombos.length,
    description: 'Firmware set bonuses for every skill. Stack the right mods and your skills hit twice as hard.',
    icon: '⚙',
    color: '#3b82f6',
  },
  {
    title: 'Weapon Talents',
    href: '/database/weapon-talents/',
    count: weaponTalents.length,
    description: 'Every weapon talent with proc conditions, damage values, and which builds they fit.',
    icon: '⚔',
    color: '#ef4444',
  },
  {
    title: 'Weapons',
    href: '/database/weapons/',
    count: standardWeapons.length,
    description: 'Standard weapon stats - RPM, magazine, damage type. ARs, SMGs, LMGs, MMRs, and shotguns.',
    icon: '🔫',
    color: '#F26822',
  },
  {
    title: 'Backpack Talents',
    href: '/database/backpack-talents/',
    count: backpackTalents.length,
    description: 'Backpack talent breakdowns with tier comparisons and recommended gear set pairings.',
    icon: '🎒',
    color: '#6DAA45',
  },
  {
    title: 'Body Armor Talents',
    href: '/database/body-armor-talents/',
    count: bodyArmorTalents.length,
    description: 'Chest piece talents ranked by archetype. Toymaker, Glass Cannon, Deep Focus, and more.',
    icon: '🛡',
    color: '#a855f7',
  },
  {
    title: 'Bonus Attributes',
    href: '/database/bonus-attributes/',
    count: bonusAttributes.length,
    description: 'Every bonus attribute that can roll on gear. Know what to chase and what to trash.',
    icon: '📊',
    color: '#14b8a6',
  },
  {
    title: 'Gear Set Effects',
    href: '/database/gear-set-effects/',
    count: gearSetEffects.length,
    description: 'Full breakdown of every gear set - 2pc through 4pc bonuses, best-in-slot combinations.',
    icon: '🏆',
    color: '#f59e0b',
  },
  {
    title: 'Exotic Weapons',
    href: '/database/exotic-weapons/',
    count: exoticWeapons.length,
    description: 'Every exotic weapon with unique talents, stat ranges, and how to farm each one.',
    icon: '💀',
    color: '#F26822',
  },
];

const totalItems = sections.reduce((sum, s) => sum + s.count, 0);

const faqs = [
  {
    question: "How is the Resurgence Builds database different from a wiki?",
    answer: "Every entry in our database is verified in-game on the current patch. We don't copy-paste data mines or rely on beta information that's been wrong for six months. When a stat says +24% Skill Intensity, someone on our team has opened the tooltip and confirmed it. The wiki can't say that."
  },
  {
    question: "How often is the database updated?",
    answer: "We update within 48 hours of every patch and hotfix. When Ubisoft changes a talent, a gear set bonus, or a weapon stat, we verify the new values in-game and update the database before publishing. Every page has a 'Last verified for Patch X.X.X' stamp so you know exactly how fresh the data is."
  },
  {
    question: "Can I use this database with the Build Planner?",
    answer: "Absolutely. The database and the Build Planner are designed to work together. Look up your gear set bonuses here, plan your attribute priorities, then hop into the Build Planner at /builder/ to see the full loadout come together."
  },
];

const siteUrl = 'https://resurgencebuilds.com';
const articleLd = {
  '@type': 'Article',
  headline: title,
  description: description,
  url: `${siteUrl}/database/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/` },
  datePublished: '2026-05-30',
  dateModified: '2026-05-31',
};
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} jsonLd={articleLd} faqs={faqs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Database" />
    <h1 class="heading-accent" style="font-size: var(--text-4xl); margin-bottom: var(--sp-3);">The Division Resurgence Database</h1>

    <div style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: #6DAA45; background: rgba(109, 170, 69, 0.1); border: 1px solid rgba(109, 170, 69, 0.25); padding: 6px 14px; border-radius: 999px; margin-bottom: var(--sp-6); letter-spacing: 0.02em;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      <span>Last verified for <strong>Patch 1.2.1</strong> · {totalItems} entries</span>
    </div>

    <p style="color: var(--ink-muted); margin-bottom: var(--sp-8); font-size: var(--text-base); max-width: 70ch; line-height: 1.7;">
      Every stat, talent, and gear set bonus in Division Resurgence - verified in-game and updated within 48 hours of every patch. This isn't a data mine dump from six months ago. If it's in this database, someone on the team opened the tooltip and confirmed it on the current live build. Use it to plan your loadouts, check talent interactions, and stop guessing whether that Reddit post from March is still accurate. Spoiler: it's not.
    </p>

    <div class="db-index-grid">
      {sections.map(section => (
        <a href={section.href} class="db-index-card">
          <div class="db-index-card__icon" style={`color: ${section.color}; border-color: ${section.color};`}>
            <span>{section.icon}</span>
          </div>
          <div class="db-index-card__body">
            <div style="display: flex; align-items: baseline; gap: var(--sp-2); margin-bottom: var(--sp-1);">
              <h2 class="db-index-card__title">{section.title}</h2>
              <span class="db-index-card__count" style={`color: ${section.color};`}>{section.count}</span>
            </div>
            <p class="db-index-card__desc">{section.description}</p>
          </div>
          <span class="db-index-card__arrow">→</span>
        </a>
      ))}
    </div>

    <AdSenseUnit />

    {faqs && faqs.length > 0 && (
      <div class="faq-section" style="margin-top: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--sp-4);">Frequently Asked Questions</h2>
        <div class="faq-list" style="display: flex; flex-direction: column; gap: var(--sp-2);">
          {faqs.map(faq => (
            <details class="faq-item">
              <summary class="faq-question">{faq.question}</summary>
              <p class="faq-answer">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .db-index-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
    margin-bottom: var(--sp-8);
  }

  @media (min-width: 640px) {
    .db-index-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .db-index-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .db-index-card {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: linear-gradient(145deg, rgba(30,30,36,0.9) 0%, rgba(20,20,24,0.95) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .db-index-card::before {
    content: '';
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 0 0 4px 4px;
  }

  .db-index-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 25px rgba(242, 104, 34, 0.1);
    border-color: rgba(242, 104, 34, 0.3);
  }

  .db-index-card:hover::before { opacity: 1; }

  .db-index-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    border-radius: 12px;
    background: rgba(0,0,0,0.3);
    border: 1px solid;
    flex-shrink: 0;
  }

  .db-index-card__body {
    flex: 1;
    min-width: 0;
  }

  .db-index-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .db-index-card__count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .db-index-card__desc {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .db-index-card__arrow {
    font-size: var(--text-xl);
    color: var(--ink-muted);
    transition: color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .db-index-card:hover .db-index-card__arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* FAQ styles matching other pages */
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 200ms ease;
  }
  .faq-item:hover { border-color: rgba(242,104,34,0.3) }
  .faq-item[open] { border-color: var(--accent) }
  .faq-question {
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 48px;
  }
  .faq-question::-webkit-details-marker { display: none }
  .faq-question::after { content: '＋'; font-size: var(--text-lg); color: var(--accent); transition: transform .2s }
  .faq-item[open] .faq-question::after { content: '－' }
  .faq-answer {
    padding: 0 var(--sp-4) var(--sp-4);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.6;
  }
</style>
