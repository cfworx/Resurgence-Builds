---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import weaponTalents from '../../data/weapon-talents.json';
import AdSenseUnit from '../../components/AdSenseUnit.astro';

const title = "Division Resurgence Weapon Talents & Attachments Guide";
const description = "Every weapon talent in Division Resurgence. Some of these will triple your DPS. Most will make you wonder what Ubisoft was thinking.";
const breadcrumbs = [
  { name: 'Weapon Talents', url: '/database/weapon-talents/' }
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Weapon Talents',
  description: description,
  numberOfItems: weaponTalents.length,
  itemListElement: weaponTalents.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: Astro.url.href,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: Astro.url.href,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Weapon Talents"
  subheading="The complete list of weapon talents and their effects. Slot the right one and watch your damage multiply obscenely."
  jsonLd={itemListLd}
  lastVerified="Patch 1.2.1"
>
  <div class="db-grid" id="talents-grid">
    {weaponTalents.map((talent) => (
      <article class="db-card">
        <div class="db-card__header">
          <div>
            <h2 class="db-card__title">{talent.name}</h2>
          </div>
        </div>
        
        <div class="db-card__body">
          <div class="talent-desc">
            <p>{talent.description}</p>
          </div>
          
          <div class="source-section">
            <span class="source-label">Source Weapons</span>
            <p class="source-text">Rolls on T2 standard & exotic weapons — see Build Planner to equip</p>
          </div>
        </div>
      </article>
    ))}
  </div>
<AdSenseUnit />
</DatabaseLayout>
