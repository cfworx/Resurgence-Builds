---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import backpackTalents from '../../../data/backpack-talents.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Division Resurgence Backpack Talents & Best Builds";
const description = "Every Backpack Talent in Division Resurgence. The good, the bad, and the ones that make you wonder if anyone playtested them.";
const breadcrumbs = [
  { name: 'Backpack Talents', url: '/database/backpack-talents/' }
];

const faqs = [
  { question: "What are backpack talents in Division Resurgence?", answer: "Backpack talents are passive abilities that roll on Tier 2 backpacks. Each backpack can have one talent, and it activates automatically — no button press needed. They affect things like healing, ammo management, and damage output. You equip them through the Build Planner." },
  { question: "What is the best backpack talent in Division Resurgence?", answer: "It depends on your build, but the most universally strong backpack talents buff sustain or amplify your main damage source. DPS players usually want talents that boost weapon damage on kill or after using skills. Tank and healer builds lean toward talents that regenerate armor or extend skill effects. Check the individual talent descriptions on this page to match one to your playstyle." },
  { question: "Can you reroll backpack talents in Division Resurgence?", answer: "Yes. You can recalibrate one attribute or talent per gear piece at the Recalibration Station. If your backpack dropped with a garbage talent but great stats, you can swap the talent out. Just remember — you can only recalibrate one slot per item, so pick wisely." },
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Backpack Talents',
  description: description,
  numberOfItems: backpackTalents.length,
  itemListElement: backpackTalents.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.url.origin}/database/backpack-talents/${item.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: `${Astro.url.origin}/database/backpack-talents/${item.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Backpack Talents"
  subheading="Every backpack talent in the game. Most of them are mid. A few of them will change your life. We've sorted them so you don't have to."
  jsonLd={itemListLd}
  lastVerified="Patch 1.1.2.2"
  {faqs}
>
  <div class="db-grid" id="talents-grid">
    {backpackTalents.map((talent) => {
      const slug = talent.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      return (
        <a href={`/database/backpack-talents/${slug}/`} class="db-card-link" style="text-decoration: none; color: inherit;">
          <article class="db-card">
            <div class="db-card__header">
              <div>
                <h2 class="db-card__title">{talent.name}</h2>
              </div>
            </div>
            
            <div class="db-card__body">
              <div class="talent-desc">
                <p>{talent.description}</p>
              </div>
              
              <div class="source-section">
                <span class="source-label">Source Backpack</span>
                <p class="source-text">Rolls on T2 backpacks — equip via Build Planner</p>
              </div>
            </div>
          </article>
        </a>
      );
    })}
  </div>
<AdSenseUnit label="Advertisement — database category" />
</DatabaseLayout>
