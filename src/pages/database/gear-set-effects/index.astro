---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import gearSets from '../../../data/gear-set-effects.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const slugify = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const title = "Division Resurgence Gear Sets & Brand Sets | Best Builds";
const description = "Every gear set and brand set in Division Resurgence with their 2, 3, and 4-piece bonuses. Stack them right and enemies file complaints.";
const breadcrumbs = [
  { name: 'Gear Set Effects', url: '/database/gear-set-effects/' }
];

const faqs = [
  { question: "How do gear sets work in Division Resurgence?", answer: "Gear sets give you stacking bonuses for wearing multiple pieces from the same set. Equip 2 pieces for a small bonus, 3 for a stronger one, and 4 pieces to unlock the full set effect — which is usually a build-defining ability. You can mix brand sets and gear sets, but the 4-piece bonus is where the real power spike lives." },
  { question: "What is the best gear set in Division Resurgence?", answer: "There's no single best gear set — it depends on your playstyle and specialization. DPS builds usually gravitate toward sets that buff weapon damage or crit. Tank builds want sets with armor bonuses and threat generation. Skill builds look for Engineering boosts and skill damage. Check the 4-piece bonuses on this page and pick the one that matches your build's core loop." },
  { question: "Should I use a gear set or brand set in Division Resurgence?", answer: "Both are viable. Gear sets give you a powerful 4-piece bonus but lock you into specific pieces. Brand sets offer more flexibility since each brand has its own 2 and 3-piece bonuses you can mix and match. Most endgame builds use a 4-piece gear set core with brand set pieces filling the remaining slots for extra stat coverage." },
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Gear Set Effects',
  description: description,
  numberOfItems: gearSets.length,
  itemListElement: gearSets.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.url.origin}/database/gear-set-effects/${slugify(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: `${Astro.url.origin}/database/gear-set-effects/${slugify(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Gear Set Effects"
  subheading="Every gear set and their 2, 3, and 4-piece bonuses. Stack these correctly and you become an entirely different class of problem."
  jsonLd={itemListLd}
  lastVerified="Patch 1.1.2.2"
  {faqs}
>
  <div class="db-grid" id="gear-grid">
    {gearSets.map((gear) => (
      <a href={`/database/gear-set-effects/${slugify(gear.name)}/`} class="db-card-link">
        <article class="db-card">
          <div class="db-card__header">
            <div>
              <h2 class="db-card__title">{gear.name}</h2>
            </div>
          </div>
          
          <div class="db-card__body">
            <div class="bonus-block">
              <div class="bonus-group">
                <span class="bonus-label bonus-label-2">
                  <span class="bonus-badge bonus-badge-2">2</span>
                  Piece Bonus
                </span>
                <p class="bonus-text">{gear.bonus2}</p>
              </div>
            </div>

            <div class="bonus-block">
              <div class="bonus-group">
                <span class="bonus-label bonus-label-3">
                  <span class="bonus-badge bonus-badge-3">3</span>
                  Piece Bonus
                </span>
                <p class="bonus-text">{gear.bonus3}</p>
              </div>
            </div>

            <div class="bonus-block">
              <div class="bonus-group">
                <span class="bonus-label bonus-label-4">
                  <span class="bonus-badge bonus-badge-4">4</span>
                  Piece Bonus
                </span>
                <p class="bonus-text">{gear.bonus4}</p>
              </div>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
<AdSenseUnit />
</DatabaseLayout>

<style>
  .db-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .db-card-link .db-card {
    height: 100%;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .db-card-link:hover .db-card {
    border-color: rgba(242,104,34,0.4);
    box-shadow: 0 0 20px rgba(242,104,34,0.08);
  }
</style>
