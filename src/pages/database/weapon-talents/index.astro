---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import weaponTalents from '../../../data/weapon-talents.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Division Resurgence Weapon Talents & Attachments Guide";
const description = "Every weapon talent in Division Resurgence. Some of these will triple your DPS. Most will make you wonder what Ubisoft was thinking.";
const breadcrumbs = [
  { name: 'Weapon Talents', url: '/database/weapon-talents/' }
];

const faqs = [
  { question: "What are weapon talents in Division Resurgence?", answer: "Weapon talents are passive or conditional abilities that roll on Tier 2 weapons. Each weapon gets one talent, and it can dramatically change how the gun performs — from boosting damage on consecutive hits to refilling your magazine on kills. The talent is often more important than the weapon's base stats." },
  { question: "What is the best weapon talent in Division Resurgence?", answer: "The best weapon talent depends on your weapon type and build. For sustained DPS with ARs and LMGs, talents that ramp damage on hits are king. For burst damage with Marksman Rifles, look for talents that reward precision. SMG builds love anything that procs on close-range kills. Read the talent descriptions below and match one to how you actually play, not what sounds cool on paper." },
  { question: "Can you change weapon talents in Division Resurgence?", answer: "Yes. You can recalibrate the talent on any Tier 2 weapon at the recalibration station. You need a donor weapon with the talent you want as a re-roll source. One recalibration slot per weapon, so if you already recalibrated a stat, you can't also swap the talent on that same gun." },
];

function toSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Weapon Talents',
  description: description,
  numberOfItems: weaponTalents.length,
  itemListElement: weaponTalents.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.url.origin}/database/weapon-talents/${toSlug(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: `${Astro.url.origin}/database/weapon-talents/${toSlug(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Weapon Talents"
  subheading="The complete list of weapon talents and their effects. Slot the right one and watch your damage multiply obscenely."
  jsonLd={itemListLd}
  lastVerified="Patch 1.1.2.2"
  {faqs}
>
  <div class="db-grid" id="talents-grid">
    {weaponTalents.map((talent) => (
      <a href={`/database/weapon-talents/${toSlug(talent.name)}/`} class="db-card-link" style="text-decoration: none; color: inherit; display: block;">
        <article class="db-card">
          <div class="db-card__header">
            <div>
              <h2 class="db-card__title">{talent.name}</h2>
            </div>
          </div>
          
          <div class="db-card__body">
            <div class="talent-desc">
              <p>{talent.description}</p>
            </div>
            
            <div class="source-section">
              <span class="source-label">Source Weapons</span>
              <p class="source-text">Rolls on T2 standard & exotic weapons — see Build Planner to equip</p>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
<AdSenseUnit />
</DatabaseLayout>
