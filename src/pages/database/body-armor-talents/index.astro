---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import armorTalents from '../../../data/body-armor-talents.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Division Resurgence Body Armor Talents & Best Builds";
const description = "Every Body Armor (Body Armor) Talent in Division Resurgence. Pick the right one and you're unkillable. Pick the wrong one and you're a loot donation.";
const breadcrumbs = [
  { name: 'Body Armor Talents', url: '/database/body-armor-talents/' }
];

const faqs = [
  { question: "What are body armor talents in Division Resurgence?", answer: "Body armor talents are passive abilities on Tier 2 Body Armor pieces. Your Body Armor talent is arguably the most impactful gear talent in the game because it directly affects survivability or damage output in every firefight. One talent per Body Armor piece, always active once equipped." },
  { question: "What is the best body armor talent for DPS in Division Resurgence?", answer: "For pure DPS, you want a Body Armor talent that amplifies weapon damage or gives you a damage bonus when certain conditions are met (like hitting crits or staying in cover). The strongest DPS Body Armor talents typically give a flat damage increase that multiplies with everything else in your build. Check the descriptions below — if it says 'amplified' damage, that's the good stuff." },
  { question: "What is the difference between backpack and body armor talents?", answer: "Backpack talents and body armor talents occupy separate gear slots and stack with each other. They’re different talent pools — you won’t find the same talent on both. Your Body Armor talent usually has a bigger impact on your build's identity, while backpack talents tend to provide sustain or utility bonuses. You want both working together." },
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Body Armor Talents',
  description: description,
  numberOfItems: armorTalents.length,
  itemListElement: armorTalents.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.url.origin}/database/body-armor-talents/${toSlug(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: `${Astro.url.origin}/database/body-armor-talents/${toSlug(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};

function toSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Body Armor Talents"
  subheading="The talent on your Body Armor piece is the most important decision you'll make in this game. Choose poorly and you're a walking loot piñata for Dark Zone rogues."
  jsonLd={itemListLd}
  lastVerified="Patch 1.1.2.2"
  {faqs}
>
  <div class="db-grid" id="talents-grid">
    {armorTalents.map((talent) => (
      <a href={`/database/body-armor-talents/${toSlug(talent.name)}/`} class="db-card-link" style="text-decoration: none; color: inherit;">
        <article class="db-card">
          <div class="db-card__header">
            <div>
              <h2 class="db-card__title">{talent.name}</h2>
            </div>
          </div>
          
          <div class="db-card__body">
            <div class="talent-desc">
              <p>{talent.description}</p>
            </div>
            
            <div class="source-section">
              <span class="source-label">Source Armor</span>
              <p class="source-text">Rolls on T2 Body Armor pieces — equip via Build Planner</p>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
<AdSenseUnit />
</DatabaseLayout>
