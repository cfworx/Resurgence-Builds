---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import bonusAttributes from '../../data/bonus-attributes.json';

const title = "Division Resurgence Bonus Attributes & Gear Score Guide";
const description = "Complete database of all Bonus Attributes in The Division Resurgence. Learn how to optimize your gear score and min-max your stats.";
const breadcrumbs = [
  { name: 'Bonus Attributes', url: '/database/bonus-attributes/' }
];

const getCategoryColor = (cat: string) => {
  switch(cat.toLowerCase()) {
    case 'firepower': return { color: '#f87171', bg: 'rgba(239,68,68,0.08)', border: 'rgba(239,68,68,0.25)' };
    case 'toughness': return { color: '#60a5fa', bg: 'rgba(59,130,246,0.08)', border: 'rgba(59,130,246,0.25)' };
    case 'engineering': return { color: '#facc15', bg: 'rgba(234,179,8,0.08)', border: 'rgba(234,179,8,0.25)' };
    default: return { color: '#b8b8c0', bg: 'rgba(255,255,255,0.04)', border: 'rgba(255,255,255,0.1)' };
  }
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Bonus Attributes"
  subheading="Every stat that can roll on your gear and weapons — organized by core function. Know your rolls, or suffer."
>
  <div class="db-grid" id="attributes-grid">
    {bonusAttributes.map((category) => {
      const palette = getCategoryColor(category.category);
      return (
        <article class="db-card" style={`border-color: ${palette.border};`}>
          <div class="db-card__header" style={`padding-bottom: var(--sp-4); border-bottom-color: ${palette.border};`}>
            <div style={`display:inline-flex;align-items:center;gap:var(--sp-3);background:${palette.bg};border:1px solid ${palette.border};padding:var(--sp-2) var(--sp-4);border-radius:8px;`}>
              <span style={`font-family:var(--font-heading);font-size:var(--text-xl);font-weight:900;color:${palette.color};`}>
                {category.category}
              </span>
              <span style={`font-family:var(--font-mono);font-size:var(--text-xs);color:${palette.color};opacity:0.7;`}>
                {category.attributes.length} stats
              </span>
            </div>
          </div>
          
          <div class="db-card__body">
            <ul class="attribute-list">
              {category.attributes.map(attr => (
                <li>{attr}</li>
              ))}
            </ul>
          </div>
        </article>
      );
    })}
  </div>
</DatabaseLayout>
