---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import armorTalents from '../../data/body-armor-talents.json';

const title = "Division Resurgence Body Armor Talents & Best Builds";
const description = "Complete database of all Body Armor (Chest) Talents in The Division Resurgence. Discover optimal gear sets and named items for PvP and PvE.";
const breadcrumbs = [
  { name: 'Database', url: '#' },
  { name: 'Body Armor Talents', url: '/database/body-armor-talents/' }
];
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Body Armor Talents"
  subheading="Browse the complete list of Body Armor (Chest) Talents and their powerful defensive and offensive effects."
>
  <div class="db-grid" id="talents-grid">
    {armorTalents.map((talent) => (
      <article class="db-card">
        <div class="db-card__header">
          <div>
            <h2 class="db-card__title">{talent.name}</h2>
          </div>
        </div>
        
        <div class="db-card__body">
          <div class="talent-desc">
            <p>{talent.description}</p>
          </div>
          
          <div class="source-section">
            <span class="source-label">Source Armor</span>
            <p class="source-text">Coming soon</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</DatabaseLayout>
