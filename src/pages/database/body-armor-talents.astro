---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import armorTalents from '../../data/body-armor-talents.json';

const title = "Division Resurgence Body Armor Talents & Best Builds";
const description = "Complete database of all Body Armor (Chest) Talents in The Division Resurgence. Discover optimal gear sets and named items for PvP and PvE.";
const breadcrumbs = [
  { name: 'Database', url: '#' },
  { name: 'Body Armor Talents', url: '/database/body-armor-talents/' }
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Database" />
    <h1 class="heading-accent">Body Armor Talents</h1>
    <p style="color:var(--ink-muted);margin-bottom:var(--sp-8);">
      Browse the complete list of Body Armor Talents and their powerful defensive and offensive effects.
    </p>

    <div class="db-grid" id="talents-grid">
      {armorTalents.map((talent) => (
        <article class="db-card">
          <div class="db-card__header">
            <h2 class="db-card__title">{talent.name}</h2>
          </div>
          
          <div class="db-card__body">
            <div class="talent-desc">
              <p>{talent.description}</p>
            </div>
            
            <div class="source-section">
              <span class="source-label">Source Armor</span>
              <p class="source-text">Coming soon...</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .db-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }

  @media (min-width: 768px) {
    .db-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .db-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .db-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--border-radius);
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .db-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.2);
    border-color: var(--accent);
  }

  .db-card__header {
    padding: var(--sp-4) var(--sp-5);
    background: linear-gradient(135deg, rgba(255, 115, 0, 0.1) 0%, rgba(255, 115, 0, 0) 100%);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .db-card__header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .db-card__title {
    font-size: var(--text-xl);
    font-weight: 800;
    margin: 0;
    color: #ffffff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    letter-spacing: 0.02em;
  }

  .db-card__body {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: var(--sp-5);
  }

  .talent-desc {
    flex-grow: 1;
  }

  .talent-desc p {
    font-size: var(--text-md);
    line-height: 1.7;
    margin: 0;
    color: var(--ink-light);
  }

  .source-section {
    margin-top: auto;
    background: rgba(255, 255, 255, 0.03);
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--border-radius);
    border-left: 3px solid var(--accent);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .source-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .source-text {
    font-size: var(--text-sm);
    margin: 0;
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
