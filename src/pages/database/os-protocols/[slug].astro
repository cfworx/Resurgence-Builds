---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';
import { truncateDesc } from '../../../utils/seo';
import osProtocols from '../../../data/os-protocols.json';

export function getStaticPaths() {
  return osProtocols.map((protocol: any) => ({
    params: { slug: protocol.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') },
    props: { protocol },
  }));
}

const { protocol } = Astro.props;

const title = `${protocol.name} OS Protocol`;
const description = truncateDesc(`${protocol.name}: ${protocol.rarity} ${protocol.specialization} OS Protocol. ${protocol.mainStat} ${protocol.mainValue}. Talent and stats breakdown.`);

const breadcrumbs = [
  { name: 'OS Protocols', url: '/database/os-protocols/' },
  { name: protocol.name, url: '#' },
];

const specColor = protocol.specialization === 'Engineering' ? '#F5CC45' :
                  protocol.specialization === 'Firepower' ? '#F26822' :
                  protocol.specialization === 'Toughness' ? '#3a7bd5' : '#888';

const rarityColor = protocol.rarity === 'High-End' ? '#F5CC45' :
                    protocol.rarity === 'Superior' ? '#a855f7' :
                    protocol.rarity === 'Specialized' ? '#3b82f6' : '#888';

const specClass = protocol.specialization === 'Engineering' ? 'Demolitionist, Tech Operator, or Tactical Pharma' :
                  protocol.specialization === 'Firepower' ? 'Vanguard' :
                  protocol.specialization === 'Toughness' ? 'Bulwark or Field Medic (Combat Medicine)' : 'any specialization';

const faqs = [
  {
    question: `Is ${protocol.name} a good OS Protocol in Division Resurgence?`,
    answer: `${protocol.name} is a ${protocol.rarity} ${protocol.specialization} OS Protocol that gives you ${protocol.mainStat} ${protocol.mainValue} plus ${protocol.attr1} ${protocol.val1}, ${protocol.attr2} ${protocol.val2}, and ${protocol.attr3} ${protocol.val3}. The talent — "${protocol.talentDescription.substring(0, 150)}${protocol.talentDescription.length > 150 ? '...' : ''}" — is the real reason you want this thing. If your build stacks ${protocol.specialization}, it slaps.`
  },
  {
    question: `Which specialization uses ${protocol.name}?`,
    answer: `${protocol.name} is a ${protocol.specialization} protocol, so it fits best on ${specClass} builds. You get ${protocol.mainStat} ${protocol.mainValue} as your main stat — plug it into any ${protocol.specialization}-stacking loadout and you'll feel the difference immediately.`
  },
  {
    question: `How do I get ${protocol.name} in Division Resurgence?`,
    answer: `${protocol.name} drops from weekly bounties, Conflicts, and endgame PvE. ${protocol.rarity === 'High-End' ? 'Fair warning — Gold protocols are rare as hell. You\'re grinding weekly bounties for multiple cycles before one shows up.' : protocol.rarity === 'Superior' ? 'Purple protocols drop pretty regularly from weekly bounties and endgame content. You won\'t be waiting forever.' : 'Blue protocols drop like candy from basically any endgame activity. You\'ll have a stack of these in no time.'} Weekly bounties are your most consistent farm.`
  }
];

const slug = protocol.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = 'https://resurgencebuilds.com';

const protocolLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${protocol.name} OS Protocol — Division Resurgence`,
  description: description,
  url: `${siteUrl}/database/os-protocols/${slug}/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/os-protocols/${slug}/` },
  datePublished: '2026-05-27',
  dateModified: '2026-05-30',
  ...(protocol.image ? { image: { '@type': 'ImageObject', url: `${siteUrl}${protocol.image}`, width: 620, height: 310 } } : {}),
  inLanguage: 'en-US',
  lastReviewed: '2026-05-30',
  wordCount: 600,
  about: { '@id': `${siteUrl}/#division-resurgence` },
};

const ogImage = protocol.image ? `${siteUrl}${protocol.image}` : undefined;
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} jsonLd={protocolLd} faqs={faqs} ogImage={ogImage}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="OS Protocol" />

    <div class="protocol-detail">
      <!-- Header -->
      <div class="protocol-header">
        <div class="protocol-header__top">
          <h1 class="protocol-title">{protocol.name}</h1>
          <div class="protocol-badges">
            <span class="protocol-badge" style={`border-color: ${rarityColor}; color: ${rarityColor};`}>{protocol.rarity}</span>
            <span class="protocol-badge" style={`border-color: ${specColor}; color: ${specColor};`}>{protocol.specialization}</span>
            {protocol.cooldown && (
              <span class="protocol-badge protocol-badge--cooldown">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {protocol.cooldown}
              </span>
            )}
          </div>
        </div>

        <div style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: #6DAA45; background: rgba(109, 170, 69, 0.1); border: 1px solid rgba(109, 170, 69, 0.25); padding: 6px 14px; border-radius: 999px; margin-top: var(--sp-4); letter-spacing: 0.02em;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>Last verified for <strong>Patch 1.1.2.2</strong></span>
        </div>
      </div>

      <!-- Protocol Image (if available) -->
      {protocol.image && (
        <div class="protocol-image-container">
          <img
            src={protocol.image}
            alt={protocol.imageAlt || `${protocol.name} OS Protocol in Division Resurgence`}
            loading="eager"
            decoding="async"
            class="protocol-image"
          />
        </div>
      )}

      <!-- Talent Section -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Talent</h2>
        <div class="protocol-talent-block">
          <p>{protocol.talentDescription}</p>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Stats</h2>

        <div class="protocol-main-stat">
          <span class="protocol-main-stat__label">Main Stat</span>
          <span class="protocol-main-stat__name">{protocol.mainStat}</span>
          <span class="protocol-main-stat__value">{protocol.mainValue}</span>
        </div>

        <div class="protocol-stats-grid">
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr1}</span>
            <span class="protocol-stat-row__value">{protocol.val1}</span>
          </div>
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr2}</span>
            <span class="protocol-stat-row__value">{protocol.val2}</span>
          </div>
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr3}</span>
            <span class="protocol-stat-row__value">{protocol.val3}</span>
          </div>
        </div>
      </div>

      <!-- Overview -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Overview</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{protocol.name} is a <strong style="color: #fff;">{protocol.rarity}</strong> OS Protocol in the <strong style="color: #fff;">{protocol.specialization}</strong> tree. If you're not familiar, OS Protocols are basically the sixth gear piece in your loadout — a chip that gives you a fat stat bonus and a unique talent that can make or break your build. {protocol.name} hands you <strong style="color: var(--accent);">{protocol.mainStat} {protocol.mainValue}</strong>, plus {protocol.attr1} ({protocol.val1}), {protocol.attr2} ({protocol.val2}), and {protocol.attr3} ({protocol.val3}) on top.</p>
          <p>But the talent is why you're here: <em>"{protocol.talentDescription}"</em> — that's the part that actually shapes how you play. {protocol.specialization === 'Engineering' ? 'As an Engineering protocol, this one is built for Demolitionist, Tech Operator, and Field Medic setups where your skills are doing the heavy lifting — damage or healing.' : protocol.specialization === 'Firepower' ? 'This is a Firepower protocol, so it\'s all about making your guns hit harder. Vanguard DPS mains, this is your lane. Works on any spec that leads with bullets.' : 'Toughness protocol = you\'re the wall. Core pick for Bulwark tank builds, Field Medic face-tankers, and anyone who needs to eat shots in Legendary or Dark Zone PvP without folding.'}</p>
        </div>
      </div>

      <!-- Build Use Cases -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Best Builds & Playstyles</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{protocol.name} belongs on <strong style="color: #fff;">{specClass}</strong> builds that are going all-in on {protocol.specialization}. That {protocol.mainStat} {protocol.mainValue} main stat is a straight multiplier on your build's core, and the talent kicks in when you're actually playing the way the build wants you to.</p>
          <p>{protocol.specialization === 'Engineering' ? 'Pair this with Jackpot (Skill Crit) or Long-term Effect (Skill Duration/Engineering) and your skills start hitting like trucks. The 4pc gear set bonus stacks multiplicatively with the OS Protocol talent — so together, they punch way harder than either one solo.' : protocol.specialization === 'Firepower' ? 'Run this alongside Fury Strike (Crit) if you want big per-shot numbers, or Phalanx Attack (Multi-Shot/Rate of Fire) if sustained DPS is your thing. Weapon talent choice matters too — In Sync, Concentrated Fire, or Killer on your primary all stack nicely with this OS bonus.' : 'Slap this on with Fearless Warrior (DR/Damage) or Self-Propelled Shield (Armor/Health) and you become unkillable. If you\'ve got access to Healing Elites (T2-only), that\'s the premium combo — disgusting survivability on top of your OS Protocol talent.'}</p>
        </div>
      </div>

      <!-- Stacking & Synergies -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Stacking & Synergies</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>Here's why OS Protocol choice matters so much: the talent stacks <strong style="color: #fff;">multiplicatively</strong> with gear set bonuses and weapon talents. It's not an additive bonus — it multiplies your total output. Pick the right OS Protocol and you're looking at 30-50% more effective DPS or healing compared to running a mismatched one. Your build lives and dies by this choice.</p>
          <p>{protocol.rarity === 'High-End' ? protocol.name + ' is a Gold (High-End) protocol — the top of the food chain. These have the fattest stat bonuses in the game and are what you\'re grinding toward at endgame. The jump from Purple to Gold is noticeable.' : protocol.rarity === 'Superior' ? protocol.name + ' is a Purple (Superior) protocol — solid and way easier to farm than Gold ones. The raw stats are a step below High-End, but the talent hits just as hard in the right build. Great to run while you\'re hunting for the Gold version.' : protocol.name + ' is a Blue (Specialized) protocol — a perfectly fine placeholder that still gives you a real talent while you grind for the Purple or Gold upgrade.'} Check the <a href="/tier-list/os-protocols/" style="color: var(--accent);">OS Protocol Tier List</a> to see where {protocol.name} stacks up.</p>
        </div>
      </div>

      <!-- How to Get -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">How to Get {protocol.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>OS Protocols drop from a handful of endgame sources. {protocol.rarity === 'High-End' ? 'Gold protocols are the rarest drops in the game, full stop. Your best bets: the DZ vendor (costs DZ Credits — you can earn 20,000 per week from DZ quests), the premium gacha, and the occasional miracle drop from Legendary/Elite missions. If you\'re F2P, the DZ vendor is your lifeline.' : protocol.rarity === 'Superior' ? 'Purple protocols show up pretty regularly from weekly bounties, Heroic mission rewards, and Conflicts reward tracks. DZ vendor stocks them too. You\'ll see one every few Heroic runs — not too painful.' : 'Blue protocols rain from the sky. Challenging missions, weekly bounties, standard reward tracks — you\'ll be swimming in these early in your endgame grind.'}</p>
          <p>Where to focus your time: <strong style="color: #fff;">Weekly Bounties</strong> (guaranteed protocol-eligible loot), <strong style="color: #fff;">Dark Zone vendor</strong> (check the rotation for {protocol.specialization} protocols), and <strong style="color: #fff;">Legendary missions</strong> (best quality drops, but you need decent gear to clear them). Also keep an eye on the <a href="/guides/division-resurgence-codes/" style="color: var(--accent);">active codes page</a> — Ubisoft drops OS Protocol selection boxes during events sometimes, and you don't want to miss those.</p>
        </div>
      </div>
      {protocol.name === 'Dominating Presence' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/milkshake-machine-strawberry-milkshake-lmg-build/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">The Milkshake Machine</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Strawberry Milkshake LMG · Vanguard · Phalanx Attack 4pc + Fury Strike 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Death From Afar' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/bulwark-breacher-build-saiynergy/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Bulwark Breacher · 334k DPS Shield Wall</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Saiynergy · Breacher · Fury Strike 4pc + Phalanx Attack 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Brains Over Brawn' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/tech-aegis-engineering-build-tampishach/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Tech Aegis · 237k DPS Skill Crit</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Tampishach · Tech Aegis · Long-term Effect 4pc + Jackpot 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Pressing Matter' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/demolitionist-glass-cannon-build-pveenjoyer/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Demolitionist Glass Cannon · 333k DPS</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">PVE Enjoyer · Demolitionist · Fire Cycle 4pc + Jackpot 2pc · Toymaker II</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Rampart' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/jackpot-striker-drone-tech-operator-build/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Jackpot Striker Drone · Tech Operator</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">RapidF5 · Tech Operator · Jackpot 4pc + Fire Cycle 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}

      <!-- Related Links -->
      <div class="protocol-related">
        <a href="/database/os-protocols/" class="protocol-back">&larr; All OS Protocols</a>
        <a href="/tier-list/os-protocols/" class="protocol-back">OS Protocol Tier List</a>
        <a href="/guides/best-os-protocol/" class="protocol-back">Best Protocol Per Class</a>
      </div>
    </div>

    <AdSenseUnit label="Advertisement — database item" />
  </div>
</BaseLayout>

<style>
  .protocol-detail {
    max-width: 700px;
  }

  .protocol-header {
    margin-bottom: var(--sp-8);
  }

  .protocol-header__top {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .protocol-title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(135deg, #fff 60%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .protocol-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .protocol-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 5px 14px;
    border: 1px solid;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .protocol-badge--cooldown {
    border-color: var(--ink-muted) !important;
    color: var(--ink-muted) !important;
  }

  /* Sections */
  .protocol-section {
    margin-bottom: var(--sp-8);
  }

  .protocol-section__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 800;
    color: #fff;
    margin: 0 0 var(--sp-4) 0;
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* Talent */
  .protocol-talent-block {
    padding: var(--sp-5);
    background: rgba(0,0,0,0.25);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
  }

  .protocol-talent-block p {
    margin: 0;
    color: #c8c8d0;
    line-height: 1.75;
    font-size: var(--text-base);
  }

  /* Main stat */
  .protocol-main-stat {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    background: linear-gradient(135deg, rgba(242, 104, 34, 0.12) 0%, rgba(242,104,34,0.04) 100%);
    border: 1px solid rgba(242, 104, 34, 0.25);
    border-radius: 8px;
    margin-bottom: var(--sp-4);
  }

  .protocol-main-stat__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    flex-shrink: 0;
  }

  .protocol-main-stat__name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: #fff;
  }

  .protocol-main-stat__value {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--accent);
    margin-left: auto;
  }

  /* Stats grid */
  .protocol-stats-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .protocol-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-3) var(--sp-4);
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .protocol-stat-row__label {
    color: #b8b8c0;
    font-size: var(--text-base);
  }

  .protocol-stat-row__value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
    color: #fff;
  }

  /* Related */
  .protocol-related {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    padding-top: var(--sp-6);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .protocol-back {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    padding: var(--sp-2) var(--sp-4);
    background: rgba(242,104,34,0.08);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .protocol-back:hover {
    background: rgba(242,104,34,0.15);
    border-color: var(--accent);
  }

  .protocol-build-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: rgba(242,104,34,0.06);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 12px;
    text-decoration: none;
    flex-wrap: wrap;
    transition: all 200ms ease;
  }
  /* Protocol image */
  .protocol-image-container {
    margin-bottom: var(--sp-8);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(0,0,0,0.3);
    max-width: 500px;
  }

  .protocol-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .protocol-build-link:hover {
    background: rgba(242,104,34,0.12);
    border-color: var(--accent);
  }
</style>
