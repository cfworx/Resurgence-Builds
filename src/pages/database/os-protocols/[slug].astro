---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';
import osProtocols from '../../../data/os-protocols.json';

export function getStaticPaths() {
  return osProtocols.map((protocol: any) => ({
    params: { slug: protocol.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') },
    props: { protocol },
  }));
}

const { protocol } = Astro.props;

const title = `${protocol.name} OS Protocol — Division Resurgence`;
const description = `${protocol.name}: ${protocol.rarity} ${protocol.specialization} OS Protocol. ${protocol.mainStat} ${protocol.mainValue}. Talent and stats breakdown.`;

const breadcrumbs = [
  { name: 'OS Protocols', url: '/database/os-protocols/' },
  { name: protocol.name, url: '#' },
];

const specColor = protocol.specialization === 'Engineering' ? '#F5CC45' :
                  protocol.specialization === 'Firepower' ? '#F26822' :
                  protocol.specialization === 'Toughness' ? '#3a7bd5' : '#888';

const rarityColor = protocol.rarity === 'High-End' ? '#F5CC45' :
                    protocol.rarity === 'Superior' ? '#a855f7' :
                    protocol.rarity === 'Specialized' ? '#3b82f6' : '#888';

const specClass = protocol.specialization === 'Engineering' ? 'Demolitionist or Tech Operator' :
                  protocol.specialization === 'Firepower' ? 'Vanguard' :
                  protocol.specialization === 'Toughness' ? 'Bulwark or Field Medic' : 'any specialization';

const faqs = [
  {
    question: `Is ${protocol.name} a good OS Protocol in Division Resurgence?`,
    answer: `${protocol.name} is a ${protocol.rarity}-tier ${protocol.specialization} OS Protocol. Its talent "${protocol.talentDescription.substring(0, 150)}${protocol.talentDescription.length > 150 ? '...' : ''}" makes it strong for builds that stack ${protocol.specialization}. The main stat gives ${protocol.mainStat} ${protocol.mainValue}, with secondary bonuses of ${protocol.attr1} ${protocol.val1}, ${protocol.attr2} ${protocol.val2}, and ${protocol.attr3} ${protocol.val3}.`
  },
  {
    question: `Which specialization uses ${protocol.name}?`,
    answer: `${protocol.name} is a ${protocol.specialization} protocol, which means it pairs best with ${specClass} builds. Any build that stacks ${protocol.specialization} will benefit from the ${protocol.mainStat} ${protocol.mainValue} main stat and the talent bonus.`
  },
  {
    question: `How do I get ${protocol.name} in Division Resurgence?`,
    answer: `OS Protocols like ${protocol.name} drop from weekly bounties, Conflicts rewards, and endgame PvE activities. ${protocol.rarity === 'High-End' ? 'As a High-End protocol, it is one of the rarest drops — expect to farm weekly bounties for several cycles.' : protocol.rarity === 'Superior' ? 'As a Superior protocol, it drops fairly regularly from weekly bounties and endgame activities.' : 'As a Specialized protocol, it is a common drop from most endgame activities.'} Keep running weekly bounties for the best chance.`
  }
];

const slug = protocol.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = 'https://resurgencebuilds.com';

const protocolLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${protocol.name} OS Protocol — Division Resurgence`,
  description: description,
  url: `${siteUrl}/database/os-protocols/${slug}/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/os-protocols/${slug}/` },
  datePublished: '2026-05-27',
  dateModified: '2026-05-30',
};
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} jsonLd={protocolLd} faqs={faqs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="OS Protocol" />

    <div class="protocol-detail">
      <!-- Header -->
      <div class="protocol-header">
        <div class="protocol-header__top">
          <h1 class="protocol-title">{protocol.name}</h1>
          <div class="protocol-badges">
            <span class="protocol-badge" style={`border-color: ${rarityColor}; color: ${rarityColor};`}>{protocol.rarity}</span>
            <span class="protocol-badge" style={`border-color: ${specColor}; color: ${specColor};`}>{protocol.specialization}</span>
            {protocol.cooldown && (
              <span class="protocol-badge protocol-badge--cooldown">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {protocol.cooldown}
              </span>
            )}
          </div>
        </div>

        <div style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: #6DAA45; background: rgba(109, 170, 69, 0.1); border: 1px solid rgba(109, 170, 69, 0.25); padding: 6px 14px; border-radius: 999px; margin-top: var(--sp-4); letter-spacing: 0.02em;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>Last verified for <strong>Patch 1.1.2.2</strong></span>
        </div>
      </div>

      <!-- Talent Section -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Talent</h2>
        <div class="protocol-talent-block">
          <p>{protocol.talentDescription}</p>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Stats</h2>

        <div class="protocol-main-stat">
          <span class="protocol-main-stat__label">Main Stat</span>
          <span class="protocol-main-stat__name">{protocol.mainStat}</span>
          <span class="protocol-main-stat__value">{protocol.mainValue}</span>
        </div>

        <div class="protocol-stats-grid">
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr1}</span>
            <span class="protocol-stat-row__value">{protocol.val1}</span>
          </div>
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr2}</span>
            <span class="protocol-stat-row__value">{protocol.val2}</span>
          </div>
          <div class="protocol-stat-row">
            <span class="protocol-stat-row__label">{protocol.attr3}</span>
            <span class="protocol-stat-row__value">{protocol.val3}</span>
          </div>
        </div>
      </div>

      <!-- Overview -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Overview</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{protocol.name} is a <strong style="color: #fff;">{protocol.rarity}</strong> OS Protocol in the <strong style="color: #fff;">{protocol.specialization}</strong> tree. OS Protocols are gear chips that grant a major stat bonus plus a unique talent — think of them as the sixth gear piece that defines how your build plays. {protocol.name}'s main stat provides <strong style="color: var(--accent);">{protocol.mainStat} {protocol.mainValue}</strong>, with secondary bonuses to {protocol.attr1} ({protocol.val1}), {protocol.attr2} ({protocol.val2}), and {protocol.attr3} ({protocol.val3}).</p>
          <p>The talent is what makes {protocol.name} worth farming: <em>"{protocol.talentDescription}"</em> — this changes how you approach combat and build composition. {protocol.specialization === 'Engineering' ? 'Engineering protocols like this one are most effective on Demolitionist, Tech Operator, and Field Medic builds where skill output is the primary damage or healing source.' : protocol.specialization === 'Firepower' ? 'Firepower protocols like this one maximize weapon damage output, making them ideal for Vanguard DPS builds and any specialization running a gun-forward playstyle.' : 'Toughness protocols like this one boost survivability and are core to Bulwark tank builds, Field Medic battle-medics, and any build that needs to absorb hits in Legendary or Dark Zone PvP.'}</p>
        </div>
      </div>

      <!-- Build Use Cases -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Best Builds & Playstyles</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{protocol.name} works best with <strong style="color: #fff;">{specClass}</strong> builds that want to maximize {protocol.specialization} output. The {protocol.mainStat} {protocol.mainValue} main stat is a direct multiplier on your build's core, and the talent adds a conditional layer that rewards specific playstyles.</p>
          <p>{protocol.specialization === 'Engineering' ? 'For Engineering builds, pair this with gear sets like Jackpot (Skill Crit) or Long-term Effect (Skill Duration/Engineering) for maximum skill scaling. The 4pc gear set bonuses compound with the OS Protocol talent to create significantly higher effective damage or healing than either would provide alone.' : protocol.specialization === 'Firepower' ? 'For Firepower builds, pair this with Fury Strike (Crit) or Phalanx Attack (Multi-Shot/Rate of Fire) depending on whether you want sustained DPS or burst windows. The weapon talent synergy matters — look for In Sync, Concentrated Fire, or Killer on your primary weapon to compound with the OS bonus.' : 'For Toughness builds, pair this with Fearless Warrior (DR/Damage) or Self-Propelled Shield (Armor/Health) for maximum tank presence. Healing Elites is the premium T2-only option that adds massive survivability on top of your OS Protocol talent.'}</p>
        </div>
      </div>

      <!-- Stacking & Synergies -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">Stacking & Synergies</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>OS Protocol talents stack <strong style="color: #fff;">multiplicatively</strong> with gear set bonuses and weapon talents — meaning they multiply your total output, not just add to it. This is why OS Protocol selection is one of the highest-impact gearing decisions in Division Resurgence. A well-chosen OS Protocol can increase your effective DPS or healing by 30-50% over a mismatched one.</p>
          <p>{protocol.rarity === 'High-End' ? 'As a High-End (Gold) protocol, ' + protocol.name + ' provides the strongest stat bonuses in its category. Gold protocols are the endgame target — they represent a significant power increase over Superior and Specialized alternatives.' : protocol.rarity === 'Superior' ? 'As a Superior (Purple) protocol, ' + protocol.name + ' is a strong mid-tier option. While High-End protocols offer higher raw stats, Superior protocols are far easier to farm and the talent can be equally impactful in the right build.' : protocol.name + ' is a Specialized (Blue) protocol — an accessible starting option that provides a meaningful talent bonus while you farm for higher-rarity alternatives.'} Check the <a href="/tier-list/os-protocols/" style="color: var(--accent);">OS Protocol Tier List</a> to see where {protocol.name} ranks against alternatives.</p>
        </div>
      </div>

      <!-- How to Get -->
      <div class="protocol-section">
        <h2 class="protocol-section__title">How to Get {protocol.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>OS Protocols drop from several endgame sources in Division Resurgence. {protocol.rarity === 'High-End' ? 'Gold OS Protocols are the rarest tier. Your best sources are: the DZ vendor (costs DZ Credits — 20,000 available per week from DZ quests), the premium gacha system, and extremely rare drops from Legendary/Elite missions. The DZ vendor is the most reliable F2P path.' : protocol.rarity === 'Superior' ? 'Superior OS Protocols drop regularly from weekly bounties, Heroic mission rewards, and Conflicts reward tracks. You can also find them at the DZ vendor. Expect to see one every few Heroic runs.' : 'Specialized OS Protocols are common drops from most endgame activities including Challenging missions, weekly bounties, and standard reward tracks. You should have several to choose from early in your endgame progression.'}</p>
          <p>The key sources to prioritize: <strong style="color: #fff;">Weekly Bounties</strong> (guaranteed protocol-eligible rewards), <strong style="color: #fff;">Dark Zone vendor</strong> (check stock rotation for {protocol.specialization} protocols), and <strong style="color: #fff;">Legendary missions</strong> (highest-quality drops but require strong gear to clear). Keep an eye on the <a href="/guides/division-resurgence-codes/" style="color: var(--accent);">active codes page</a> — Ubisoft occasionally distributes OS Protocol selection boxes during events.</p>
        </div>
      </div>
      {protocol.name === 'Dominating Presence' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/milkshake-machine-strawberry-milkshake-lmg-build/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">The Milkshake Machine</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Strawberry Milkshake LMG · Vanguard · Phalanx Attack 4pc + Fury Strike 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Death From Afar' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/bulwark-breacher-build-saiynergy/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Bulwark Breacher · 334k DPS Shield Wall</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Saiynergy · Breacher · Fury Strike 4pc + Phalanx Attack 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Brains Over Brawn' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/tech-aegis-engineering-build-tampishach/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Tech Aegis · 237k DPS Skill Crit</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">Tampishach · Tech Aegis · Long-term Effect 4pc + Jackpot 2pc</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}
      {protocol.name === 'Pressing Matter' && (
        <div class="protocol-section">
          <h2 class="protocol-section__title">Featured Build</h2>
          <a href="/builds/demolitionist-glass-cannon-build-pveenjoyer/" class="protocol-build-link">
            <div>
              <strong style="color: #fff;">Demolitionist Glass Cannon · 333k DPS</strong>
              <span style="display: block; font-size: var(--text-sm); color: var(--ink-muted); margin-top: 2px;">PVE Enjoyer · Demolitionist · Fire Cycle 4pc + Jackpot 2pc · Toymaker II</span>
            </div>
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #fff; background: rgba(242,104,34,0.2); border: 1px solid rgba(242,104,34,0.4); padding: 8px 16px; border-radius: 6px; white-space: nowrap;">View Build →</span>
          </a>
        </div>
      )}

      <!-- Related Links -->
      <div class="protocol-related">
        <a href="/database/os-protocols/" class="protocol-back">&larr; All OS Protocols</a>
        <a href="/tier-list/os-protocols/" class="protocol-back">OS Protocol Tier List</a>
        <a href="/guides/best-os-protocol/" class="protocol-back">Best Protocol Per Class</a>
      </div>
    </div>

    <AdSenseUnit />
  </div>
</BaseLayout>

<style>
  .protocol-detail {
    max-width: 700px;
  }

  .protocol-header {
    margin-bottom: var(--sp-8);
  }

  .protocol-header__top {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .protocol-title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(135deg, #fff 60%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .protocol-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .protocol-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 5px 14px;
    border: 1px solid;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .protocol-badge--cooldown {
    border-color: var(--ink-muted) !important;
    color: var(--ink-muted) !important;
  }

  /* Sections */
  .protocol-section {
    margin-bottom: var(--sp-8);
  }

  .protocol-section__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 800;
    color: #fff;
    margin: 0 0 var(--sp-4) 0;
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* Talent */
  .protocol-talent-block {
    padding: var(--sp-5);
    background: rgba(0,0,0,0.25);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
  }

  .protocol-talent-block p {
    margin: 0;
    color: #c8c8d0;
    line-height: 1.75;
    font-size: var(--text-base);
  }

  /* Main stat */
  .protocol-main-stat {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    background: linear-gradient(135deg, rgba(242, 104, 34, 0.12) 0%, rgba(242,104,34,0.04) 100%);
    border: 1px solid rgba(242, 104, 34, 0.25);
    border-radius: 8px;
    margin-bottom: var(--sp-4);
  }

  .protocol-main-stat__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    flex-shrink: 0;
  }

  .protocol-main-stat__name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: #fff;
  }

  .protocol-main-stat__value {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--accent);
    margin-left: auto;
  }

  /* Stats grid */
  .protocol-stats-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .protocol-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-3) var(--sp-4);
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .protocol-stat-row__label {
    color: #b8b8c0;
    font-size: var(--text-base);
  }

  .protocol-stat-row__value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
    color: #fff;
  }

  /* Related */
  .protocol-related {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    padding-top: var(--sp-6);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .protocol-back {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    padding: var(--sp-2) var(--sp-4);
    background: rgba(242,104,34,0.08);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .protocol-back:hover {
    background: rgba(242,104,34,0.15);
    border-color: var(--accent);
  }

  .protocol-build-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: rgba(242,104,34,0.06);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 12px;
    text-decoration: none;
    flex-wrap: wrap;
    transition: all 200ms ease;
  }
  .protocol-build-link:hover {
    background: rgba(242,104,34,0.12);
    border-color: var(--accent);
  }
</style>
