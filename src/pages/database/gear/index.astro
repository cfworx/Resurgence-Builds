---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';

const breadcrumbs = [
  { name: 'Database', url: '/database/' },
  { name: 'Gear', url: '/database/gear/' }
];

const title = "All Gear — Division Resurgence Database";
const description = "Complete Division Resurgence gear database. Every piece of High-End and Superior gear.";
const noindex = true;

---

<BaseLayout {title} {description} {breadcrumbs} noindex={true} noAds={true}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Gear Database" />
    <h1 class="heading-accent">All Gear</h1>
    <p style="color: var(--ink-muted); margin-bottom: var(--sp-6); max-width: 800px;">
      This page will feature a complete list of every piece of gear in Division Resurgence.
    </p>

    <!-- Placeholder for future gear grid -->
    <div style="min-height: 300px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--border); border-radius: 8px; background: rgba(0,0,0,0.1); margin-bottom: var(--sp-8);">
      <p style="color: var(--ink-muted); font-style: italic;">Gear data coming soon...</p>
    </div>
  </div>
</BaseLayout>
