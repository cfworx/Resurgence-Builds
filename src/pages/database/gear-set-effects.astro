---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import gearSets from '../../data/gear-set-effects.json';

const title = "Division Resurgence Gear Sets & Brand Sets | Best Builds";
const description = "A complete database of all Division Resurgence Gear Sets, Brand Sets, and their effects. Find the best pieces for your mobile endgame builds.";
const breadcrumbs = [
  { name: 'Gear Set Effects', url: '/database/gear-set-effects/' }
];
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Gear Set Effects"
  subheading="Every gear set and their 2, 3, and 4-piece bonuses. Stack these correctly and you become an entirely different class of problem."
>
  <div class="db-grid" id="gear-grid">
    {gearSets.map((gear) => (
      <article class="db-card">
        <div class="db-card__header">
          <div>
            <h2 class="db-card__title">{gear.name}</h2>
          </div>
        </div>
        
        <div class="db-card__body">
          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-2">
                <span class="bonus-badge bonus-badge-2">2</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus2}</p>
            </div>
          </div>

          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-3">
                <span class="bonus-badge bonus-badge-3">3</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus3}</p>
            </div>
          </div>

          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-4">
                <span class="bonus-badge bonus-badge-4">4</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus4}</p>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</DatabaseLayout>
