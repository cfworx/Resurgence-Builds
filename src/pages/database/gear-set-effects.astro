---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import gearSets from '../../data/gear-set-effects.json';

const title = "Division Resurgence Gear Sets & Brand Sets | Best Builds";
const description = "Every gear set and brand set in Division Resurgence with their 2, 3, and 4-piece bonuses. Stack them right and enemies file complaints.";
const breadcrumbs = [
  { name: 'Gear Set Effects', url: '/database/gear-set-effects/' }
];

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Gear Set Effects',
  description: description,
  numberOfItems: gearSets.length,
  itemListElement: gearSets.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: Astro.url.href,
    item: {
      '@type': 'Thing',
      '@id': `${Astro.url.href}#item-${i}`,
      name: item.name || item.talent || item.attribute || item.protocolName || 'Item',
      description: item.description || item.talentDescription || item.effect || item.notes || `Details for ${item.name || item.talent || item.attribute || item.protocolName || 'item'}`,
      url: Astro.url.href,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Gear Set Effects"
  subheading="Every gear set and their 2, 3, and 4-piece bonuses. Stack these correctly and you become an entirely different class of problem."
  jsonLd={itemListLd}
>
  <div class="db-grid" id="gear-grid">
    {gearSets.map((gear) => (
      <article class="db-card">
        <div class="db-card__header">
          <div>
            <h2 class="db-card__title">{gear.name}</h2>
          </div>
        </div>
        
        <div class="db-card__body">
          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-2">
                <span class="bonus-badge bonus-badge-2">2</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus2}</p>
            </div>
          </div>

          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-3">
                <span class="bonus-badge bonus-badge-3">3</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus3}</p>
            </div>
          </div>

          <div class="bonus-block">
            <div class="bonus-group">
              <span class="bonus-label bonus-label-4">
                <span class="bonus-badge bonus-badge-4">4</span>
                Piece Bonus
              </span>
              <p class="bonus-text">{gear.bonus4}</p>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</DatabaseLayout>
