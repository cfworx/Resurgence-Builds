---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';
import WeaponAttributes from '../../../components/WeaponAttributes.astro';
import { truncateDesc } from '../../../utils/seo';
import exoticWeapons from '../../../data/exotic-weapons.json';

export function getStaticPaths() {
  return exoticWeapons.map((weapon: any) => ({
    params: {
      slug: weapon.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
    },
    props: { weapon }
  }));
}

const { weapon } = Astro.props;

const title = `${weapon.name} — Exotic ${weapon.type}`;
const description = truncateDesc(`${weapon.name} exotic ${weapon.type}: ${weapon.damage} damage, ${weapon.rpm} RPM, talent "${weapon.talentName}". Full stats and build recommendations.`);

const breadcrumbs = [
  { name: 'Exotic Weapons', url: '/database/exotic-weapons/' },
  { name: weapon.name, url: '#' }
];

const faqs = [
  {
    question: `Is ${weapon.name} good in Division Resurgence?`,
    answer: `${weapon.name} is an exotic ${weapon.type} — ${weapon.damage} damage, ${weapon.rpm} RPM, and the "${weapon.talentName}" talent that completely changes how you play. ${weapon.talentDescription.substring(0, 200)}${weapon.talentDescription.length > 200 ? '...' : ''} — yeah, it's worth farming for. Scroll down for a proven build that runs it.`
  },
  {
    question: `What builds use ${weapon.name}?`,
    answer: `You want to build entirely around the "${weapon.talentName}" talent — that's the whole point of running an exotic. As a ${weapon.type}, pair it with specs that stack the matching core stat, then find gear sets and OS Protocols that feed into what the talent does. Don't just slap it on any random loadout.`
  },
  {
    question: `How do I get ${weapon.name} in Division Resurgence?`,
    answer: `${weapon.name} drops from endgame stuff — Conflicts, Dark Zone, Legendary missions. Exotic drop rates are brutal, so target activities that have ${weapon.type}s in the loot pool. Weekly bounties and targeted loot zones give you a shot too. Prepare to grind.`
  }
];

const slug = weapon.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = 'https://resurgencebuilds.com';

const weaponLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: `${siteUrl}/database/exotic-weapons/${slug}/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/exotic-weapons/${slug}/` },
  datePublished: '2026-05-29',
  dateModified: '2026-05-30',
  image: weapon.image ? { '@type': 'ImageObject', url: `${siteUrl}${weapon.image}`, width: 620, height: 310 } : { '@type': 'ImageObject', url: `${siteUrl}/images/resurgence-builds-official-logo.png`, width: 800, height: 800 },
  inLanguage: 'en-US',
  lastReviewed: '2026-05-30',
  wordCount: 800,
  about: { '@id': `${siteUrl}/#division-resurgence` },
};

const itemLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${siteUrl}/database/exotic-weapons/${slug}/#item`,
  name: `${weapon.name} — Exotic ${weapon.type} in Division Resurgence`,
  description: `${weapon.name} exotic ${weapon.type} in Division Resurgence. ${weapon.damage} damage, ${weapon.rpm} RPM, ${weapon.mag} mag. Exotic talent: ${weapon.talentName}.`,
  genre: 'Video Game Item Database',
  isPartOf: {
    '@type': 'VideoGame',
    name: 'Tom Clancy\'s The Division Resurgence',
    gamePlatform: ['iOS', 'Android'],
    applicationCategory: 'Game',
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Weapon Class', value: weapon.type },
    { '@type': 'PropertyValue', name: 'Rarity', value: 'Exotic' },
    { '@type': 'PropertyValue', name: 'Talent', value: weapon.talentName },
    { '@type': 'PropertyValue', name: 'RPM', value: String(weapon.rpm) },
    { '@type': 'PropertyValue', name: 'Magazine', value: String(weapon.mag) },
    { '@type': 'PropertyValue', name: 'Damage', value: String(weapon.damage) },
  ]
};
---

<BaseLayout {title} {description} {breadcrumbs} faqs={faqs} jsonLd={[weaponLd, itemLd]}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Exotic Weapon" />

    <div class="weapon-detail">
      <div class="weapon-detail__header">
        <h1 class="weapon-detail__name">{weapon.name}</h1>
        <span class="weapon-type-badge">{weapon.type}</span>
      </div>

      {weapon.image && (
        <div style="margin-bottom: var(--sp-6); border-radius: 8px; overflow: hidden; border: 1px solid var(--border);">
          <img src={weapon.image} alt={`${weapon.name} Exotic ${weapon.type} in Division Resurgence`} style="width: 100%; height: auto; display: block;" />
        </div>
      )}

      <!-- Stats Grid -->
      <div class="weapon-stats">
        <h2 class="weapon-stats__heading">Weapon Stats</h2>
        <div class="weapon-stats__grid">
          <div class="weapon-stat">
            <span class="weapon-stat__label">Damage</span>
            <span class="weapon-stat__value">{weapon.damage}</span>
          </div>
          <div class="weapon-stat">
            <span class="weapon-stat__label">RPM</span>
            <span class="weapon-stat__value">{weapon.rpm}</span>
          </div>
          <div class="weapon-stat">
            <span class="weapon-stat__label">MAG</span>
            <span class="weapon-stat__value">{weapon.mag}</span>
          </div>
        </div>
      </div>

      <WeaponAttributes 
        accuracy={weapon.accuracy} 
        reloadSpeed={weapon.reloadSpeed} 
        optimalRange={weapon.optimalRange} 
        movementSpeed={weapon.movementSpeed} 
        stability={weapon.stability} 
      />

      <!-- Talent Section -->
      <div class="weapon-talent">
        <h2 class="weapon-talent__heading">Exotic Talent</h2>
        <div class="weapon-talent__card">
          <h3 class="weapon-talent__name">{weapon.talentName}</h3>
          <p class="weapon-talent__desc">{weapon.talentDescription}</p>
        </div>
      </div>

      <!-- Overview -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 class="weapon-stats__heading">Overview</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>The <strong style="color: #fff;">{weapon.name}</strong> is one of only three exotics in Division Resurgence right now — so yeah, it's kind of a big deal. The whole reason you run an exotic over a regular {weapon.type} is the talent: <strong style="color: #F5CC45;">{weapon.talentName}</strong> completely changes how you play. Stat-wise, you're looking at {weapon.damage} base damage, {weapon.rpm} RPM, and a {weapon.mag}-round mag. {weapon.rpm >= 800 ? 'That high fire rate means you\'re getting up close and proccing talent effects as fast as possible.' : weapon.rpm >= 600 ? 'It sits in a sweet spot between sustained DPS and burst — works at most ranges without feeling awkward.' : 'Big magazine, steady damage — this thing rewards you for holding the trigger and letting talents stack up over long engagements.'}</p>
        </div>
      </div>

      <!-- How the Talent Works -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 class="weapon-stats__heading">How {weapon.talentName} Works</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          {weapon.name === 'Lady Death' && (
            <Fragment>
              <p><strong style="color: #fff;">Breathe Free</strong> is a movement-based stacking talent. While moving, you gain 4 stacks per second (8 while sprinting), up to 40 stacks maximum. Each round fired consumes 1 stack and grants <strong style="color: var(--accent);">+15% Weapon Damage</strong>. Deploying a skill consumes 10 stacks and grants <strong style="color: var(--accent);">+15% Skill Damage</strong>. Kills grant +10% Movement Speed for 10 seconds.</p>
              <p>The optimal loop: sprint-stack to 40 before engaging, unload your mag for the boosted damage, deploy a skill mid-fight for the skill damage bonus, then reposition. Lady Death rewards aggressive players who are constantly moving — standing still means zero stacks and zero bonus damage. In the Dark Zone, the movement speed on kill chains into repositioning, making Lady Death one of the strongest PvP SMGs in the game.</p>
            </Fragment>
          )}
          {weapon.name === 'Warlord' && (
            <Fragment>
              <p><strong style="color: #fff;">Play Rough</strong> gives you <strong style="color: var(--accent);">25% damage reduction while firing</strong>. When you stop firing, 60% of the damage that was reduced gets applied to enemies in range, and you gain +10% Skill Damage for 10 seconds. This creates a unique tank-DPS hybrid playstyle — you absorb punishment while shooting, then the stored damage explodes outward.</p>
              <p><strong style="color: #F5CC45;">Warning — The Warlord Trap:</strong> Warlord is a T1 Exotic AR available from the Battle Pass. Committing to it requires significant PvP farming for weapon proficiency — Level 7 requires roughly 70 agent kills. There is also a known proficiency tracking bug. Make sure the build actually needs Warlord before investing the PvP grind time. For PvE-only players, the proficiency gate can be a blocker.</p>
            </Fragment>
          )}
          {weapon.name === 'Strawberry Milkshake' && (
            <Fragment>
              <p>The Strawberry Milkshake has <strong style="color: #fff;">three talents</strong> — <strong style="color: var(--accent);">Anarchy</strong> (DoT on body shots, stacks up to 50, transfers on kill), <strong style="color: var(--accent);">Concentrated Fire</strong> (+0.36% WCHD per hit, up to 100 stacks on same target), and <strong style="color: var(--accent);">Swift Taunt</strong> (hit 3 enemies in 5s for taunt + Extra Health).</p>
              <p><strong style="color: #F5CC45;">Community reality check:</strong> The Anarchy DoT is effectively non-functional in practice — the per-tick damage is negligible. Do NOT build around the DoT mechanic. The Strawberry Milkshake's real value is the 100-round magazine combined with Concentrated Fire (massive crit damage stacking on boss targets) and Swift Taunt (free Extra Health for survivability). Pair with In Sync on a secondary weapon and Phalanx Attack 4pc for Multi-Shot + Rate of Fire to maximize the sustained-fire engine.</p>
              <p><strong style="color: #fff;">Damage type note:</strong> Strawberry Milkshake deals <strong>Shredding</strong> damage — NOT Blast. This is a common misreporting. Matters for armor-type matchups against specific enemy types.</p>
            </Fragment>
          )}
        </div>
      </div>

      <!-- Build Strategy -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 class="weapon-stats__heading">Build Strategy</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>With exotics, the talent IS the build. Everything else revolves around it. {weapon.name === 'Lady Death' ? 'Lady Death builds go hard on Firepower and Weapon Damage so every stack of that +15% WD bonus hits like a freight train. Vanguard for Tactical Link synergy, or Bulwark Breacher if you like the aggressive shield-rush playstyle. Gear sets: Fury Strike 4pc (Crit) for fat per-shot damage, or Quick Draw 4pc for Headshot Damage if your aim is cracked.' : weapon.name === 'Warlord' ? 'Warlord turns you into a tank-DPS hybrid. Stack Toughness if you want to be unkillable, Firepower if you want to deal more — either works. That 25% DR while firing is nuts for Legendary missions where adds are constantly shooting at you. Pair with Fearless Warrior if you want to face-tank everything, or Fury Strike if you\'d rather crit harder.' : 'Strawberry Milkshake is all about never stopping shooting. That 100-round mag means Concentrated Fire hits max stacks, Multi-Shot keeps proccing, and you just don\'t reload. Run Phalanx Attack 4pc for +18% Mag Size and +12% Multi-Shot, Fury Strike 2pc for Crit Chance, Glass Cannon Body Armor for +20% damage, and Dominating Presence OS for even more Multi-Shot per enemy in range. It\'s a machine.'}</p>
          <p>Hit the <a href="/tier-list/" style="color: var(--accent);">Build Tier List</a> for verified loadouts running {weapon.name}, or use the <a href="/builder/" style="color: var(--accent);">Build Planner</a> to cook up your own.</p>
        </div>
      </div>

      <!-- How to Get -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 class="weapon-stats__heading">How to Get {weapon.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>Exotics drop from endgame activities — Legendary/Elite missions, Dark Zone, and Conflicts. Drop rates are pain. Expect to run dozens of activities before you see one. {weapon.name === 'Warlord' ? 'Warlord is the exception — you can grab a T1 version from the Battle Pass, making it the easiest exotic to get your hands on. The catch? Upgrading proficiency means PvP kills. Hope you like the Dark Zone.' : 'Focus on Legendary missions for the best drop rates, and run activities that have ' + weapon.type + 's in the targeted loot pool so you\'re not just praying to RNG.'}</p>
          <p>T2 exotics only drop from Elite/Legendary difficulty. T1 versions are easier to get and still hold their own in most content. You can start leveling weapon proficiency on any tier, so the second you get one — any tier — start grinding those proficiency kills.</p>
        </div>
      </div>
      {weapon.name === 'Strawberry Milkshake' && (
        <div class="weapon-build">
          <h2 class="weapon-stats__heading">Featured Build</h2>
          <a href="/builds/milkshake-machine-strawberry-milkshake-lmg-build/" class="weapon-build__card">
            <div>
              <h3 class="weapon-build__title">The Milkshake Machine</h3>
              <p class="weapon-build__desc">Phalanx Attack 4pc + Fury Strike 2pc Vanguard LMG build. In Sync double-dip, ~37% Multi-Shot, Glass Cannon + Swift Taunt. Full gear, talents, and rotation.</p>
            </div>
            <span class="weapon-build__btn">View Build →</span>
          </a>
        </div>
      )}

      <!-- Back Link -->
      <div class="weapon-detail__back">
        <a href="/database/exotic-weapons/" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          Back to All Exotics
        </a>
      </div>
    </div>

    <AdSenseUnit label="Advertisement — database item" />
  </div>
</BaseLayout>

<style>
  .weapon-detail {
    max-width: 48rem;
  }

  .weapon-detail__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-8);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .weapon-detail__name {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(135deg, #fff 60%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (min-width: 768px) {
    .weapon-detail__name {
      font-size: var(--text-5xl);
    }
  }

  .weapon-type-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #F26822;
    background: rgba(242,104,34,0.12);
    border: 1px solid rgba(242,104,34,0.25);
    padding: 5px 14px;
    border-radius: 999px;
  }

  /* Stats */
  .weapon-stats {
    margin-bottom: var(--sp-8);
  }

  .weapon-stats__heading {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--ink-heading);
    margin-bottom: var(--sp-4);
  }

  .weapon-stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-3);
  }

  @media (min-width: 640px) {
    .weapon-stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .weapon-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: rgba(0,0,0,0.25);
    padding: var(--sp-4);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .weapon-stat__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .weapon-stat__value {
    font-size: var(--text-lg);
    font-weight: 700;
    color: #fff;
  }

  /* Talent */
  .weapon-talent {
    margin-bottom: var(--sp-8);
  }

  .weapon-talent__heading {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--ink-heading);
    margin-bottom: var(--sp-4);
  }

  .weapon-talent__card {
    padding: var(--sp-6);
    background: rgba(245, 204, 69, 0.05);
    border: 1px solid rgba(245, 204, 69, 0.2);
    border-radius: 12px;
  }

  .weapon-talent__name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: #F5CC45;
    margin: 0 0 var(--sp-3) 0;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .weapon-talent__name::before {
    content: '⬡';
    font-size: 0.7em;
    opacity: 0.7;
  }

  .weapon-talent__desc {
    font-size: var(--text-base);
    line-height: 1.75;
    color: #b8b8c0;
    margin: 0;
  }

  /* Back link */
  .weapon-detail__back {
    padding-top: var(--sp-6);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: var(--sp-3) var(--sp-5);
    border: 1px solid rgba(242,104,34,0.25);
    border-radius: 8px;
    background: rgba(242,104,34,0.06);
    transition: all 200ms ease;
  }

  .back-link:hover {
    background: rgba(242,104,34,0.12);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Featured Build */
  .weapon-build {
    margin-bottom: var(--sp-8);
  }
  .weapon-build__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: rgba(242,104,34,0.06);
    border: 1px solid rgba(242,104,34,0.2);
    border-radius: 12px;
    text-decoration: none;
    flex-wrap: wrap;
    transition: all 200ms ease;
  }
  .weapon-build__card:hover {
    background: rgba(242,104,34,0.12);
    border-color: var(--accent);
  }
  .weapon-build__title {
    margin: 0 0 4px 0;
    font-size: var(--text-base);
    font-weight: 700;
    color: #fff;
  }
  .weapon-build__desc {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--ink-muted);
  }
  .weapon-build__btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    padding: 10px 20px;
    color: #fff;
    background: rgba(242,104,34,0.2);
    border: 1px solid rgba(242,104,34,0.4);
    border-radius: 8px;
  }
</style>
