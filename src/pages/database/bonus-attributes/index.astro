---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import bonusAttributes from '../../../data/bonus-attributes.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Bonus Attributes — All 24 Stats Explained";
const description = "Every bonus attribute that can roll on your gear in Division Resurgence, organized by Firepower, Toughness, Engineering, and Universal pools. Know your rolls or suffer.";
const breadcrumbs = [
  { name: 'Weapon/Gear Bonus Attributes', url: '/database/bonus-attributes/' }
];

const toSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const getCategoryColor = (cat: string) => {
  switch(cat.toLowerCase()) {
    case 'firepower': return { color: '#f87171', bg: 'rgba(239,68,68,0.08)', border: 'rgba(239,68,68,0.25)' };
    case 'toughness': return { color: '#60a5fa', bg: 'rgba(59,130,246,0.08)', border: 'rgba(59,130,246,0.25)' };
    case 'engineering': return { color: '#facc15', bg: 'rgba(234,179,8,0.08)', border: 'rgba(234,179,8,0.25)' };
    default: return { color: '#b8b8c0', bg: 'rgba(255,255,255,0.04)', border: 'rgba(255,255,255,0.1)' };
  }
};

const faqs = [
  { question: "What are bonus attributes in Division Resurgence?", answer: "Bonus attributes are secondary stats that roll on your gear alongside the core stat (Firepower, Toughness, or Engineering). They include Weapon Critical Hit Chance, Weapon Critical Hit Damage, Skill Intensity, Damage Reduction, and more. Each core stat type unlocks a specific pool of attributes, plus Universal attributes that can roll on any core." },
  { question: "What bonus attributes should I prioritize in Division Resurgence?", answer: "For DPS builds: Weapon Critical Hit Chance and Weapon Critical Hit Damage are king. For tank builds: Max Health, Armor, and Damage Reduction. For skill builds: Skill Intensity and Skill Cooldown Recovery. Universal attributes like Damage to Elites and Received Healing fit any build. The right bonus attributes turn a mediocre build into something that actually melts." },
  { question: "Can you recalibrate bonus attributes in Division Resurgence?", answer: "Yes. At the Recalibration Station, you can swap one bonus attribute per gear piece. You need a donor item with the stat you want. Each gear piece only gets one recalibration slot, so plan carefully before committing. Recalibrating one attribute locks the others on that piece permanently." },
];

const allAttrs: Array<{name: string; category: string}> = [];
bonusAttributes.forEach((cat: any) => {
  cat.attributes.forEach((attr: string) => {
    allAttrs.push({ name: attr, category: cat.category });
  });
});

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Weapon/Gear Bonus Attributes',
  description: description,
  numberOfItems: allAttrs.length,
  itemListElement: allAttrs.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
      name: item.name,
      description: `${item.name} — ${item.category} bonus attribute in Division Resurgence`,
      url: `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Bonus Attributes"
  subheading={`All ${allAttrs.length} bonus attributes across ${bonusAttributes.length} stat pools — organized by core function. Know your rolls, or suffer.`}
  jsonLd={itemListLd}
  lastVerified="Patch 1.2.1"
  {faqs}
>
  <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base); margin-bottom: var(--sp-8); max-width: 72ch;">
    <p>Bonus attributes are the secondary stats on every gear piece in Division Resurgence. They sit alongside your core stat — Firepower, Toughness, or Engineering — and provide specialized bonuses like Weapon Critical Hit Chance, Skill Intensity, or Damage Reduction. Each core stat type unlocks a specific pool of bonus attributes, so a Firepower-core vest will roll different options than an Engineering-core vest.</p>
    <p>There are {allAttrs.length} bonus attributes across {bonusAttributes.length} pools: <strong>Firepower</strong> (offensive weapon stats), <strong>Toughness</strong> (survivability), <strong>Engineering</strong> (skill scaling), and <strong>Universal</strong> (attributes that roll on any core type). Universal attributes like Damage to Elites and Received Healing are the most flexible options for builds that need cross-category value.</p>
    <p>You can recalibrate one bonus attribute per gear piece at the Recalibration Station, but doing so locks the other attributes on that piece. This means planning your recalibration targets before you commit is critical — especially on Tier 2 endgame gear that you cannot easily replace.</p>
  </div>
  <div class="db-grid" id="attributes-grid">
    {bonusAttributes.map((category) => {
      const palette = getCategoryColor(category.category);
      return (
        <article class="db-card" style={`border-color: ${palette.border};`}>
          <div class="db-card__header" style={`padding-bottom: var(--sp-4); border-bottom-color: ${palette.border};`}>
            <div style={`display:inline-flex;align-items:center;gap:var(--sp-3);background:${palette.bg};border:1px solid ${palette.border};padding:var(--sp-2) var(--sp-4);border-radius:8px;`}>
              <span style={`font-family:var(--font-heading);font-size:var(--text-xl);font-weight:900;color:${palette.color};`}>
                {category.category}
              </span>
              <span style={`font-family:var(--font-mono);font-size:var(--text-xs);color:${palette.color};opacity:0.7;`}>
                {category.attributes.length} stats
              </span>
            </div>
          </div>
          
          <div class="db-card__body">
            <ul class="attribute-list">
              {category.attributes.map((attr: string) => (
                <li><a href={`/database/bonus-attributes/${toSlug(attr)}/`} style="color: inherit; text-decoration: none; display: block; padding: 2px 0; transition: color 0.15s;">{attr}</a></li>
              ))}
            </ul>
          </div>
        </article>
      );
    })}
  </div>
<AdSenseUnit label="Advertisement — database category" />
</DatabaseLayout>
