---
import DatabaseLayout from '../../../layouts/DatabaseLayout.astro';
import bonusAttributes from '../../../data/bonus-attributes.json';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';

const title = "Division Resurgence Bonus Attributes & Gear Score Guide";
const description = "Every stat that can roll on your gear in Division Resurgence, organized by Firepower, Toughness, and Engineering. Know your rolls or suffer.";
const breadcrumbs = [
  { name: 'Bonus Attributes', url: '/database/bonus-attributes/' }
];

const toSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const getCategoryColor = (cat: string) => {
  switch(cat.toLowerCase()) {
    case 'firepower': return { color: '#f87171', bg: 'rgba(239,68,68,0.08)', border: 'rgba(239,68,68,0.25)' };
    case 'toughness': return { color: '#60a5fa', bg: 'rgba(59,130,246,0.08)', border: 'rgba(59,130,246,0.25)' };
    case 'engineering': return { color: '#facc15', bg: 'rgba(234,179,8,0.08)', border: 'rgba(234,179,8,0.25)' };
    default: return { color: '#b8b8c0', bg: 'rgba(255,255,255,0.04)', border: 'rgba(255,255,255,0.1)' };
  }
};

const faqs = [
  { question: "What are bonus attributes in Division Resurgence?", answer: "Bonus attributes are secondary stats that roll on your gear alongside the core attribute (Firepower, Toughness, or Engineering). They include things like Critical Hit Chance, Headshot Damage, Armor Regeneration, Skill Haste, and more. Every gear piece can roll one or two bonus attributes, and they stack across your loadout." },
  { question: "What bonus attributes should I prioritize in Division Resurgence?", answer: "For DPS builds: Critical Hit Chance and Critical Hit Damage until you cap CHC around 50-60%, then stack CHD and Headshot Damage. For tank builds: Armor Regeneration and Health. For skill builds: Skill Haste and Skill Damage. The right bonus attributes turn a mediocre build into something that actually melts." },
  { question: "Can you recalibrate bonus attributes in Division Resurgence?", answer: "Yes. At the Recalibration Station, you can swap one bonus attribute per gear piece. You'll need to extract the stat you want from a donor item first, which stores it in your Recalibration Library permanently. Once it's in the library, you can apply it as many times as you want. Don't sleep on filling out that library early." },
];

const allAttrs: Array<{name: string; category: string}> = [];
bonusAttributes.forEach((cat: any) => {
  cat.attributes.forEach((attr: string) => {
    allAttrs.push({ name: attr, category: cat.category });
  });
});

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Bonus Attributes',
  description: description,
  numberOfItems: allAttrs.length,
  itemListElement: allAttrs.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
    item: {
      '@type': 'Thing',
      '@id': `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
      name: item.name,
      description: `${item.name} — ${item.category} bonus attribute in Division Resurgence`,
      url: `https://resurgencebuilds.com/database/bonus-attributes/${toSlug(item.name)}/`,
      subjectOf: { '@id': 'https://resurgencebuilds.com/#division-resurgence' }
    }
  })),
};
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Bonus Attributes"
  subheading="Every stat that can roll on your gear and weapons — organized by core function. Know your rolls, or suffer."
  jsonLd={itemListLd}
  lastVerified="Patch 1.2.1"
  {faqs}
>
  <div class="db-grid" id="attributes-grid">
    {bonusAttributes.map((category) => {
      const palette = getCategoryColor(category.category);
      return (
        <article class="db-card" style={`border-color: ${palette.border};`}>
          <div class="db-card__header" style={`padding-bottom: var(--sp-4); border-bottom-color: ${palette.border};`}>
            <div style={`display:inline-flex;align-items:center;gap:var(--sp-3);background:${palette.bg};border:1px solid ${palette.border};padding:var(--sp-2) var(--sp-4);border-radius:8px;`}>
              <span style={`font-family:var(--font-heading);font-size:var(--text-xl);font-weight:900;color:${palette.color};`}>
                {category.category}
              </span>
              <span style={`font-family:var(--font-mono);font-size:var(--text-xs);color:${palette.color};opacity:0.7;`}>
                {category.attributes.length} stats
              </span>
            </div>
          </div>
          
          <div class="db-card__body">
            <ul class="attribute-list">
              {category.attributes.map((attr: string) => (
                <li><a href={`/database/bonus-attributes/${toSlug(attr)}/`} style="color: inherit; text-decoration: none; display: block; padding: 2px 0; transition: color 0.15s;">{attr}</a></li>
              ))}
            </ul>
          </div>
        </article>
      );
    })}
  </div>
<AdSenseUnit />
</DatabaseLayout>
