---
import DatabaseLayout from '../../layouts/DatabaseLayout.astro';
import backpackTalents from '../../data/backpack-talents.json';

const title = "Division Resurgence Backpack Talents & Best Builds";
const description = "Complete database of all Backpack Talents in The Division Resurgence. Find the best named items and gear combinations for your endgame build.";
const breadcrumbs = [
  { name: 'Backpack Talents', url: '/database/backpack-talents/' }
];
---

<DatabaseLayout
  {title}
  {description}
  {breadcrumbs}
  heading="Backpack Talents"
  subheading="Browse the complete list of Backpack Talents to optimize your build's utility and survivability."
>
  <div class="db-grid" id="talents-grid">
    {backpackTalents.map((talent) => (
      <article class="db-card">
        <div class="db-card__header">
          <div>
            <h2 class="db-card__title">{talent.name}</h2>
          </div>
        </div>
        
        <div class="db-card__body">
          <div class="talent-desc">
            <p>{talent.description}</p>
          </div>
          
          <div class="source-section">
            <span class="source-label">Source Backpack</span>
            <p class="source-text">Rolls on T2 backpacks — equip via Build Planner</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</DatabaseLayout>
