---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionTag from '../../../components/SectionTag.astro';
import AdSenseUnit from '../../../components/AdSenseUnit.astro';
import standardWeapons from '../../../data/standard-weapons.json';

export function getStaticPaths() {
  return standardWeapons.map((weapon: any) => ({
    params: {
      slug: weapon.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
    },
    props: { weapon }
  }));
}

const { weapon } = Astro.props;

const slug = weapon.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = 'https://resurgencebuilds.com';

const title = `${weapon.name} — ${weapon.type}`;
const description = `${weapon.name} ${weapon.type} stats: ${weapon.rpm} RPM, ${weapon.mag} magazine, ${weapon.dmgType} damage. Full breakdown for Division Resurgence.`;

const breadcrumbs = [
  { name: 'Weapons', url: '/database/weapons/' },
  { name: weapon.name, url: '#' }
];

const typeGuide: Record<string, string> = {
  'Assault Rifle': 'ARs are the jack-of-all-trades in Division Resurgence — good damage, good RPM, good range. If you just want one gun that works everywhere without thinking too hard, this is it. Most meta builds run an AR primary for a reason.',
  'SMG': 'SMGs are for players who like getting in people\'s faces. You give up range for insane RPM and built-in Crit Chance, which makes them absolute monsters in Dark Zone PvP and aggressive PvE runs. If you\'re not pushing forward, you\'re wasting the gun.',
  'LMG': 'LMGs let you hold the trigger and just keep shooting. Massive magazines mean you\'re stacking talents like Multi-Shot and In Sync without ever stopping to reload. Great for solo and group PvE — you become the team\'s damage printer.',
  'Marksman Rifle': 'Marksman Rifles hit the hardest per shot in Division Resurgence. If your aim is good, the headshot multipliers are disgusting. These are the backbone of sniper builds running Death From Afar OS Protocol.',
  'Shotgun': 'Shotguns delete people up close. In Division Resurgence, they\'re best on Bulwark Breacher builds with a Ballistic Shield — walk up, blast, repeat. Not subtle, but extremely effective.',

};

const typeDesc = typeGuide[weapon.type] || `${weapon.type}s are a weapon category in Division Resurgence offering unique playstyle options depending on your build and specialization.`;

const faqs = [
  {
    question: `Is the ${weapon.name} good in Division Resurgence?`,
    answer: `The ${weapon.name} is a ${weapon.type} — ${weapon.rpm} RPM, ${weapon.mag}-round mag, ${weapon.dmgType} damage. ${typeDesc.split('.')[0]}. How good it actually is depends on what weapon talents you roll and how well it fits your gear set combo.`
  },
  {
    question: `What type of damage does the ${weapon.name} do?`,
    answer: `${weapon.dmgType} damage. This actually matters — some gear sets, OS Protocols, and weapon talents give bonuses tied to specific damage types. Make sure your build isn't fighting against the damage type you're dealing.`
  },
  {
    question: `What builds use ${weapon.type}s in Division Resurgence?`,
    answer: typeDesc
  }
];

const weaponLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: `${siteUrl}/database/weapons/${slug}/`,
  author: { '@type': 'Person', '@id': `${siteUrl}/author/rapidf5/#person`, name: 'RapidF5' },
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization`, name: 'Resurgence Builds' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/database/weapons/${slug}/` },
  datePublished: '2026-05-30',
  dateModified: '2026-05-30',
};

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${siteUrl}/database/weapons/${slug}/#product`,
  name: weapon.name,
  category: weapon.type,
  description: `${weapon.name} ${weapon.type} in Division Resurgence. ${weapon.rpm} RPM, ${weapon.mag} magazine, ${weapon.dmgType} damage.`,
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Weapon Class', value: weapon.type },
    { '@type': 'PropertyValue', name: 'Rarity', value: 'High-End' },
    { '@type': 'PropertyValue', name: 'RPM', value: String(weapon.rpm) },
    { '@type': 'PropertyValue', name: 'Magazine', value: String(weapon.mag) },
    { '@type': 'PropertyValue', name: 'Damage Type', value: weapon.dmgType },
  ]
};
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} jsonLd={[weaponLd, productLd]} faqs={faqs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbs} />
    <SectionTag label="Weapon Database" />

    <div style="max-width: 700px;">
      <!-- Header -->
      <div style="margin-bottom: var(--sp-8); padding-bottom: var(--sp-6); border-bottom: 1px solid rgba(255,255,255,0.08);">
        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-4);">
          <h1 style="font-family: var(--font-heading); font-size: var(--text-4xl); font-weight: 900; letter-spacing: -0.03em; margin: 0; background: linear-gradient(135deg, #fff 60%, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{weapon.name}</h1>
          <span style="display: inline-flex; align-items: center; font-family: var(--font-mono); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); background: rgba(242,104,34,0.12); border: 1px solid rgba(242,104,34,0.25); padding: 5px 14px; border-radius: 999px;">{weapon.type}</span>
        </div>
        <div style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: var(--text-xs); color: #6DAA45; background: rgba(109, 170, 69, 0.1); border: 1px solid rgba(109, 170, 69, 0.25); padding: 6px 14px; border-radius: 999px; margin-top: var(--sp-4); letter-spacing: 0.02em;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>Last verified for <strong>Patch 1.1.2.2</strong></span>
        </div>
      </div>

      <!-- Overview -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">Overview</h2>
        <p style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          The <strong>{weapon.name}</strong> is a <strong>{weapon.type}</strong> in The Division Resurgence that fires at <strong>{weapon.rpm} RPM</strong> with a <strong>{weapon.mag}-round</strong> magazine and deals <strong>{weapon.dmgType}</strong> damage. {typeDesc}
        </p>
      </div>

      <!-- Stats -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">Stats</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-3);">
          <div style="display: flex; flex-direction: column; gap: 4px; background: rgba(0,0,0,0.25); padding: var(--sp-4); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.06em;">RPM</span>
            <span style="font-size: var(--text-lg); font-weight: 700; color: #fff;">{weapon.rpm}</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 4px; background: rgba(0,0,0,0.25); padding: var(--sp-4); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.06em;">Magazine</span>
            <span style="font-size: var(--text-lg); font-weight: 700; color: #fff;">{weapon.mag}</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 4px; background: rgba(0,0,0,0.25); padding: var(--sp-4); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.06em;">Damage Type</span>
            <span style="font-size: var(--text-lg); font-weight: 700; color: #fff;">{weapon.dmgType}</span>
          </div>
        </div>
      </div>

      <!-- Weapon class guide -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">{weapon.type} Class Guide</h2>
        <div style="padding: var(--sp-5); background: rgba(0,0,0,0.25); border-left: 3px solid var(--accent); border-radius: 0 8px 8px 0;">
          <p style="margin: 0; color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">{typeDesc}</p>
        </div>
      </div>

      <!-- Best Builds & Playstyle -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">Best Builds for {weapon.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{weapon.type === 'Assault Rifle' ? `The ${weapon.name} at ${weapon.rpm} RPM fits best in Vanguard DPS or Bulwark Breacher builds. At this fire rate, you want gear sets that reward sustained damage — Fury Strike for crit-stacking or Phalanx Attack for Multi-Shot procs. Pair it with a Firepower OS Protocol and stack Weapon Damage, Crit Chance, and Crit Damage as your priority bonus attributes. ARs are versatile enough to work in PvE and PvP, making this gun a safe choice for any loadout.` : weapon.type === 'SMG' ? `The ${weapon.name} with its ${weapon.rpm} RPM fire rate is built for aggressive, in-your-face playstyles. SMGs get built-in Crit Chance, which means you can focus your gear on Crit Damage instead. Fury Strike 4pc is the natural gear set — the crit stacking synergy is disgusting. Run it on Vanguard with a mobility OS Protocol for DZ PvP, or pair it with a Bulwark Breacher shield build for close-range PvE domination.` : weapon.type === 'LMG' ? `The ${weapon.name} and its ${weapon.mag}-round magazine makes it a sustained DPS monster. With that many rounds, you're stacking weapon talents like In Sync and Multi-Shot procs before you ever need to reload. Phalanx Attack 4pc is the meta choice — Magazine Size, Rate of Fire, and Multi-Shot Chance all multiply your already-massive sustained damage. Vanguard DPS or Tech Operator hybrid builds get the most out of LMG primaries.` : weapon.type === 'Marksman Rifle' ? `The ${weapon.name} is a precision weapon — high damage per shot, low RPM. Sniper builds running Quick Draw or One Shot One Kill gear sets pair naturally with this gun. Stack Headshot Damage on your mask and Crit Damage everywhere else. Death From Afar OS Protocol turns this into a true one-shot build in Heroic content. If your aim is consistent, this gun outperforms any AR in raw per-shot damage.` : weapon.type === 'Shotgun' ? `The ${weapon.name} is a close-quarters brawler. Bulwark Breacher shield builds are the natural home — walk up with a Ballistic Shield, blast them point-blank, and let your Toughness handle the rest. Fearless Warrior gear set gives you the DR to survive the push. In PvP, shotguns are the ultimate "around the corner" weapon. Stack Weapon Damage and Armor for maximum aggression.` : `The ${weapon.name} is a solid weapon option. Check what weapon talents it can roll and match it with a gear set and OS Protocol that synergize with this weapon class for maximum output.`}</p>
        </div>
      </div>

      <!-- Weapon Talents to Pair -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">Best Weapon Talents for {weapon.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>{weapon.type === 'Assault Rifle' ? `Top AR talents: **Killer** (kill → crit damage buff, snowballs in multi-enemy fights), **Concentrated Fire** (bonus damage ramps with consecutive hits on the same target - rewards accuracy), **In Sync** (if you use offensive skills alongside your AR). Breadbasket is solid for headshot chains. Avoid healing-focused talents - ARs should be all offense.` : weapon.type === 'SMG' ? `Best SMG talents: **Killer** (crits → more crit damage, and SMGs already crit constantly), **Strained** (crit damage scales as mag empties - timing reloads matters), **In Sync** (if you're also running offensive skills). Pummel works on aggressive Breacher builds where melee finishers are part of the rotation.` : weapon.type === 'LMG' ? `Best LMG talents: **Unhinged** (flat weapon damage boost with a handling trade-off - worth it on a bipod LMG), **In Sync** (pairing with Assault Turret means both buffs are always active), **Steady Handed** (kills extend your already-huge mag even further). Avoid talents that require kills to activate - LMGs are about sustained damage, not burst.` : weapon.type === 'Marksman Rifle' ? `Best MMR talents: **Concentrated Fire** (first shot bonus is massive on a bolt-action), **Head Collection** (headshot kill → next shot hits like a truck), **Killer** (if you're critting consistently). The talent should reward precision - if a talent procs on body shots the same as headshots, it's wasted on an MMR.` : weapon.type === 'Shotgun' ? `Best shotgun talents: **Pummel** (melee kills boost damage - Bulwark Breacher synergy), **Killer** (crits → more crit damage, shotgun headshots crit hard), **Strained** (crit damage scales as mag empties - every shell counts). Shotgun talent choice is about maximizing that one devastating blast.` : `Check the weapon talent database for the full list - the right talent depends entirely on your build's archetype and playstyle.`}</p>
        </div>
      </div>

      <!-- Recommended Bonus Attributes -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">Recommended Bonus Attributes for {weapon.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>When rolling bonus attributes on gear for a {weapon.type} build using the {weapon.name}, prioritize in this order:</p>
          <ol style="padding-left: var(--sp-5); margin-top: var(--sp-2);">
            <li><strong style="color: var(--accent);">Weapon {weapon.dmgType} Damage</strong> — Direct multiplier for this weapon's damage output. This is your highest-impact single stat.</li>
            {weapon.type === 'SMG' ? (
              <li><strong style="color: #fff;">Crit Damage</strong> — SMGs already get built-in Crit Chance, so stacking Crit Damage gives you more per-crit bang.</li>
            ) : weapon.type === 'Marksman Rifle' ? (
              <li><strong style="color: #fff;">Headshot Damage</strong> — MMRs live on headshots. This stat scales the hardest on precision weapons.</li>
            ) : (
              <li><strong style="color: #fff;">Crit Chance</strong> — Until you hit the soft cap (~60%), Crit Chance is the most efficient damage stat.</li>
            )}
            <li><strong style="color: #fff;">{weapon.type === 'Marksman Rifle' ? 'Crit Damage' : 'Crit Damage'}</strong> — After Crit Chance is healthy, stack Crit Damage for bigger crits.</li>
            <li><strong style="color: #fff;">Damage to Elites</strong> — For PvE, this stat is a flat multiplier on every named and elite enemy.</li>
          </ol>
          <p style="margin-top: var(--sp-3);">Check the <a href="/database/bonus-attributes/" style="color: var(--accent);">bonus attributes database</a> for exact values and which gear slots can roll each stat.</p>
        </div>
      </div>

      <!-- PvE vs PvP Viability -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">{weapon.name} in PvE vs PvP</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);">
          <div style="padding: var(--sp-4); background: rgba(109,170,69,0.08); border: 1px solid rgba(109,170,69,0.2); border-radius: 8px;">
            <h3 style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #6DAA45; margin: 0 0 var(--sp-2) 0;">PvE Rating</h3>
            <p style="color: #c8c8d0; font-size: var(--text-sm); line-height: 1.6; margin: 0;">
              {weapon.type === 'Assault Rifle' ? `Solid all-rounder. ARs work in every PvE scenario — story missions, Heroic, Legendary. The ${weapon.rpm} RPM fire rate gives you good sustained damage without burning through ammo.` : weapon.type === 'SMG' ? `Situational. SMGs need close range to perform, which puts you at risk in Heroic and Legendary content. Best paired with a shield or aggressive playstyle.` : weapon.type === 'LMG' ? `Excellent. The ${weapon.mag}-round magazine means you're firing longer than anyone else. In group PvE, LMGs are the sustained damage king.` : weapon.type === 'Marksman Rifle' ? `Strong if your aim is good. One-shot potential on standard enemies makes MMRs the fastest clearers in the game — but you need consistent headshots.` : weapon.type === 'Shotgun' ? `Niche. You need a shield to safely get into shotgun range in harder PvE content. Works great on Bulwark Breacher builds, risky on everything else.` : `Works in PvE content. Match it with appropriate gear and talents for best results.`}
            </p>
          </div>
          <div style="padding: var(--sp-4); background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px;">
            <h3 style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: #ef4444; margin: 0 0 var(--sp-2) 0;">PvP Rating</h3>
            <p style="color: #c8c8d0; font-size: var(--text-sm); line-height: 1.6; margin: 0;">
              {weapon.type === 'Assault Rifle' ? `Good. ARs are the safe PvP pick — consistent damage at medium range, no hard counters. Not the fastest TTK but not the slowest either.` : weapon.type === 'SMG' ? `Excellent. Built-in Crit Chance + close-range damage bonuses make SMGs the fastest TTK weapons in PvP. Lady Death is the king, but any SMG with Killer talent shreds.` : weapon.type === 'LMG' ? `Decent for suppression. LMGs are better at zone control than dueling — pin enemies behind cover while your team flanks.` : weapon.type === 'Marksman Rifle' ? `High risk, high reward. If you can hit headshots under PvP pressure, MMRs can one-shot. If you miss, you're dead before the next shot chambers.` : weapon.type === 'Shotgun' ? `Strong in close quarters. Shotguns paired with a Bulwark shield are the ultimate "around the corner" PvP weapon. One blast at point-blank range can delete a player.` : `PvP viability depends on your build and playstyle.`}
            </p>
          </div>
        </div>
      </div>

      <!-- How to Farm -->
      <div style="margin-bottom: var(--sp-8);">
        <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0; padding-bottom: var(--sp-2); border-bottom: 1px solid rgba(255,255,255,0.08);">How to Get {weapon.name}</h2>
        <div style="color: #c8c8d0; line-height: 1.75; font-size: var(--text-base);">
          <p>Standard weapons like the {weapon.name} drop from the general loot pool - any activity can drop it. <strong style="color: #fff;">Heroic missions</strong> and <strong style="color: #fff;">weekly bounties</strong> are your most consistent T2 weapon farms. DZ extractions also frequently drop T2 weapons with random talent rolls. When farming, you're looking for two things: the right weapon AND the right talent. If you find a {weapon.name} with a bad talent but great base stats, recalibrate the talent at the recalibration station.</p>
          <p>Keep in mind: {weapon.dmgType} damage type means you should match your bonus attributes to this type. <strong style="color: var(--accent);">Weapon {weapon.dmgType} Damage</strong> as a bonus attribute on your gear will directly boost this gun's output. Check the <a href="/database/bonus-attributes/" style="color: var(--accent);">bonus attributes database</a> for the full list of damage-type specific stats.</p>
        </div>
      </div>

      <!-- Related links -->
      <div style="display: flex; flex-wrap: wrap; gap: var(--sp-3); padding-top: var(--sp-6); border-top: 1px solid rgba(255,255,255,0.08);">
        <a href="/database/weapons/" style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">&larr; All Weapons</a>
        <a href="/database/weapon-talents/" style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Weapon Talents</a>
        <a href="/database/exotic-weapons/" style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Exotic Weapons</a>
        <a href="/database/gear-set-effects/" style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Gear Sets</a>
        <a href="/tier-list/" style="font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Tier List</a>
      </div>
    </div>

    <AdSenseUnit />
  </div>
</BaseLayout>

