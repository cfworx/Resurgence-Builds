---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allBuilds = await getCollection('builds');

  const classes = [
    {
      id: 'vanguard',
      name: 'Vanguard',
      role: 'DPS / Team Utility',
      description: 'A front-line attacker that bridges tanking and DPS. The Vanguard kit is built around Mobile Cover and Pulse-style scouting tools, giving the team both positional advantage and intel. The Commando focus centers on close-range burst damage with weapons like the Warlord and Lady Death, while the Scout Recon path provides high-impact team utility that the community consistently rates as one of the strongest endgame setups in Division Resurgence. Vanguard excels in both PvE and PvP, making it one of the most versatile specializations in the game. If you want a class that can flex between aggressive DPS and squad-wide support without swapping loadouts, the Vanguard delivers.',
      signature: {
        name: 'Tactical Link',
        description: 'The Vanguard\'s iconic offensive team buff. Tactical Link provides a high-impact damage and tempo boost tied into the class\'s cover and scouting tools. When activated, your entire squad benefits from increased rate of fire and damage output for a limited window — making it the go-to signature for coordinated burst phases in Legendary missions and Dark Zone extractions.'
      },
      perkOverview: 'Vanguard talents branch into Commando (Firepower-focused DPS with Warlord, Lady Death, and DBS builds) and Scout Recon (Engineering-focused team utility using Smart Cover and Scanning Pulse). Community builds rate Scout Recon as very strong in endgame group content.',
      signatureTalents: 'The Vanguard talent tree splits into two distinct paths. **Commando** is pure DPS — stack Firepower, run Fury Strike 4pc or Phalanx Attack 4pc, and let your weapon talents do the heavy lifting. Commando Vanguards are the top of the damage charts in most squad compositions. **Scout Recon** flips the script entirely — you stack Engineering and run Smart Cover plus Scanning Pulse to buff the entire team\'s damage and survivability simultaneously. Scout Recon doesn\'t show up on the DPS meter, but experienced squads will tell you the Recon player is the reason they cleared.',
      howToPlay: [
        'Stack Firepower on Commando builds and Engineering on Scout Recon. Mixing the two will leave you mediocre at both — commit to one path.',
        'In group content, deploy Mobile Cover before engagements and use it as your anchor point. Your team benefits from the cover bonuses and you control the fight\'s positioning.',
        'Tactical Link is a team resource. Don\'t blow it on trash mobs — save it for boss phases, extraction timers, and DZ PvP fights where the burst window decides who walks away.',
        'If you\'re running Commando with an LMG, the Strawberry Milkshake paired with Phalanx Attack is disgusting sustained DPS. Check the Milkshake Machine build for the exact setup.',
        'Scout Recon players: your Scanning Pulse uptime matters more than your personal damage. Keep that pulse cycling and your squad\'s effective DPS doubles.'
      ],
      bestWeapons: 'Assault Rifles (Warlord, StG 44) for Commando, LMGs (Strawberry Milkshake) for sustained DPS, and SMGs (Lady Death) for aggressive PvP pushes. Scout Recon can run any weapon since damage comes from team buffs.'
    },
    {
      id: 'field-medic',
      name: 'Field Medic',
      role: 'Healer / Support',
      description: 'The backbone of any Legendary mission or Dark Zone squad. The Field Medic keeps the team alive through healing skills, support tools, and a powerful burst-heal ultimate. The Combat Medicine focus runs Healing Swarm, Healing Hive, and Support Station to keep the squad standing while stacking Toughness with the Defensive Measures mod for off-tank damage. Tactical Pharma flips the script with Oxidizing Swarm, Oxidizing Hive, and Chemical Trap for corrosive area pressure. Field Medic is the class that makes Legendary content possible for most squads. In PvP, a good Field Medic turns a mediocre squad into an unkillable nightmare.',
      signature: { name: 'Healing Swarm / Oxidizing Swarm', description: 'Each Field Medic focus has its own signature skill. Combat Medicine deploys Healing Swarm, while Tactical Pharma deploys Oxidizing Swarm.' },
      signatures: [
        {
          focus: 'Combat Medicine',
          name: 'Healing Swarm',
          description: 'Deploys a swarm of nanobots that seeks out and heals nearby allies. Healing Swarm is the Combat Medicine signature skill, providing sustained group healing that scales with Toughness and Skill Intensity. The swarm prioritizes low-health allies, making it the cornerstone of group survival in Legendary content. Pairs with Healing Hive and Support Station for near-permanent healing uptime.'
        },
        {
          focus: 'Tactical Pharma',
          name: 'Oxidizing Swarm',
          description: 'Deploys a corrosive swarm of nanobots that seeks out enemies and applies stacking Oxidation damage. Oxidizing Swarm is the Tactical Pharma signature skill, dealing area-of-effect corrosive damage that scales with Skill Crit Chance and Skill Crit Damage. The swarm softens entire enemy packs for your DPS teammates to finish off. Pairs with Oxidizing Hive and Chemical Trap for maximum corrosive pressure.'
        }
      ],
      perkOverview: 'Community builds commonly prioritize Toughness (for survival and Defensive Measures damage scaling), followed by Skill Intensity, Skill Duration, and Skill CDR. Deep Focus chest talent and Captain Cow gear set extend Support Station uptime significantly.',
      signatureTalents: 'Field Medic has two focuses: **Combat Medicine** and **Tactical Pharma (Oxi Medic)**. Combat Medicine is the hybrid path: you stack Toughness, which simultaneously makes you harder to kill AND boosts your Defensive Measures damage output. It\'s the most popular path because you contribute both healing and damage without sacrificing either. **Tactical Pharma** goes all-in on Oxidizing Swarm area pressure, stacking Skill Crit Chance and Skill Crit Damage with Jackpot 4pc + Boom-Shakalaka 2pc. The Oxi build is competitive in group play where the corrosive stacks soften up entire packs for your DPS teammates to finish off.',
      howToPlay: [
        'Your Support Station placement wins or loses fights. Put it behind solid cover where the squad naturally clusters — never in the open where it gets destroyed.',
        'Stack Toughness first, then Skill Intensity. Toughness keeps you alive AND scales Defensive Measures damage on Combat Medicine builds.',
        'Save Emergency Healing for emergencies. Do not pop it when your squad is at 80% health. Wait until someone is about to go down and the heal value is worth the cooldown.',
        'In Dark Zone PvP, your survival is the squad\'s survival. If you go down, the team dies 15 seconds later. Play conservative and stay behind your Bulwark.',
        'Deep Focus chest talent + Captain Cow gear set = near-permanent Support Station uptime. This combo is non-negotiable for Legendary difficulty.'
      ],
      bestWeapons: 'Any weapon works since your damage comes from Toughness scaling, but ARs (for range) and LMGs (for suppression) are the most common picks. SMGs work on aggressive Combat Medicine builds that play close to the Bulwark.'
    },
    {
      id: 'demolitionist',
      name: 'Demolitionist',
      role: 'AoE DPS / Explosive Specialist',
      description: 'The Demolitionist excels at area denial and burst damage through grenades, artillery skills, and explosive chain reactions. The HE (High Explosive) focus stacks Engineering and Skill Crit for devastating AoE output, while the Field Grenadier variant offers an alternative approach to explosive damage. Demolitionist is the king of PvE add-clear - drop an Artillery Turret, toss an Explosive Seeker Mine, and watch the screen fill with damage numbers while you sit back at range. In Legendary content, a well-built Demolitionist competes with or exceeds pure weapon-DPS classes because the skill scaling with Engineering is multiplicative, not additive.',
      signature: {
        name: 'M32A1 Grenade Launcher',
        description: 'A heavy explosive launcher that deals massive area-of-effect damage. The M32A1 fires multiple rounds in rapid succession, each dealing splash damage across a wide radius. Mods can dramatically increase per-shot damage at the cost of magazine capacity. The signature synergizes with Engineering stacking and explosive OS Protocols, and the Frag Grenades firmware set accelerates charge recovery through Artillery Turret damage ticks.'
      },
      perkOverview: 'Talent trees revolve around Engineering stacking, Skill Crit Chance, Skill Crit Damage, and Skill Intensity. Community builds commonly run Jackpot (4pc) with Fire Cycle or Boom-Shakalaka (2pc) for maximum skill crit output.',
      signatureTalents: 'The Demolitionist talent tree splits into **HE Munitions** (High Explosive) and **Field Grenadier**. HE Munitions is the dominant path — you stack Engineering to the ceiling and let your skills scale multiplicatively. Fire Cycle T2 with Jackpot 2pc is the meta setup, running Toymaker II for the glass-cannon Skill Multi-Shot boost. PVE Enjoyer\'s 333k DPS build is the template everyone copies. **Field Grenadier** takes a more direct approach with grenade-centric damage, but the scaling doesn\'t match HE Munitions in current patch meta. Most experienced Demolitionist players run HE.',
      howToPlay: [
        'Engineering is your god stat. Stack it everywhere — gear cores, OS Protocol, weapon mods. Engineering multiplies every skill\'s damage, not just the ones you have equipped.',
        'Artillery Turret placement is everything. Drop it on elevated terrain with line-of-sight to the engagement area. A badly placed turret is a wasted cooldown.',
        'Toymaker II chest talent requires 20m distance from enemies. This isn\'t optional — it\'s a +21% Skill Multi-Shot Chance that disappears the moment a rusher closes the gap. Stay back.',
        'If you don\'t have Fire Cycle T2 yet (requires Conflicts Level 100 or T2 PvE), run 4pc Jackpot as a bridge. The Skill Crit and Skill Radius bonuses still slap.',
        'Pressing Matter OS Protocol is the standard pick for +24% Skill Intensity and +10% Skill CDR. Brains Over Brawn is the swap if you want Skill Crit Chance instead.'
      ],
      bestWeapons: 'Warlord (for the Engineering-scaled exotic talent) and StG 44 (for Skill Multi-Shot Chance weapon attribute). Your weapons are secondary — the real damage comes from Artillery Turret and Explosive Seeker Mine.'
    },
    {
      id: 'tech-operator',
      name: 'Tech Operator',
      role: 'Skill DPS / Utility',
      description: 'The Tech Operator dominates through deployed skills and gadgetry. The Aegis Operations focus uses a shield with a passive burst mechanic that deals significant damage when built around Engineering - the shield pulse scales with your Engineering stat, not your Firepower, which catches a lot of new players off guard. The Offensive Operations focus uses Striker Drone crits to apply Disoriented status and chain skill damage across multiple targets. Tech Operator has one of the highest skill ceilings in Division Resurgence - in PvP, a skilled Tech Op with proper cooldown management can 1v2 or 1v3 consistently, per community assessment.',
      signature: { name: 'Drone Overload / Defender Drone', description: 'Each Tech Operator focus has its own signature skill. Offensive Operations deploys Drone Overload, while Aegis Operations deploys Defender Drone.' },
      signatures: [
        {
          focus: 'Offensive Operations',
          name: 'Drone Overload',
          description: 'Overloads deployed drones and turrets for a limited duration, dramatically increasing their damage output and effectiveness. During Drone Overload, your Striker Drone hits harder, turret fire rate increases, and all skill cooldowns are reduced. Pairs with Engineering stacking for maximum burst potential.'
        },
        {
          focus: 'Aegis Operations',
          name: 'Defender Drone',
          description: 'Deploys a defensive drone that protects the user and nearby allies by intercepting incoming projectiles. The Defender Drone scales with Engineering and creates a protective zone where your team is significantly harder to kill. At full build it produces uptime numbers that make PvP opponents check if there is a bug.'
        }
      ],
      perkOverview: 'Aegis builds prioritize Engineering, which benefits the passive burst mechanic significantly more than Skill Damage. Tampishach\'s 237k DPS Tech Aegis build runs Long-term Effect 4pc with Brains Over Brawn for 53% Skill Crit Chance. Striker Drone is standard for offensive builds. High skill ceiling in PvP per community assessment.',
      signatureTalents: 'Tech Operator branches into **Aegis Operations** and **Offensive Operations**. Aegis Operations is the shield path - the passive burst mechanic scales off Engineering, dealing damage to nearby enemies on a timed pulse. This makes the Tech Aegis a tanky DPS hybrid that face-tanks while dealing competitive damage. Tampishach\'s 237k DPS build is the community reference. **Offensive Operations** runs Striker Drone with crit-focused gear to apply Disoriented status and chain skill damage. It\'s more of a utility/DPS role - the Disoriented debuff is incredibly strong in PvP, locking down enemy players for your team to focus fire.',
      howToPlay: [
        'Aegis builds: Engineering is your main stat, not Firepower and not Skill Damage. The shield pulse mechanic scales directly off Engineering - misattributing your stats is the #1 mistake new Tech Operators make.',
        'Long-term Effect 4pc + Brains Over Brawn OS Protocol = 53% Skill Crit Chance. This is the proven Aegis combo. Don\'t reinvent the wheel.',
        'Striker Drone needs line-of-sight to keep hitting. In urban map environments, it gets stuck on geometry constantly. Reposition to give your drone clean angles.',
        'Drone Overload timing is crucial - pop it right before you engage, not mid-fight when your skills are on cooldown. The duration is short and every second counts.',
        'In PvP, the Disoriented status from Offensive Operations Striker Drone crits is a death sentence for the enemy. Build for crit chance to ensure consistent procs.'
      ],
      bestWeapons: 'Any weapon class works since your damage comes from skills. ARs for general use, SMGs for Aegis builds that play in close (your shield keeps you alive), or LMGs for Offensive builds that want sustained suppression while the drone works.'
    },
    {
      id: 'bulwark',
      name: 'Bulwark',
      role: 'Tank / Frontline',
      description: 'The immovable object. The Bulwark draws enemy fire, absorbs incoming damage, and anchors the team\'s position behind the Phalanx Shield. Shockwave Spike MK3 emits shockwaves that apply Shock status, immobilizing enemies for several seconds — making Bulwark the most feared PvP specialization in the current meta. In PvE, the Bulwark turns Legendary missions from chaotic scrambles into controlled pushes where the squad moves behind the shield at the tank\'s pace. Without a Bulwark, most squads struggle with Legendary boss encounters because there\'s no one to hold aggro and soak damage.',
      signature: {
        name: 'Breach Combo',
        description: 'Expands the Phalanx Shield and pairs it with a powerful shotgun for aggressive close-range engagements. The Bulwark\'s signature enables the class to push forward while maintaining full frontal protection — you become a walking siege engine that absorbs damage, stuns enemies with Shockwave Spike procs, and blasts anything in shotgun range. In PvP, a Breach Combo push into an enemy position is almost impossible to stop without coordinated focus fire.'
      },
      perkOverview: 'Juggernaut is the dominant Bulwark focus for both PvP and endgame PvE. Shockwave Spike MK3 provides approximately 5-second stuns on a short cooldown per community observation. Build around Toughness to maximize shield HP. Breacher is a proven PvE DPS path - Saiynergy\'s 334k DPS shield build runs Fury Strike 4pc with Death From Afar.',
      signatureTalents: 'Bulwark splits into **Juggernaut** and **Breacher**. Juggernaut is pure tank — Shockwave Spike MK3 stuns enemies for ~5 seconds on a short cooldown, which in PvP is an eternity. You stack Toughness, run Fearless Warrior or Self-Propelled Shield gear sets, and become the unkillable anchor the team plays behind. **Breacher** is the DPS tank path — Saiynergy\'s 334k DPS build proves that Bulwark can top damage charts while holding a shield. The trick is Fury Strike 4pc with Death From Afar OS Protocol, running a shotgun for devastating close-range burst. It\'s the class for players who want to tank AND do damage.',
      howToPlay: [
        'Toughness is everything for Juggernaut. Every point of Toughness directly increases your Phalanx Shield HP. A dead shield is a dead Bulwark is a dead squad.',
        'Position your shield to create a choke point. In PvE, this means doorways and corridors where enemies funnel into your Shockwave Spike stuns. In PvP, this means blocking DZ extraction points.',
        'Shockwave Spike MK3 has a ~5-second stun window. Communicate with your squad when you land a stun so they can burst the stunned targets. Uncoordinated stuns are wasted stuns.',
        'Breacher Bulwarks: you are playing a melee DPS class with a shield. Push aggressively, get into shotgun range, and let Fury Strike crits carry your damage. If you\'re playing passive with a Breacher build, you\'re doing it wrong.',
        'Always run a shotgun as your primary on Breacher builds. The Phalanx Shield restricts you to one-handed weapons, and shotguns deal the most damage per shot at the ranges you\'ll be fighting at.'
      ],
      bestWeapons: 'Shotguns for Breacher builds (mandatory — the Phalanx Shield requires one-handed weapons). For Juggernaut, any one-handed weapon works since your job is crowd control, not damage. Sidearms with utility talents are a common Juggernaut pick.'
    }
  ];

  return classes.map(c => {
    // Filter builds for this specific class
    const classBuilds = allBuilds
      .filter(build => build.data.specialization === c.name)
      .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

    return {
      params: { spec: c.id },
      props: { classData: c, builds: classBuilds }
    };
  });
}

const { classData, builds } = Astro.props;

const breadcrumbItems = [
  { name: 'Classes', url: '/builds/' },
  { name: classData.name, url: `/class/${classData.id}/` }
];

const title = `Best ${classData.name} Builds — Division Resurgence May 2026`;
const description = `Top ${classData.name} builds for PvE and PvP in Division Resurgence. ${classData.role} loadouts with gear sets, talents, and OS Protocols. Updated for Patch 1.2.1.`;

const faqs = [
  {
    question: `Is ${classData.name} good in Division Resurgence?`,
    answer: classData.description
  },
  {
    question: `What is the best ${classData.name} build right now?`,
    answer: builds.length > 0
      ? `The top-rated ${classData.name} build on Resurgence Builds is ${builds[0].data.title}. ${classData.perkOverview}`
      : `${classData.name} builds focus on ${classData.role} playstyles. ${classData.perkOverview}`
  },
  {
    question: `What gear sets work best for ${classData.name}?`,
    answer: classData.perkOverview
  },
  {
    question: `What's the best weapon for ${classData.name} in Division Resurgence?`,
    answer: classData.bestWeapons
  }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbItems}
  faqs={faqs}
  ogType="article"
  article={{
    publishDate: '2026-05-30T00:00:00Z',
    modifiedDate: '2026-05-30T00:00:00Z',
    author: 'RapidF5',
    tags: [classData.name, 'builds', 'Division Resurgence', classData.role],
  }}
  ogImage={builds.length > 0 && builds[0].data.featuredImage ? builds[0].data.featuredImage : '/images/best-pve-dps-builds-division-resurgence.png'}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Class Hub" />
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-4); font-size: var(--text-sm);">
      <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); border-radius: 4px; color: #22c55e; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.03em;">✓ Verified for Patch 1.2.1</span>
    </div>
    
    <div style="margin-bottom: var(--sp-8); padding-bottom: var(--sp-6); border-bottom: 1px solid var(--border);">
      <div style="display: flex; align-items: baseline; gap: var(--sp-3); margin-bottom: var(--sp-2);">
        <h1 class="heading-accent" style="margin: 0;">Best {classData.name} Builds — May 2026</h1>
        <span class="tag tag--accent">{classData.role}</span>
      </div>
      
      <p style="font-size: var(--text-lg); color: var(--ink-muted); max-width: 800px; margin-bottom: var(--sp-6); line-height: 1.6;">
        {classData.description}
      </p>

      {classData.signatures ? (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-4);">
          {classData.signatures.map((sig: any) => (
            <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
              <h3 style="color: var(--accent); margin-bottom: var(--sp-1); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Signature Skill: {sig.name}</h3>
              <span style="display: inline-block; font-family: var(--font-mono); font-size: 10px; color: #a78bfa; background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.25); padding: 2px 8px; border-radius: 999px; margin-bottom: var(--sp-2); letter-spacing: 0.04em;">{sig.focus} Focus</span>
              <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
                {sig.description}
              </p>
            </div>
          ))}
          <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
            <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Talent Overview</h3>
            <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
              {classData.perkOverview}
            </p>
          </div>
        </div>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--sp-4);">
          <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
            <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Signature Skill: {classData.signature.name}</h3>
            <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
              {classData.signature.description}
            </p>
          </div>
          <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
            <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Talent Overview</h3>
            <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
              {classData.perkOverview}
            </p>
          </div>
        </div>
      )}
    </div>

    <!-- Signature Talents Deep Dive -->
    <div style="margin-bottom: var(--sp-8); padding: var(--sp-5); background: rgba(0,0,0,0.15); border: 1px solid var(--border); border-radius: var(--border-radius); max-width: 800px;">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-3) 0;">{classData.name} Talent Breakdown</h2>
      <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75; margin: 0;" set:html={classData.signatureTalents} />
    </div>

    <AdSenseUnit />

    <!-- Why Play section -->
    <div style="margin-bottom: var(--sp-8); padding: var(--sp-5); background: rgba(0,0,0,0.15); border: 1px solid var(--border); border-radius: var(--border-radius); max-width: 800px;">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-3) 0;">Why Play {classData.name}?</h2>
      <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75; margin: 0 0 var(--sp-3) 0;">
        If you want to <strong style="color: var(--ink);">{classData.role}</strong> in Division Resurgence, this is your pick.
        {classData.signatures
          ? <>{' '}Each focus has its own signature skill: <strong style="color: var(--accent);">{classData.signatures[0].name}</strong> for {classData.signatures[0].focus} and <strong style="color: var(--accent);">{classData.signatures[1].name}</strong> for {classData.signatures[1].focus}. Pick the path that matches your playstyle.</>
          : <>{' '}Your signature move, <strong style="color: var(--accent);">{classData.signature.name}</strong>, {classData.signature.description.toLowerCase().split('.')[0]} - and yeah, it's as good as it sounds.</>
        }
      </p>
      <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75; margin: 0;">
        Every build below has been run in-game and verified on the current patch - no theory-craft copium here.
      </p>
    </div>

    <!-- How to Play section -->
    <div style="margin-bottom: var(--sp-8); max-width: 800px;">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0;">How to Play {classData.name}</h2>
      <ul style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75; padding-left: var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-3);">
        {classData.howToPlay.map(tip => (
          <li>{tip}</li>
        ))}
      </ul>
    </div>

    <!-- Related resources -->
    <div style="display: flex; flex-wrap: wrap; gap: var(--sp-3); margin-bottom: var(--sp-8);">
      <a href="/tier-list/" style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Best Builds Tier List</a>
      <a href="/builder/" style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Build Planner</a>
      <a href="/database/os-protocols/" style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">OS Protocols</a>
      <a href="/database/gear-set-effects/" style="font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--accent); text-decoration: none; padding: var(--sp-2) var(--sp-4); background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 6px; transition: all 0.2s;">Gear Sets</a>
    </div>

    <h2 class="heading-accent" style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Top {classData.name} Builds</h2>
    
    {builds.length > 0 ? (
      <div class="grid grid--3">
        {builds.map((build) => (
          <div style="display: flex; height: 100%;">
            <BuildCard
              title={build.data.title}
              href={`/builds/${build.id}/`}
              specialization={build.data.specialization}
              playstyle={build.data.playstyle}
              description={build.data.description}
              patch={build.data.patch}
              pve={build.data.pve}
              pvp={build.data.pvp}
              tags={build.data.tags}
              featuredImage={build.data.featuredImage}
              imageAlt={build.data.imageAlt}
            />
          </div>
        ))}
      </div>
    ) : (
      <div style="text-align: center; padding: var(--sp-8) 0; background: rgba(0,0,0,0.1); border-radius: var(--border-radius); border: 1px dashed var(--border);">
        <p style="color: var(--ink-muted);">No builds have been published for this class yet. Check back soon!</p>
      </div>
    )}

    <AdSenseUnit />
  </div>
</BaseLayout>
