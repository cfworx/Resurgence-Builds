---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allBuilds = await getCollection('builds');

  const classes = [
    {
      id: 'vanguard',
      name: 'Vanguard',
      role: 'Support / DPS',
      description: 'The Vanguard is the most versatile specialization in Resurgence. The Commando subclass delivers aggressive close-range burst DPS with Warlord and Lady Death builds, while the Scout subclass is the highest-impact support in the game — buffing team damage through Smart Cover and Scanning Pulse so effectively that one Scout can triple a squad\'s total output.',
      signature: {
        name: 'Tactical Link',
        description: 'Buffs allies with Pulsed status and preferentially targets enemy shields with its damage. Pairs with SAC Efficiency stacking for faster uptime in group content.'
      },
      perkOverview: 'Vanguard talents branch into Commando (Firepower-focused DPS with Warlord/Lady Death/DBS builds) and Scout Recon (Engineering-focused support using Smart Cover and Scanning Pulse to multiply team damage). The Scout meta currently dominates endgame group content.'
    },
    {
      id: 'field-medic',
      name: 'Field Medic',
      role: 'Healer / Battle Medic',
      description: 'The backbone of any Legendary mission or Dark Zone squad. The Field Medic keeps the team alive through Support Station healing, Mender Drone sustain, and the Emergency Healing ultimate. The Combat Medic subclass can also deal meaningful damage by stacking Toughness with the Defensive Measures mod.',
      signature: {
        name: 'Emergency Healing',
        description: 'A burst heal that restores health to the user and nearby allies at 50% of the self-heal value. The AoE radius is fixed and does not scale with Skill Radius or Skill Duration stats.'
      },
      perkOverview: 'Healer stat priority runs Toughness (for survival and Defensive Measures damage scaling) → Skill Intensity → Skill Duration → Skill CDR. Deep Focus chest talent and Captain Cow gear set extend Support Station uptime significantly. Engineering is not worth prioritizing on pure medic builds.'
    },
    {
      id: 'demolitionist',
      name: 'Demolitionist',
      role: 'AoE DPS / Skill DPS',
      description: 'The Demolitionist excels at area denial and burst damage through grenades, artillery skills, and explosive chain reactions. The HE (High Explosive) subclass stacks Engineering and Skill Crit for devastating AoE output, while the Field Grenadier variant offers an alternative approach to explosive damage.',
      signature: {
        name: 'Grenade Launcher',
        description: 'A heavy explosive launcher that deals massive area-of-effect damage. The Thermabaric Grenades mod increases damage to 460% at level 1 but reduces the magazine to a single shot. Synergizes with the Explosive Charge OS Protocol for burst rotations.'
      },
      perkOverview: 'Talent trees revolve around Engineering stacking, Skill Crit Chance/Damage, and Skill Intensity. Recommended gear sets are Jackpot (4pc) with Fire Cycle or Boom-Shakalaka (2pc). Artillery rotations synergize with the Explosive Charge OS Protocol for chained burst damage.'
    },
    {
      id: 'tech-operator',
      name: 'Tech Operator',
      role: 'Skill DPS / Utility',
      description: 'The Tech Operator dominates through deployed skills and gadgetry. The Aegis Operator subclass uses a shield with a powerful undocumented 3-second passive burst mechanic that deals significant damage when stacked with Engineering. The Offensive subclass relies on Striker Drone crits to apply Disoriented status and chain skill damage.',
      signature: {
        name: 'Overdrive',
        description: 'Overcharges deployed skills, dramatically increasing their damage output and effectiveness for a limited duration. Pairs with Engineering stacking and Skill CDR for maximum uptime.'
      },
      perkOverview: 'Aegis builds prioritize Engineering (which benefits the burst mechanic 2.25x more than Skill Damage). Striker Drone is standard for all offensive builds. Swift Aim weapon talent reduces Skill CDR and is effective for Aegis rotations. High skill ceiling in PvP — rewards deep mechanics knowledge.'
    },
    {
      id: 'bulwark',
      name: 'Bulwark',
      role: 'Tank / Frontline',
      description: 'The immovable object. The Bulwark draws enemy fire, absorbs incoming damage, and anchors the team\'s position behind the Phalanx Shield. The Juggernaut subclass is the dominant force in PvP — Shockwave Spike delivers a 3-5 second stun on a 10-second cooldown that the community considers effectively unbeatable.',
      signature: {
        name: 'Shockwave Spike',
        description: 'A devastating stun that incapacitates enemies for 3-5 seconds with a 10-second cooldown. Combined with a Stun Grenade, this creates a 5-second stunlock with no current counterplay. Can also softlock Boss Juggernaut AI with repeated stun loops.'
      },
      perkOverview: 'Juggernaut is universally dominant in PvP and endgame content. Build around Toughness stacking to maximize shield HP. Recommended gear sets are Fearless Warrior or Phalanx Attack (4pc) with Self-Propelled Shield (2pc). Breacher has niche PvE use for armor-breaking but is not meta-defining.'
    }
  ];

  return classes.map(c => {
    // Filter builds for this specific class
    const classBuilds = allBuilds
      .filter(build => build.data.specialization === c.name)
      .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

    return {
      params: { spec: c.id },
      props: { classData: c, builds: classBuilds }
    };
  });
}

const { classData, builds } = Astro.props;

const breadcrumbItems = [
  { name: 'Classes', url: '#' },
  { name: classData.name, url: `/class/${classData.id}/` }
];

const title = `Best ${classData.name} Builds - The Division Resurgence`;
const description = `Discover the top ${classData.name} builds for PvE and PvP in The Division Resurgence. Master the ${classData.signature.name} signature skill and optimize your loadout.`;
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbItems}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Class Hub" />
    
    <div style="margin-bottom: var(--sp-8); padding-bottom: var(--sp-6); border-bottom: 1px solid var(--border);">
      <div style="display: flex; align-items: baseline; gap: var(--sp-3); margin-bottom: var(--sp-2);">
        <h1 class="heading-accent" style="margin: 0;">{classData.name}</h1>
        <span class="tag tag--accent">{classData.role}</span>
      </div>
      
      <p style="font-size: var(--text-lg); color: var(--ink-muted); max-width: 800px; margin-bottom: var(--sp-6); line-height: 1.6;">
        {classData.description}
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--sp-4);">
        <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
          <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Signature Skill: {classData.signature.name}</h3>
          <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
            {classData.signature.description}
          </p>
        </div>
        <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
          <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Talent Overview</h3>
          <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
            {classData.perkOverview}
          </p>
        </div>
      </div>
    </div>

    <h2 class="heading-accent" style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Top {classData.name} Builds</h2>
    
    {builds.length > 0 ? (
      <div class="grid grid--3">
        {builds.map((build) => (
          <div style="display: flex; height: 100%;">
            <BuildCard
              title={build.data.title}
              href={`/builds/${build.id}/`}
              specialization={build.data.specialization}
              playstyle={build.data.playstyle}
              description={build.data.description}
              patch={build.data.patch}
              pve={build.data.pve}
              pvp={build.data.pvp}
              tags={build.data.tags}
              featuredImage={build.data.featuredImage}
              imageAlt={build.data.imageAlt}
            />
          </div>
        ))}
      </div>
    ) : (
      <div style="text-align: center; padding: var(--sp-8) 0; background: rgba(0,0,0,0.1); border-radius: var(--border-radius); border: 1px dashed var(--border);">
        <p style="color: var(--ink-muted);">No builds have been published for this class yet. Check back soon!</p>
      </div>
    )}
  </div>
</BaseLayout>
