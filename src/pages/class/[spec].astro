---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allBuilds = await getCollection('builds');

  const classes = [
    {
      id: 'vanguard',
      name: 'Vanguard',
      role: 'DPS / Team Utility',
      description: 'A front-line attacker that bridges tanking and DPS. The Vanguard kit is built around Mobile Cover and Pulse-style scouting tools, giving the team both positional advantage and intel. The Commando subclass focuses on close-range burst damage, while the Scout Recon path provides high-impact team utility that community builds frequently rate as one of the strongest endgame setups.',
      signature: {
        name: 'Tactical Link',
        description: 'The Vanguard\'s iconic offensive team buff. Tactical Link provides a high-impact damage and tempo boost tied into the class\'s cover and scouting tools.'
      },
      perkOverview: 'Vanguard talents branch into Commando (Firepower-focused DPS with Warlord, Lady Death, and DBS builds) and Scout Recon (Engineering-focused team utility using Smart Cover and Scanning Pulse). Community builds rate Scout Recon as very strong in endgame group content.'
    },
    {
      id: 'field-medic',
      name: 'Field Medic',
      role: 'Healer / Support',
      description: 'The backbone of any Legendary mission or Dark Zone squad. The Field Medic keeps the team alive through healing skills, support tools, and a powerful burst-heal ultimate. The Combat Medic subclass can also deal meaningful damage by stacking Toughness with the Defensive Measures mod.',
      signature: {
        name: 'Burst Heal',
        description: 'A burst heal that restores health to the user and splashes healing to nearby allies. The Field Medic\'s emergency heal is the most impactful single-use recovery tool in the game.'
      },
      perkOverview: 'Community builds commonly prioritize Toughness (for survival and Defensive Measures damage scaling), followed by Skill Intensity, Skill Duration, and Skill CDR. Deep Focus chest talent and Captain Cow gear set extend Support Station uptime significantly.'
    },
    {
      id: 'demolitionist',
      name: 'Demolitionist',
      role: 'AoE DPS / Explosive Specialist',
      description: 'The Demolitionist excels at area denial and burst damage through grenades, artillery skills, and explosive chain reactions. The HE (High Explosive) subclass stacks Engineering and Skill Crit for devastating AoE output, while the Field Grenadier variant offers an alternative approach to explosive damage.',
      signature: {
        name: 'Grenade Launcher',
        description: 'A heavy explosive launcher that deals massive area-of-effect damage. Mods can dramatically increase per-shot damage at the cost of magazine capacity. The signature synergizes with Engineering stacking and explosive OS Protocols.'
      },
      perkOverview: 'Talent trees revolve around Engineering stacking, Skill Crit Chance, Skill Crit Damage, and Skill Intensity. Community builds commonly run Jackpot (4pc) with Fire Cycle or Boom-Shakalaka (2pc) for maximum skill crit output.'
    },
    {
      id: 'tech-operator',
      name: 'Tech Operator',
      role: 'Skill DPS / Utility',
      description: 'The Tech Operator dominates through deployed skills and gadgetry. The Aegis Operator subclass uses a shield with a passive burst mechanic that deals significant damage when built around Engineering. The Offensive subclass uses Striker Drone crits to apply Disoriented status and chain skill damage.',
      signature: {
        name: 'Skill Overcharge',
        description: 'Overcharges deployed skills for a limited duration, increasing their damage output and effectiveness. Pairs with Engineering stacking for maximum burst potential.'
      },
      perkOverview: 'Aegis builds prioritize Engineering, which benefits the passive burst mechanic significantly more than Skill Damage. Tampishach\'s 237k DPS Tech Aegis build runs Long-term Effect 4pc with Brains Over Brawn for 53% Skill Crit Chance. Striker Drone is standard for offensive builds. High skill ceiling in PvP per community assessment.'
    },
    {
      id: 'bulwark',
      name: 'Bulwark',
      role: 'Tank / Frontline',
      description: 'The immovable object. The Bulwark draws enemy fire, absorbs incoming damage, and anchors the team\'s position behind the Phalanx Shield. Shockwave Spike MK3 emits shockwaves that apply Shock status, immobilizing enemies for several seconds — making Bulwark the most feared PvP specialization in the current meta.',
      signature: {
        name: 'Breach Combo',
        description: 'Expands the Phalanx Shield and pairs it with a powerful shotgun for aggressive close-range engagements. The Bulwark\'s signature enables the class to push forward while maintaining full frontal protection.'
      },
      perkOverview: 'Juggernaut is the dominant Bulwark subclass for both PvP and endgame PvE. Shockwave Spike MK3 provides approximately 5-second stuns on a short cooldown per community observation. Build around Toughness to maximize shield HP. Breacher is a proven PvE DPS path — Saiynergy\'s 334k DPS shield build runs Fury Strike 4pc with Death From Afar.'
    }
  ];

  return classes.map(c => {
    // Filter builds for this specific class
    const classBuilds = allBuilds
      .filter(build => build.data.specialization === c.name)
      .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

    return {
      params: { spec: c.id },
      props: { classData: c, builds: classBuilds }
    };
  });
}

const { classData, builds } = Astro.props;

const breadcrumbItems = [
  { name: 'Classes', url: '/builds/' },
  { name: classData.name, url: `/class/${classData.id}/` }
];

const title = `Best ${classData.name} Builds — Division Resurgence`;
const description = `Top ${classData.name} builds for PvE and PvP in Division Resurgence. ${classData.role} loadouts with gear sets, talents, and OS Protocols.`;

const faqs = [
  {
    question: `Is ${classData.name} good in Division Resurgence?`,
    answer: classData.description
  },
  {
    question: `What is the best ${classData.name} build?`,
    answer: builds.length > 0
      ? `The top-rated ${classData.name} build on Resurgence Builds is ${builds[0].data.title}. ${classData.perkOverview}`
      : `${classData.name} builds focus on ${classData.role} playstyles. ${classData.perkOverview}`
  },
  {
    question: `What gear sets work best for ${classData.name}?`,
    answer: classData.perkOverview
  }
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbItems} faqs={faqs} ogImage={builds.length > 0 && builds[0].data.featuredImage ? builds[0].data.featuredImage : '/images/best-pve-dps-builds-division-resurgence.png'}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Class Hub" />
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-4); font-size: var(--text-sm);">
      <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); border-radius: 4px; color: #22c55e; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.03em;">✓ Verified for Patch 1.2.1</span>
    </div>
    
    <div style="margin-bottom: var(--sp-8); padding-bottom: var(--sp-6); border-bottom: 1px solid var(--border);">
      <div style="display: flex; align-items: baseline; gap: var(--sp-3); margin-bottom: var(--sp-2);">
        <h1 class="heading-accent" style="margin: 0;">{classData.name}</h1>
        <span class="tag tag--accent">{classData.role}</span>
      </div>
      
      <p style="font-size: var(--text-lg); color: var(--ink-muted); max-width: 800px; margin-bottom: var(--sp-6); line-height: 1.6;">
        {classData.description}
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--sp-4);">
        <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
          <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Signature Skill: {classData.signature.name}</h3>
          <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
            {classData.signature.description}
          </p>
        </div>
        <div style="background: rgba(0,0,0,0.2); padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--border-radius);">
          <h3 style="color: var(--accent); margin-bottom: var(--sp-2); font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.05em;">Talent Overview</h3>
          <p style="color: var(--ink-muted); font-size: var(--text-sm); margin: 0;">
            {classData.perkOverview}
          </p>
        </div>
      </div>
    </div>

    <h2 class="heading-accent" style="font-size: var(--text-xl); margin-bottom: var(--sp-4);">Top {classData.name} Builds</h2>
    
    {builds.length > 0 ? (
      <div class="grid grid--3">
        {builds.map((build) => (
          <div style="display: flex; height: 100%;">
            <BuildCard
              title={build.data.title}
              href={`/builds/${build.id}/`}
              specialization={build.data.specialization}
              playstyle={build.data.playstyle}
              description={build.data.description}
              patch={build.data.patch}
              pve={build.data.pve}
              pvp={build.data.pvp}
              tags={build.data.tags}
              featuredImage={build.data.featuredImage}
              imageAlt={build.data.imageAlt}
            />
          </div>
        ))}
      </div>
    ) : (
      <div style="text-align: center; padding: var(--sp-8) 0; background: rgba(0,0,0,0.1); border-radius: var(--border-radius); border: 1px dashed var(--border);">
        <p style="color: var(--ink-muted);">No builds have been published for this class yet. Check back soon!</p>
      </div>
    )}

    <AdSenseUnit />
  </div>
</BaseLayout>
