---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found"
  description="The page you are looking for does not exist on Resurgence Builds."
>
  <div class="container section text-center" style="padding-top: 15vh; padding-bottom: 15vh;">
    <h1 style="font-size: 6rem; color: var(--accent); margin-bottom: var(--sp-4);">404</h1>
    <h2 class="heading-accent" style="margin-bottom: var(--sp-6);">Agent Offline</h2>
    <p style="color: var(--ink-muted); font-size: var(--text-lg); max-width: 600px; margin: 0 auto var(--sp-8);">
      The page you're trying to reach has gone rogue or doesn't exist. Check your coordinates and try again.
    </p>
    <a href="/" class="btn btn--primary">Return to Base</a>
  </div>
</BaseLayout>

<style>
  .text-center {
    text-align: center;
  }
</style>
