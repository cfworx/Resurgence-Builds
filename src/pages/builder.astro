---
import BaseLayout from '../layouts/BaseLayout.astro';
import gearSets from '../data/gear-set-effects.json';
import weaponTalents from '../data/weapon-talents.json';
import exoticWeapons from '../data/exotic-weapons.json';
import standardWeapons from '../data/standard-weapons.json';
import bodyArmorTalents from '../data/body-armor-talents.json';
import backpackTalents from '../data/backpack-talents.json';
import osProtocols from '../data/os-protocols.json';
import skillModCombos from '../data/skill-mod-combos.json';
import bonusAttributes from '../data/bonus-attributes.json';
import { getCollection } from 'astro:content';

const allBuilds = await getCollection('builds');
const templates = allBuilds
  .filter(b => b.data.plannerHash)
  .map(b => ({
    id: b.id,
    name: (b.data.title.split(' — ')[1] || b.data.title).trim(),
    hash: b.data.plannerHash,
    spec: b.data.specialization
  }));

const title = "SHD Build Lab — Division Resurgence Tactical Loadout Planner";
const description = "Plan your Division Resurgence loadout with the SHD Build Lab. Configure gear sets, weapons, OS protocols, and skill mods with live ISAC diagnostics, synergy mapping, and shareable build links.";
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Build Lab', url: '/builder/' }
];
const jsonLd = {
  '@type': 'WebApplication',
  '@id': 'https://resurgencebuilds.com/builder/#app',
  name: 'SHD Build Lab — Division Resurgence Loadout Planner',
  url: 'https://resurgencebuilds.com/builder/',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any (browser)',
  browserRequirements: 'Requires JavaScript. Modern evergreen browser.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  about: { '@id': 'https://resurgencebuilds.com/#division-resurgence' },
  publisher: { '@id': 'https://resurgencebuilds.com/#organization' }
};

const allAttributes = bonusAttributes.flatMap(cat => cat.attributes);
const dataPayload = JSON.stringify({
  gearSets, weaponTalents, exoticWeapons, standardWeapons,
  bodyArmorTalents, backpackTalents, osProtocols, skillModCombos,
  bonusAttributes, allAttributes, templates
});

const gearSetCount = gearSets.length;
const osCount = osProtocols.length;
const smcCount = skillModCombos.length;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
  noAds={true}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/builder-v3.css" />
  </Fragment>

  <!-- Boot / Scan Overlay -->
  <div class="boot" id="boot" aria-hidden="true">
    <div class="boot__grid"></div>
    <div class="boot__core">
      <svg class="boot__ring" viewBox="0 0 200 200" width="200" height="200">
        <circle class="boot__ring-track" cx="100" cy="100" r="86"/>
        <circle class="boot__ring-prog" cx="100" cy="100" r="86"/>
        <circle class="boot__ring-track" cx="100" cy="100" r="64" opacity=".5"/>
        <path class="boot__tick" d="M100 14 L100 26 M186 100 L174 100 M100 186 L100 174 M14 100 L26 100"/>
        <g class="boot__hex">
          <path d="M100 60 L134 80 L134 120 L100 140 L66 120 L66 80 Z"/>
        </g>
      </svg>
      <div class="boot__readout">
        <span class="boot__label">SHD NETWORK</span>
        <span class="boot__status" id="bootStatus">ESTABLISHING UPLINK</span>
        <div class="boot__bar"><i id="bootBar"></i></div>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__scan"></div>
    <div class="hero__inner">
      <span class="hero__eyebrow"><i class="dot"></i> SHD TERMINAL ACCESS // SECURE</span>
      <h1 class="hero__title">SHD <em>BUILD LAB</em></h1>
      <p class="hero__sub">DIVISION RESURGENCE — TACTICAL LOADOUT TERMINAL</p>
      <div class="hero__meta">
        <span class="chip chip--ok"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Verified · Patch 1.1.2.2</span>
      </div>
    </div>
  </section>

  <!-- App Shell -->
  <div class="lab" id="lab">

    <!-- Template Bar -->
    <div class="panel panel--bar">
      <div class="bar__label"><span class="kicker">// LOADOUT TEMPLATE</span></div>
      <div class="bar__select">
        <div class="picker" data-picker="template">
          <button class="picker__btn" id="tplBtn" aria-haspopup="listbox">
            <span id="tplLabel">Select a verified template to populate the terminal…</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
        </div>
      </div>
      <button class="btn-ghost" id="resetBtn">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 109-9 9 9 0 00-6.4 2.6L3 8M3 4v4h4"/></svg>
        Reset
      </button>
    </div>

    <!-- Build Name -->
    <div class="panel panel--bar" style="margin-top:-8px;padding:10px var(--space-5)">
      <div class="bar__label"><span class="kicker">// BUILD NAME</span></div>
      <div class="build-name">
        <input type="text" class="build-name__input" id="buildNameInput" placeholder="Name your build…" maxlength="60" autocomplete="off">
      </div>
    </div>

    <div class="lab__grid">

      <!-- LEFT COLUMN: AGENT -->
      <div class="col col--left">

        <section class="panel" id="specPanel">
          <div class="panel__hd"><span class="kicker">// AGENT SPECIALIZATION</span></div>
          <div class="panel__bd">
            <div class="spec-grid" id="specGrid"></div>
            <div class="field">
              <label class="field__lbl">Specialization Focus</label>
              <div class="picker" data-picker="subclass">
                <button class="picker__btn picker__btn--sm" id="subBtn" aria-haspopup="listbox">
                  <span id="subLabel">—</span>
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </button>
              </div>
            </div>
          </div>
        </section>

        <section class="panel" id="osPanel">
          <div class="panel__hd">
            <span class="kicker">// OS PROTOCOL</span>
            <span class="tag tag--blue" id="osFocusTag">SELECT SPEC</span>
          </div>
          <div class="panel__bd">
            <div class="slot slot--lg" id="osSlot">
              <div class="slot__icon">
                <img src="/images/icons/icon-os.webp" alt="OS Protocol" width="22" height="22" />
              </div>
              <div class="slot__body">
                <span class="slot__name" id="osName">Select OS Protocol</span>
                <span class="slot__sub" id="osSub">Choose a protocol matched to your focus</span>
              </div>
            </div>
          </div>
        </section>

        <section class="panel" id="talentPanel">
          <div class="panel__hd"><span class="kicker">// ARMOR TALENTS</span></div>
          <div class="panel__bd">
            <div class="picktag picktag--wide" data-armortalent="body"><span class="picktag__lbl">Body Armor Talent</span><span class="picktag__val" id="bodyTalentVal">—</span></div>
            <div class="picktag picktag--wide" data-armortalent="backpack"><span class="picktag__lbl">Backpack Talent</span><span class="picktag__val" id="backTalentVal">—</span></div>
          </div>
        </section>

        <section class="panel" id="skillPanel">
          <div class="panel__hd"><span class="kicker">// SKILL MODS</span><span class="tag" id="skillCount">0 / 3</span></div>
          <div class="panel__bd skill-list" id="skillList"></div>
        </section>

      </div>

      <!-- CENTER COLUMN: LOADOUT -->
      <div class="col col--center">

        <section class="panel panel--loadout" id="gearPanel">
          <div class="panel__hd"><span class="kicker">// GEAR LOADOUT</span><span class="tag" id="gearPieces">0 / 6 SLOTS</span></div>
          <div class="panel__bd">
            <div class="rig">
              <svg class="rig__trace" viewBox="0 0 600 360" preserveAspectRatio="none" aria-hidden="true">
                <path id="trace-line" d="M150 70 L300 40 L450 70 M150 180 L300 180 L450 180 M150 290 L300 320 L450 290" />
              </svg>
              <div class="rig__col rig__col--l">
                <div class="gearslot" data-slot="mask">
                  <div class="gearslot__ico" data-ico="mask"><img src="/images/icons/icon-mask.webp" alt="Mask gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Mask</span><span class="gearslot__val">Empty</span></div>
                </div>
                <div class="gearslot" data-slot="gloves">
                  <div class="gearslot__ico" data-ico="gloves"><img src="/images/icons/icon-gloves.webp" alt="Gloves gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Gloves</span><span class="gearslot__val">Empty</span></div>
                </div>
                <div class="gearslot" data-slot="holster">
                  <div class="gearslot__ico" data-ico="holster"><img src="/images/icons/icon-holster.webp" alt="Holster gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Holster</span><span class="gearslot__val">Empty</span></div>
                </div>
              </div>
              <div class="rig__core">
                <div class="rig__silhouette" id="rigSil">
                  <span class="rig__score-lbl">BUILD SCORE</span>
                  <span class="rig__score" id="rigScore">—</span>
                  <img src="/images/resurgence-builds-official-logo.webp" alt="ResurgenceBuilds" class="rig__logo" width="120" height="120" />
                </div>
              </div>
              <div class="rig__col rig__col--r">
                <div class="gearslot" data-slot="body">
                  <div class="gearslot__ico" data-ico="body"><img src="/images/icons/icon-shield.webp" alt="Body armor gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Body Armor</span><span class="gearslot__val">Empty</span></div>
                </div>
                <div class="gearslot" data-slot="backpack">
                  <div class="gearslot__ico" data-ico="backpack"><img src="/images/icons/icon-backpack.webp" alt="Backpack gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Backpack</span><span class="gearslot__val">Empty</span></div>
                </div>
                <div class="gearslot" data-slot="kneepads">
                  <div class="gearslot__ico" data-ico="kneepads"><img src="/images/icons/icon-kneepads.webp" alt="Kneepads gear slot" width="24" height="24" /></div>
                  <div class="gearslot__txt"><span class="gearslot__lbl">Kneepads</span><span class="gearslot__val">Empty</span></div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Weapons -->
        <div class="weapon-row">
          <section class="panel" data-weapon="1">
            <div class="panel__hd"><span class="kicker">// PRIMARY WEAPON</span></div>
            <div class="panel__bd">
              <div class="slot" data-wslot="1">
                <div class="slot__icon"><img src="/images/icons/icon-weapon.webp" alt="Primary weapon" width="20" height="20" /></div>
                <div class="slot__body"><span class="slot__name" id="w1name">Select Primary</span><span class="slot__sub" id="w1sub">—</span></div>
              </div>
              <div class="weapon-bonuses">
                <div class="weapon-bonus" data-wbonus="1" data-wbidx="1">
                  <span class="picktag__lbl">BONUS 1</span>
                  <span class="picktag__val" id="w1bonus1">—</span>
                </div>
                <div class="weapon-bonus" data-wbonus="1" data-wbidx="2">
                  <span class="picktag__lbl">BONUS 2</span>
                  <span class="picktag__val" id="w1bonus2">—</span>
                </div>
              </div>
              <div class="talent-pair">
                <div class="picktag is-fixed" id="w1fixed" style="display:none"><span class="picktag__lbl">EXOTIC</span><span class="picktag__val">—</span></div>
                <div class="picktag" data-talent="w1t1"><span class="picktag__lbl">Talent 1</span><span class="picktag__val">—</span></div>
                <div class="picktag" data-talent="w1t2"><span class="picktag__lbl">Talent 2</span><span class="picktag__val">—</span></div>
              </div>
            </div>
          </section>
          <section class="panel" data-weapon="2">
            <div class="panel__hd"><span class="kicker">// SECONDARY WEAPON</span></div>
            <div class="panel__bd">
              <div class="slot" data-wslot="2">
                <div class="slot__icon"><img src="/images/icons/icon-weapon.webp" alt="Secondary weapon" width="20" height="20" /></div>
                <div class="slot__body"><span class="slot__name" id="w2name">Select Secondary</span><span class="slot__sub" id="w2sub">—</span></div>
              </div>
              <div class="weapon-bonuses">
                <div class="weapon-bonus" data-wbonus="2" data-wbidx="1">
                  <span class="picktag__lbl">BONUS 1</span>
                  <span class="picktag__val" id="w2bonus1">—</span>
                </div>
                <div class="weapon-bonus" data-wbonus="2" data-wbidx="2">
                  <span class="picktag__lbl">BONUS 2</span>
                  <span class="picktag__val" id="w2bonus2">—</span>
                </div>
              </div>
              <div class="talent-pair">
                <div class="picktag is-fixed" id="w2fixed" style="display:none"><span class="picktag__lbl">EXOTIC</span><span class="picktag__val">—</span></div>
                <div class="picktag" data-talent="w2t1"><span class="picktag__lbl">Talent 1</span><span class="picktag__val">—</span></div>
                <div class="picktag" data-talent="w2t2"><span class="picktag__lbl">Talent 2</span><span class="picktag__val">—</span></div>
              </div>
            </div>
          </section>
        </div>

        <!-- Build Overview -->
        <section class="panel" id="loopPanel">
          <div class="panel__hd"><span class="kicker">// BUILD OVERVIEW</span></div>
          <div class="panel__bd loop__bd">
            <div class="loop__graph" id="loopGraph"></div>
            <ol class="loop__steps" id="loopSteps"></ol>
          </div>
        </section>
      </div>

      <!-- RIGHT COLUMN: TELEMETRY -->
      <aside class="col col--right">

        <section class="panel panel--isac" id="isacPanel">
          <div class="panel__hd"><span class="kicker">// ISAC ANALYSIS</span><i class="isac-pulse"></i></div>
          <div class="panel__bd">
            <div class="rating" id="rating">
              <span class="rating__grade" id="ratingGrade">STANDBY</span>
              <div class="rating__meter"><i id="ratingMeter"></i></div>
            </div>
            <p class="isac-text" id="isacText">Awaiting agent configuration. Select a specialization to initialize loadout diagnostics.</p>
          </div>
        </section>

        <section class="panel" id="statsPanel">
          <div class="panel__hd"><span class="kicker">// STAT TELEMETRY</span></div>
          <div class="panel__bd stat-list" id="statList"></div>
        </section>

        <section class="panel" id="bonusPanel">
          <div class="panel__hd"><span class="kicker">// ACTIVE SET BONUSES</span></div>
          <div class="panel__bd" id="bonusList">
            <p class="empty">No active set bonuses. Equip 2+ matching pieces.</p>
          </div>
        </section>

        <section class="panel" id="diagPanel">
          <div class="panel__hd"><span class="kicker">// DIAGNOSTICS</span></div>
          <div class="panel__bd" id="diagList">
            <p class="empty">No conflicts detected.</p>
          </div>
        </section>

        <div class="share-row">
          <button class="btn-primary" id="shareBtn">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8h16v-8M12 3v13M7 8l5-5 5 5"/></svg>
            COPY BUILD LINK
          </button>
          <button class="btn-ghost btn-ghost--card" id="cardBtn">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3 9h18"/></svg>
            Build Card
          </button>
        </div>
      </aside>


    </div>
  </div>

  <!-- Picker Modal -->
  <div class="modal" id="modal" aria-hidden="true">
    <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal__hd">
        <span class="kicker" id="modalTitle">// SELECT</span>
        <button class="modal__x" id="modalClose" aria-label="Close">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <div class="modal__search">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <input type="text" id="modalSearch" placeholder="Search by name, stat, or effect…" autocomplete="off">
      </div>
      <div class="modal__list" id="modalList"></div>
    </div>
  </div>

  <!-- Build Card Modal -->
  <div class="modal" id="cardModal" aria-hidden="true">
    <div class="modal__panel modal__panel--card" role="dialog" aria-modal="true">
      <div class="modal__hd">
        <span class="kicker">// SHAREABLE BUILD CARD</span>
        <button class="modal__x" id="cardClose" aria-label="Close">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <div class="card-preview" id="cardPreview"></div>
      <p class="card-note">This is how your build appears when shared to Discord, Reddit, or X.</p>
    </div>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <!-- Data payload from verified Astro JSON files -->
  <script type="application/json" id="builder-data" set:html={dataPayload}></script>
  <script is:inline src="/js/builder-v3-engine.js"></script>
</BaseLayout>

<style is:global>
  /* Override BaseLayout for SHD terminal aesthetic */
  body:has(.lab) {
    background-color: #05070b !important;
    background-image:
      radial-gradient(1200px 600px at 80% -10%, rgba(255,138,46,.08), transparent 60%),
      radial-gradient(900px 500px at -10% 20%, rgba(82,168,255,.05), transparent 55%),
      linear-gradient(rgba(82,168,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(82,168,255,.04) 1px, transparent 1px) !important;
    background-size: auto, auto, 44px 44px, 44px 44px !important;
    background-attachment: fixed !important;
  }
  /* Scanline grain */
  body:has(.lab)::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: .5;
    background: repeating-linear-gradient(0deg, rgba(255,255,255,.012) 0 1px, transparent 1px 3px);
  }
  /* Boot overlay must cover EVERYTHING including header */
  body:has(.boot:not(.is-done)) .site-header,
  body:has(.boot:not(.is-done)) header {
    opacity: 0 !important;
    pointer-events: none !important;
  }
  body:has(.boot:not(.is-done)) #main-content {
    z-index: 10001 !important;
  }
  /* Hide the normal page container padding */
  body:has(.lab) #main-content {
    padding: 0 !important;
    max-width: none !important;
  }
  body:has(.lab) #main-content > .container {
    max-width: none !important;
    padding: 0 !important;
  }
  /* Spec icon sizing */
  .sigil {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }
  .spec-btn.is-active .sigil {
    filter: drop-shadow(0 0 6px rgba(255,138,46,.7)) drop-shadow(0 0 12px rgba(255,138,46,.3));
  }
  /* Stat icon in telemetry */
  .stat-ico {
    width: 14px;
    height: 14px;
    object-fit: contain;
    margin-right: 6px;
    vertical-align: middle;
    opacity: .8;
  }
</style>
