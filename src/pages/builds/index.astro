---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import { getCollection } from 'astro:content';

const allBuilds = await getCollection('builds');
const sorted = allBuilds.sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

const specs = [...new Set(allBuilds.map(b => b.data.specialization))];
const playstyles = [...new Set(allBuilds.map(b => b.data.playstyle))];

const breadcrumbItems = [{ name: 'Builds', url: '/builds/' }];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://resurgencebuilds.com';
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Best Builds Tier List',
  itemListElement: sorted.map((build, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: build.data.title,
    url: `${siteUrl}/builds/${build.id}/`,
  }))
};
---

<BaseLayout
  title="Builds"
  description="Browse all Division Resurgence builds. Filter by specialization and playstyle. Updated every patch."
  breadcrumbs={breadcrumbItems}
  jsonLd={itemListLd}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Builds" />
    <h1 class="heading-accent">All Builds</h1>
    <p style="color:var(--ink-muted);margin-bottom:var(--sp-6);">
      Tested and optimized meta and non-meta builds for every specialization and playstyle. Updated for the latest patch.
    </p>

    <div class="filter-bar" id="build-filters">
      <button class="filter-btn is-active" data-filter="all">All</button>
      <div class="filter-separator" style="width: 1px; height: 1.5rem; background: var(--border); margin: 0 var(--sp-2);"></div>
      <button class="filter-btn" data-filter="pve">PvE</button>
      <button class="filter-btn" data-filter="pvp">PvP</button>
      <button class="filter-btn" data-filter="meta">Meta</button>
      <div class="filter-separator" style="width: 1px; height: 1.5rem; background: var(--border); margin: 0 var(--sp-2);"></div>
      {specs.map(s => <button class="filter-btn" data-filter={s}>{s}</button>)}
    </div>

    <div class="grid grid--3" id="builds-grid">
      {sorted.map((build) => (
        <div 
          style="display: flex; height: 100%;"
          data-spec={build.data.specialization} 
          data-playstyle={build.data.playstyle}
          data-pve={build.data.pve ? 'true' : 'false'}
          data-pvp={build.data.pvp ? 'true' : 'false'}
          data-tags={JSON.stringify(build.data.tags || [])}
        >
          <BuildCard
            title={build.data.title}
            href={`/builds/${build.id}/`}
            specialization={build.data.specialization}
            playstyle={build.data.playstyle}
            description={build.data.description}
            patch={build.data.patch}
            pve={build.data.pve}
            pvp={build.data.pvp}
            tags={build.data.tags}
            featuredImage={build.data.featuredImage}
            imageAlt={build.data.imageAlt}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const filterBar = document.getElementById('build-filters');
  const grid = document.getElementById('builds-grid');
  if (filterBar && grid) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn');
      if (!btn) return;
      
      // Update UI state immediately
      filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.getAttribute('data-filter');
      
      // Defer DOM updates to next frame to optimize INP
      requestAnimationFrame(() => {
        grid.querySelectorAll('[data-spec]').forEach(card => {
          const el = card as HTMLElement;
          let show = false;
          
          if (filter === 'all') {
            show = true;
          } else if (filter === 'pve') {
            show = el.dataset.pve === 'true';
          } else if (filter === 'pvp') {
            show = el.dataset.pvp === 'true';
          } else if (filter === 'meta') {
            try {
              const tags = JSON.parse(el.dataset.tags || '[]');
              // Case insensitive match for 'meta' tag
              show = tags.some((t: string) => t.toLowerCase() === 'meta');
            } catch {
              show = false;
            }
          } else {
            // Must be a specialization filter
            show = el.dataset.spec === filter;
          }
          
          el.style.display = show ? '' : 'none';
        });
      });
    });
  }
</script>
