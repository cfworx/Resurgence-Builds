---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import { getCollection } from 'astro:content';

const allBuilds = await getCollection('builds');
const sorted = allBuilds.sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

const specs = [...new Set(allBuilds.map(b => b.data.specialization))];

const breadcrumbItems = [{ name: 'Builds', url: '/builds/' }];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://resurgencebuilds.com';
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Division Resurgence Best Builds Tier List',
  itemListElement: sorted.map((build, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: build.data.title,
    url: `${siteUrl}/builds/${build.id}/`,
  }))
};
---

<BaseLayout
  title="Division Resurgence Builds & Tier List"
  description="Browse every Division Resurgence build guide, filtered by specialization and playstyle. Updated every patch with the latest PvE and PvP meta loadouts."
  breadcrumbs={breadcrumbItems}
  jsonLd={itemListLd}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Builds" />
    <h1 class="heading-accent">All Builds</h1>
    <p style="color:var(--ink-muted);margin-bottom:var(--sp-6);">
      Every build we've tested and haven't been embarrassed to publish. Updated every patch with the latest meta shifts and balance changes.
    </p>

    <div class="filter-bar" id="build-filters">
      <button class="filter-btn is-active" data-filter="all">All</button>
      <div class="filter-separator" style="width: 1px; height: 1.5rem; background: var(--border); margin: 0 var(--sp-2);"></div>
      <button class="filter-btn" data-filter="pve">PvE</button>
      <button class="filter-btn" data-filter="pvp">PvP</button>
      <button class="filter-btn" data-filter="pvepvp">PvE/PvP</button>
      <div class="filter-separator" style="width: 1px; height: 1.5rem; background: var(--border); margin: 0 var(--sp-2);"></div>
      {specs.map(s => <button class="filter-btn" data-filter={s}>{s}</button>)}
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: var(--sp-2); margin-bottom: var(--sp-8);">
      <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.08em; align-self: center; margin-right: var(--sp-1);">Class Hubs</span>
      <a href="/class/vanguard/" style="font-size: var(--text-xs); padding: 4px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; color: var(--ink-muted); transition: all 200ms ease; text-decoration: none;">Vanguard</a>
      <a href="/class/field-medic/" style="font-size: var(--text-xs); padding: 4px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; color: var(--ink-muted); transition: all 200ms ease; text-decoration: none;">Field Medic</a>
      <a href="/class/demolitionist/" style="font-size: var(--text-xs); padding: 4px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; color: var(--ink-muted); transition: all 200ms ease; text-decoration: none;">Demolitionist</a>
      <a href="/class/tech-operator/" style="font-size: var(--text-xs); padding: 4px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; color: var(--ink-muted); transition: all 200ms ease; text-decoration: none;">Tech Operator</a>
      <a href="/class/bulwark/" style="font-size: var(--text-xs); padding: 4px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; color: var(--ink-muted); transition: all 200ms ease; text-decoration: none;">Bulwark</a>
    </div>

    <div class="grid grid--3" id="builds-grid">
      {sorted.map((build) => (
        <div 
          style="display: flex; height: 100%;"
          data-spec={build.data.specialization} 
          data-playstyle={build.data.playstyle}
          data-pve={build.data.pve ? 'true' : 'false'}
          data-pvp={build.data.pvp ? 'true' : 'false'}
          data-tags={JSON.stringify(build.data.tags || [])}
        >
          <BuildCard
            title={build.data.title}
            href={`/builds/${build.id}/`}
            specialization={build.data.specialization}
            playstyle={build.data.playstyle}
            description={build.data.description}
            patch={build.data.patch}
            pve={build.data.pve}
            pvp={build.data.pvp}
            tags={build.data.tags}
            featuredImage={build.data.featuredImage}
            imageAlt={build.data.imageAlt}
          />
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <div id="pagination-controls" style="justify-content:center; align-items:center; gap:var(--sp-4); margin-top:var(--sp-8); display:none;">
      <button class="btn btn--outline" id="prev-page" disabled>Previous</button>
      <span id="page-info" style="color:var(--ink); font-family:var(--font-mono);">Page 1 of 1</span>
      <button class="btn btn--outline" id="next-page" disabled>Next</button>
    </div>

    <!-- Empty state -->
    <div id="no-results" style="display:none;text-align:center;padding:var(--sp-12) 0;">
      <p style="color:var(--ink-muted);font-size:var(--text-lg);">No builds match that filter. Your standards are too high. Lower them and try again.</p>
      <button class="btn btn--outline" id="clear-filter" style="margin-top:var(--sp-4);">Show All Builds</button>
    </div>
  </div>
</BaseLayout>

<script>
  const filterBar = document.getElementById('build-filters');
  const grid = document.getElementById('builds-grid');
  const noResults = document.getElementById('no-results');
  const clearBtn = document.getElementById('clear-filter');
  
  const paginationControls = document.getElementById('pagination-controls');
  const prevBtn = document.getElementById('prev-page');
  const nextBtn = document.getElementById('next-page');
  const pageInfo = document.getElementById('page-info');

  const ITEMS_PER_PAGE = 9;
  let currentPage = 1;
  let currentFilter = 'all';

  function filterBuilds() {
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-spec]'));
    let matchedCards: HTMLElement[] = [];

    cards.forEach((el) => {
      let show = false;
      if (currentFilter === 'all') {
        show = true;
      } else if (currentFilter === 'pve') {
        show = el.dataset.pve === 'true';
      } else if (currentFilter === 'pvp') {
        show = el.dataset.pvp === 'true';
      } else if (currentFilter === 'pvepvp') {
        show = el.dataset.pve === 'true' && el.dataset.pvp === 'true';
      } else {
        show = el.dataset.spec === currentFilter;
      }

      if (show) {
        matchedCards.push(el);
      } else {
        el.style.display = 'none';
      }
    });

    const totalPages = Math.ceil(matchedCards.length / ITEMS_PER_PAGE);
    if (currentPage > totalPages) currentPage = totalPages || 1;

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    matchedCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.style.display = matchedCards.length === 0 ? '' : 'none';
    }

    if (paginationControls && prevBtn && nextBtn && pageInfo) {
      if (totalPages > 1) {
        paginationControls.style.display = 'flex';
        pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        
        if (currentPage === 1) {
          prevBtn.setAttribute('disabled', 'true');
        } else {
          prevBtn.removeAttribute('disabled');
        }

        if (currentPage === totalPages) {
          nextBtn.setAttribute('disabled', 'true');
        } else {
          nextBtn.removeAttribute('disabled');
        }
      } else {
        paginationControls.style.display = 'none';
      }
    }
  }

  function setActiveButton(activeBtn: Element) {
    filterBar?.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('is-active'));
    activeBtn.classList.add('is-active');
  }

  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn');
      if (!btn) return;
      setActiveButton(btn);
      currentFilter = btn.getAttribute('data-filter') || 'all';
      currentPage = 1;
      filterBuilds();
    });
  }

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      const allBtn = filterBar?.querySelector('[data-filter="all"]');
      if (allBtn) setActiveButton(allBtn);
      currentFilter = 'all';
      currentPage = 1;
      filterBuilds();
    });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        filterBuilds();
        grid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      currentPage++;
      filterBuilds();
      grid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  filterBuilds();
</script>
