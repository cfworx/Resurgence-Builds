---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';
import { getCollection } from 'astro:content';

const allBuilds = await getCollection('builds');

function assignTier(build) {
  const text = (build.data.title + ' ' + build.data.description + ' ' + (build.data.tags||[]).join(' ')).toLowerCase();
  
  if (text.includes('roguemadras') || text.includes('tactical pharma')) return 'S';
  if (text.includes('saiynergy') || text.includes('breacher')) return 'A';
  if (text.includes('tampishach') || text.includes('tech aegis')) return 'A';
  if (text.includes('milkshake') || text.includes('strawberry')) return 'B';
  if (text.includes('disorient') || text.includes('tech-op')) return 'A';
  if (text.includes('agenthuntzman') || (text.includes('vanguard') && text.includes('recon'))) return 'B';
  if (text.includes('pve enjoyer') || (text.includes('demolitionist') && text.includes('glass cannon'))) return 'A';

  return 'B';
}

const buildsWithTers = allBuilds.map(b => ({ ...b, tier: assignTier(b) }));

const sTier = buildsWithTers.filter(b => b.tier === 'S');
const aTier = buildsWithTers.filter(b => b.tier === 'A');
const bTier = buildsWithTers.filter(b => b.tier === 'B');
const cTier = buildsWithTers.filter(b => b.tier === 'C');

const breadcrumbItems = [{ name: 'Tier List', url: '/tier-list/' }];

const title = "Best Builds & Tier List — Division Resurgence";
const description = "The best Division Resurgence builds ranked S through C tier. PvE Legendary, Dark Zone PvP, and Conflict meta loadouts. Updated for Patch 1.2.1.";

const faqs = [
  {
    question: "How do you rank builds on the tier list?",
    answer: "Every build is tested in live gameplay — Legendary missions, Dark Zone PvP, and Conflict. We look at raw DPS output, survivability, team utility, and how forgiving the build is if you mess up a rotation. No theory-crafting from spreadsheets. If it doesn't perform in-game, it doesn't rank high."
  },
  {
    question: "How often is the tier list updated?",
    answer: "We re-evaluate the tier list after every major patch and hotfix. If a balance change moves the meta, we update within 48 hours. Each build card links to a full guide with a Last Updated date so you know exactly how fresh the info is."
  },
  {
    question: "I think my build is ranked too low. What do I do?",
    answer: "Hit us up on Discord in the #builds channel with your loadout, stats, and gameplay clips. If your build is putting up numbers we can't argue with, we'll re-test it and adjust the ranking. We've moved builds up before — prove it and we'll own the mistake."
  },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbItems} ogImage="/images/best-pve-dps-builds-division-resurgence.png" faqs={faqs}>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Meta Ranking" />
    <h1 class="heading-accent">Best Division Resurgence Builds — Tier List</h1>
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-4); font-size: var(--text-sm);">
      <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); border-radius: 4px; color: #22c55e; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.03em;">✓ Verified for Patch 1.2.1</span>
    </div>
    <p style="color:var(--ink-muted);margin-bottom:var(--sp-6); max-width: 800px;">
      Every build on this list is in-game verified and ranked by real endgame performance. <strong>S-Tier</strong> builds are the best builds in Division Resurgence right now — so overtuned that running them feels like cheating and we respect that. <strong>A-Tier</strong> builds will carry you through anything if you have a functioning thumb. <strong>B-Tier</strong> builds work great but your teammates will still blame you when you wipe. <strong>C-Tier</strong> builds are for people who enjoy suffering. We don't judge. Much.
    </p>

    <div class="tier-list">
      
      <!-- S-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-s">S</div>
        <div class="tier-content">
          {sTier.length > 0 ? (
            <div class="tier-grid">
              {sTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h4>{build.data.title.split(' — ')[0]}</h4>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` · ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">Nothing here yet. If your build belongs in S-Tier, prove it. Our Discord is open.</div>
          )}
        </div>
      </div>

      <!-- A-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-a">A</div>
        <div class="tier-content">
          {aTier.length > 0 ? (
            <div class="tier-grid">
              {aTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h4>{build.data.title.split(' — ')[0]}</h4>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` · ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty"></div>
          )}
        </div>
      </div>

      <!-- B-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-b">B</div>
        <div class="tier-content">
          {bTier.length > 0 ? (
            <div class="tier-grid">
              {bTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h4>{build.data.title.split(' — ')[0]}</h4>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` · ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">B-Tier is empty. Which is weird because most of us live here.</div>
          )}
        </div>
      </div>

      <!-- C-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-c">C</div>
        <div class="tier-content">
          {cTier.length > 0 ? (
            <div class="tier-grid">
              {cTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h4>{build.data.title.split(' — ')[0]}</h4>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` · ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">No C-Tier builds. We have standards. Low ones, but standards.</div>
          )}
        </div>
      </div>

    </div>

    <AdSenseUnit />
  </div>
</BaseLayout>

<style>
  .tier-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    background: rgba(0,0,0,0.2);
    padding: var(--sp-4);
    border-radius: var(--border-radius);
    border: 1px solid var(--border);
  }

  .tier-row {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: 8px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .tier-row {
      flex-direction: row;
    }
  }

  .tier-label {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: #1a1a20;
    min-width: 100px;
    padding: var(--sp-4);
    text-shadow: 0 1px 2px rgba(255,255,255,0.2);
  }

  .tier-s { background: linear-gradient(135deg, #ff7b00, #ff5100); }
  .tier-a { background: linear-gradient(135deg, #00d2ff, #3a7bd5); }
  .tier-b { background: linear-gradient(135deg, #28a745, #20c997); }
  .tier-c { background: linear-gradient(135deg, #6c757d, #adb5bd); }

  .tier-content {
    flex: 1;
    padding: var(--sp-3);
    background: rgba(0,0,0,0.15);
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-2);
  }

  .tier-card {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .tier-card:hover {
    border-color: var(--accent);
    background: rgba(255,255,255,0.05);
    transform: translateY(-2px);
  }

  .tier-card__img {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .tier-card__info h4 {
    color: var(--ink);
    font-size: 13px;
    margin: 0 0 2px 0;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tier-card__spec {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .tier-empty {
    color: var(--ink-muted);
    font-style: italic;
    padding: var(--sp-2);
    font-size: var(--text-sm);
  }
</style>
