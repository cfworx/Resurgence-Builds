---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildCard from '../../components/BuildCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionTag from '../../components/SectionTag.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';
import { getCollection } from 'astro:content';

const allBuilds = await getCollection('builds');

function assignTier(build) {
  const text = (build.data.title + ' ' + build.data.description + ' ' + (build.data.tags||[]).join(' ')).toLowerCase();
  
  if (text.includes('roguemadras') || text.includes('tactical pharma') || text.includes('jackpot striker drone') || text.includes('involuntary nap time')) return 'S';
  if (text.includes('saiynergy') || text.includes('breacher')) return 'A';
  if (text.includes('tampishach') || text.includes('tech aegis')) return 'B';
  if (text.includes('milkshake') || text.includes('strawberry')) return 'B';
  if (text.includes('disorient') || text.includes('tech-op')) return 'A';
  if (text.includes('nadie') || text.includes('muscular nurse')) return 'A';
  if (text.includes('ltfoe') || text.includes('double agent')) return 'A';
  if (text.includes('agenthuntzman') || (text.includes('vanguard') && text.includes('recon'))) return 'A';
  if (text.includes('pve enjoyer') || (text.includes('demolitionist') && text.includes('glass cannon'))) return 'A';

  return 'B';
}

const buildsWithTiers = allBuilds.map(b => ({ ...b, tier: assignTier(b) }));

const sTier = buildsWithTiers.filter(b => b.tier === 'S');
const aTier = buildsWithTiers.filter(b => b.tier === 'A');
const bTier = buildsWithTiers.filter(b => b.tier === 'B');
const cTier = buildsWithTiers.filter(b => b.tier === 'C');
const dTier = buildsWithTiers.filter(b => b.tier === 'D');

const breadcrumbItems = [{ name: 'Tier List', url: '/tier-list/' }];

const title = "Best Builds & Tier List - Division Resurgence";
const description = "Best Division Resurgence builds ranked S through D tier. PvE Legendary, Dark Zone PvP, and Conflict meta loadouts. Updated for Patch 1.1.2.2.";

const siteUrl = 'https://resurgencebuilds.com';

// ItemList schema for ranked builds
const allRanked = [...sTier, ...aTier, ...bTier, ...cTier, ...dTier];
const itemListLd = {
  '@type': 'ItemList',
  name: `Division Resurgence Build Tier List - ${new Date().toLocaleDateString('en-US', {month:'long', year:'numeric'})} Meta Rankings`,
  description: description,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: allRanked.length,
  itemListElement: allRanked.map((build, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: build.data.title,
    url: `${siteUrl}/builds/${build.id}/`,
  })),
};

const faqs = [
  {
    question: "How do you rank builds on the tier list?",
    answer: "Every build is tested in live gameplay - Legendary missions, Dark Zone PvP, and Conflict. We look at raw DPS output, survivability, team utility, and how forgiving the build is if you mess up a rotation. No theory-crafting from spreadsheets. If it doesn't perform in-game, it doesn't rank high."
  },
  {
    question: "How often is the tier list updated?",
    answer: "We re-evaluate the tier list after every major patch and hotfix. If a balance change moves the meta, we update within 48 hours. Each build card links to a full guide with a Last Updated date so you know exactly how fresh the info is."
  },
  {
    question: "I think my build is ranked too low. What do I do?",
    answer: "Hit us up on Discord in the #builds channel with your loadout, stats, and gameplay clips. If your build is putting up numbers we can't argue with, we'll re-test it and adjust the ranking. We've moved builds up before - prove it and we'll own the mistake."
  },
  {
    question: "What's the best build for PvE in Division Resurgence?",
    answer: "For pure PvE damage, S-Tier builds like Tactical Pharma dominate Legendary content. The Demolitionist Glass Cannon build from PVE Enjoyer is also a top performer at 333k DPS with Fire Cycle T2. For group play, pair a DPS build with a Bulwark tank and Field Medic healer for the safest clears."
  },
  {
    question: "What's the best PvP build in the Dark Zone?",
    answer: "Bulwark Juggernaut builds with Shockwave Spike MK3 are the most feared PvP archetype right now - the 5-second stuns are borderline broken. For damage-focused PvP, SMG Lady Death builds on Vanguard Commando have the fastest TTK at close range. The meta shifts every patch, so check back after each update."
  },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbItems} ogImage="/images/best-pve-dps-builds-division-resurgence.png" faqs={faqs} jsonLd={itemListLd}
  article={{
    publishDate: new Date().toISOString(),
    modifiedDate: new Date().toISOString(),
    author: 'RapidF5',
    tags: ['tier list', 'best builds', 'meta', 'Division Resurgence'],
  }}
>
  <div class="container section">
    <Breadcrumbs items={breadcrumbItems} />
    <SectionTag label="Meta Ranking" />
    <h1 class="heading-accent">Division Resurgence Build Tier List - {new Date().toLocaleDateString('en-US', {month:'long', year:'numeric'})} Meta Rankings</h1>
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-4); font-size: var(--text-sm);">
      <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); border-radius: 4px; color: #22c55e; font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.03em;">&#9989; Verified for Patch 1.1.2.2</span>
      <span style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(242,104,34,0.08); border: 1px solid rgba(242,104,34,0.2); border-radius: 4px; color: var(--accent); font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600;">{allRanked.length} builds ranked</span>
    </div>
    <p style="color:var(--ink-muted);margin-bottom:var(--sp-4); max-width: 800px; line-height: 1.7;">
      Every build on this list is in-game verified and ranked by real endgame performance. <strong>S-Tier</strong> builds are the best builds in Division Resurgence right now - so overtuned that running them feels like cheating and we respect that. <strong>A-Tier</strong> builds will carry you through anything if you have a functioning thumb. <strong>B-Tier</strong> builds work great but your teammates will still blame you when you wipe. <strong>C-Tier</strong> builds are for people who enjoy suffering. We don't judge. Much.
    </p>

    <!-- Methodology -->
    <div style="background: rgba(0,0,0,0.15); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 0 8px 8px 0; padding: var(--sp-5); margin-bottom: var(--sp-6); max-width: 800px;">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-base); font-weight: 800; color: #fff; margin: 0 0 var(--sp-2) 0;">How We Rank Builds</h2>
      <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.7; margin: 0;">
        Every build is run in three scenarios: <strong style="color: var(--ink);">Legendary missions</strong> (sustained DPS and survivability), <strong style="color: var(--ink);">Dark Zone PvP</strong> (TTK and positioning), and <strong style="color: var(--ink);">Conflicts</strong> (team composition impact). We measure DPS output, clear times, death count, and team contribution across multiple runs. Builds that perform consistently across all three contexts rank higher than one-trick setups. We re-test after every patch and hotfix - if a balance change moves the meta, the tier list updates within 48 hours.
      </p>
    </div>

    <div class="tier-list">
      
      <!-- S-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-s">S</div>
        <div class="tier-content">
          {sTier.length > 0 ? (
            <div class="tier-grid">
              {sTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h3>{build.data.title.split(' - ')[0]}</h3>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` - ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">Nothing here yet. If your build belongs in S-Tier, prove it. Our Discord is open.</div>
          )}
        </div>
      </div>

      <!-- A-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-a">A</div>
        <div class="tier-content">
          {aTier.length > 0 ? (
            <div class="tier-grid">
              {aTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h3>{build.data.title.split(' - ')[0]}</h3>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` - ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty"></div>
          )}
        </div>
      </div>

      <!-- B-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-b">B</div>
        <div class="tier-content">
          {bTier.length > 0 ? (
            <div class="tier-grid">
              {bTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h3>{build.data.title.split(' - ')[0]}</h3>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` - ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">B-Tier is empty. Which is weird because most of us live here.</div>
          )}
        </div>
      </div>

      <!-- C-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-c">C</div>
        <div class="tier-content">
          {cTier.length > 0 ? (
            <div class="tier-grid">
              {cTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h3>{build.data.title.split(' - ')[0]}</h3>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` - ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">No C-Tier builds.</div>
          )}
        </div>
      </div>

      <!-- D-TIER -->
      <div class="tier-row">
        <div class="tier-label tier-d">D</div>
        <div class="tier-content">
          {dTier.length > 0 ? (
            <div class="tier-grid">
              {dTier.map(build => (
                <a href={`/builds/${build.id}/`} class="tier-card">
                  <div class="tier-card__img" style={`background-image: url('${build.data.featuredImage || '/images/default-cover.webp'}')`}></div>
                  <div class="tier-card__info">
                    <h3>{build.data.title.split(' - ')[0]}</h3>
                    <span class="tier-card__spec">{build.data.specialization}{build.data.subclass ? ` - ${build.data.subclass}` : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="tier-empty">No D-Tier builds. We have standards. Low ones, but standards.</div>
          )}
        </div>
      </div>

    </div>

    <AdSenseUnit label="Advertisement — tier list 1" />

    <!-- Per-Tier Analysis -->
    <div style="max-width: 800px; margin-top: var(--sp-6);">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 800; color: #fff; margin: 0 0 var(--sp-4) 0;">Tier Breakdown - Patch 1.1.2.2 Meta</h2>

      <div style="margin-bottom: var(--sp-6);">
        <h3 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #ff7b00; margin: 0 0 var(--sp-2) 0;">S-Tier - The Untouchables</h3>
        <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75;">
          S-Tier is reserved for builds that break the game in their favor. Right now that's Tactical Pharma - RogueMadras put together a setup that pushes 800k+ effective DPS with healing output that keeps the squad alive through damage checks that should be wiping you. It's the kind of build where teammates type "what are you running" in chat after the first boss melts in 8 seconds. If you want to clear Legendary content on autopilot, these are the loadouts that do it.
        </p>
      </div>

      <div style="margin-bottom: var(--sp-6);">
        <h3 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #3a7bd5; margin: 0 0 var(--sp-2) 0;">A-Tier - Endgame Ready</h3>
        <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75;">
          A-Tier builds are what most experienced players run. The Bulwark Breacher from Saiynergy (334k DPS while holding a shield), PVE Enjoyer's Demolitionist Glass Cannon (333k DPS at 20m range), and AgentHuntzman's Vanguard Recon (team damage multiplier that doesn't show on your own DPS meter but carries the squad). These builds clear all content comfortably and are competitive in Dark Zone PvP. The difference between A-Tier and S-Tier is usually one stat check or one gear piece - if you're running A-Tier, you're doing endgame right.
        </p>
      </div>

      <div style="margin-bottom: var(--sp-6);">
        <h3 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 800; color: #28a745; margin: 0 0 var(--sp-2) 0;">B-Tier - Solid Picks</h3>
        <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.75;">
          B-Tier builds work. Period. The Milkshake Machine (Strawberry Milkshake LMG with Phalanx Attack) is disgusting sustained DPS that just keeps firing. Tampishach's Tech Aegis (237k DPS shield pulse) is a tanky DPS hybrid with one of the highest skill ceilings in the game. These builds won't top the damage charts against an optimized S-Tier or A-Tier setup, but they'll clear every piece of content in the game and they're often more forgiving to play. If you're still farming for that perfect Fire Cycle T2 roll, B-Tier is where you live - and it's comfortable.
        </p>
      </div>
    </div>

    <!-- Patch Watchlist -->
    <div style="background: rgba(242,104,34,0.06); border: 1px solid rgba(242,104,34,0.2); border-radius: 12px; padding: var(--sp-5); margin-bottom: var(--sp-6); max-width: 800px;">
      <h2 style="font-family: var(--font-heading); font-size: var(--text-base); font-weight: 800; color: var(--accent); margin: 0 0 var(--sp-2) 0;">&#128064; Patch 1.3 Watchlist</h2>
      <p style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.7; margin: 0 0 var(--sp-3) 0;">
        Based on community discussion and Ubisoft's balance history, these are the areas we're watching for Patch 1.3 changes:
      </p>
      <ul style="color: var(--ink-muted); font-size: var(--text-sm); line-height: 1.7; padding-left: var(--sp-5); margin: 0;">
        <li><strong style="color: var(--ink);">Shockwave Spike MK3:</strong> The ~5-second stun is widely considered too strong for PvP. A cooldown or duration nerf is likely.</li>
        <li><strong style="color: var(--ink);">Fire Cycle T2:</strong> The +12% passive Skill Multi-Shot Chance with zero conditions is on the radar. Expect either a nerf or a conditional requirement.</li>
        <li><strong style="color: var(--ink);">Toymaker II:</strong> The 20m range requirement may get tightened or the Skill Multi-Shot bonus reduced from +21%.</li>
        <li><strong style="color: var(--ink);">Vanguard Recon:</strong> Smart Cover buffs may see a cap or diminishing returns in group play.</li>
      </ul>
    </div>

    <AdSenseUnit label="Advertisement — tier list 2" />
  </div>
</BaseLayout>

<style>
  .tier-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    background: rgba(0,0,0,0.2);
    padding: var(--sp-4);
    border-radius: var(--border-radius);
    border: 1px solid var(--border);
  }

  .tier-row {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: 8px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .tier-row {
      flex-direction: row;
    }
  }

  .tier-label {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: #1a1a20;
    min-width: 100px;
    padding: var(--sp-4);
    text-shadow: 0 1px 2px rgba(255,255,255,0.2);
  }

  .tier-s { background: linear-gradient(135deg, #ff7b00, #ff5100); }
  .tier-a { background: linear-gradient(135deg, #00d2ff, #3a7bd5); }
  .tier-b { background: linear-gradient(135deg, #28a745, #20c997); }
  .tier-c { background: linear-gradient(135deg, #6c757d, #adb5bd); }
  .tier-d { background: linear-gradient(135deg, #495057, #343a40); }

  .tier-content {
    flex: 1;
    padding: var(--sp-3);
    background: rgba(0,0,0,0.15);
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-2);
  }

  .tier-card {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px;
    text-decoration: none;
    transition: all 0.2s;
    min-height: 62px;
  }

  .tier-card:hover {
    border-color: var(--accent);
    background: rgba(255,255,255,0.05);
    transform: translateY(-2px);
  }

  .tier-card__img {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .tier-card__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .tier-card__info h3 {
    color: var(--ink);
    font-size: 13px;
    margin: 0 0 2px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 600;
  }

  .tier-card__spec {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .tier-empty {
    color: var(--ink-muted);
    font-style: italic;
    padding: var(--sp-2);
    font-size: var(--text-sm);
  }
</style>
