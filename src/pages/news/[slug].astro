---
import NewsLayout from '../../layouts/NewsLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<NewsLayout title={post.data.title} description={post.data.description} publishDate={post.data.publishDate} author={post.data.author} tags={post.data.tags} image={post.data.featuredImage} imageAlt={post.data.imageAlt} parentPath="/news/" parentLabel="News" headings={headings}>
  <Content />
</NewsLayout>
