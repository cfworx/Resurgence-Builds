---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/SectionTag.astro';
import PostCard from '../components/PostCard.astro';
import AdSenseUnit from '../components/AdSenseUnit.astro';
import { getCollection } from 'astro:content';

// Fetch all content collections
const allNews = await getCollection('news');
const allPatchNotes = await getCollection('patchNotes');
const allGuides = await getCollection('guides');
const allBuilds = await getCollection('builds');

// Normalize into a unified post format
interface UnifiedPost {
  title: string;
  href: string;
  date: Date;
  author: string;
  description: string;
  type: 'news' | 'patch-notes' | 'guide' | 'build';
  tags: string[];
  featuredImage?: string;
  imageAlt?: string;
}

const posts: UnifiedPost[] = [
  ...allNews.map((post) => ({
    title: post.data.title,
    href: `/news/${post.id}/`,
    date: post.data.publishDate,
    author: post.data.author,
    description: post.data.description,
    type: 'news' as const,
    tags: post.data.tags,
    featuredImage: post.data.featuredImage,
    imageAlt: post.data.imageAlt,
  })),
  ...allPatchNotes.map((pn) => ({
    title: pn.data.title,
    href: `/patch-notes/${pn.id}/`,
    date: pn.data.patchDate,
    author: pn.data.author,
    description: pn.data.summary,
    type: 'patch-notes' as const,
    tags: [`v${pn.data.version}`],
    featuredImage: pn.data.featuredImage,
    imageAlt: pn.data.imageAlt,
  })),
  ...allGuides.map((guide) => ({
    title: guide.data.title,
    href: `/guides/${guide.id}/`,
    date: guide.data.lastUpdated,
    author: guide.data.author || 'Resurgence Builds',
    description: guide.data.description,
    type: 'guide' as const,
    tags: guide.data.tags,
    featuredImage: guide.data.featuredImage,
    imageAlt: guide.data.imageAlt,
  })),
  ...allBuilds.map((build) => ({
    title: build.data.title,
    href: `/builds/${build.id}/`,
    date: build.data.lastUpdated,
    author: build.data.author,
    description: build.data.description,
    type: 'build' as const,
    tags: build.data.tags,
    featuredImage: build.data.featuredImage,
    imageAlt: build.data.imageAlt,
  })),
];

// Sort by date (newest first)
posts.sort((a, b) => b.date.getTime() - a.date.getTime());

// Fixed tag list
const filterTags = [
  { label: 'News', value: 'news' },
  { label: 'Builds', value: 'build' },
  { label: 'Guides', value: 'guide' },
  { label: 'Patch Notes', value: 'patch-notes' },
];
---

<BaseLayout
  title="Division Resurgence Builds & Guides"
  description="The top independent wiki for The Division Resurgence. Discover the best mobile builds, weapon tier lists, patch notes, and class guides."
  keywords={[
    "the division resurgence",
    "division resurgence mobile",
    "division resurgence guide",
    "division resurgence tier list",
    "division resurgence builds",
    "division resurgence best build",
    "division resurgence weapon tier list",
    "division resurgence gear sets"
  ]}
>
  <!-- Hero -->
  <section class="hero-banner">
    <img src="/images/hero-banner.webp" alt="The Division Resurgence Hero Banner" class="hero-banner__img" width="1920" height="1080" fetchpriority="high" loading="eager" />
    <div class="hero-banner__overlay"></div>
    <div class="hero-banner__content container" style="display:flex; justify-content:center;">
      <div class="hero-box">
        <h1 class="hero__title" style="margin-bottom: var(--sp-4);">
          The Division Resurgence <span style="color:var(--accent);">Builds</span>
        </h1>
        <p style="color: var(--ink-muted); font-size: 1.1rem; line-height: 1.6; max-width: 600px; margin: 0 auto var(--sp-6);">
          The ultimate <strong>Division Resurgence guide</strong> and <strong>Division Resurgence tier list</strong>. Tested loadouts, real math, and zero clickbait. We play the game, test the <strong>Division Resurgence builds</strong>, and argue about the math so you don't have to.
        </p>
        <div class="hero__actions">
          <a href="/builds/" class="btn btn--primary">Browse Builds</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:var(--max-width);margin:0 auto;" />

  <!-- Latest Posts Feed -->
  <section class="section" id="latest-posts-section">
    <div class="container">
      <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end; gap: var(--sp-6); margin-bottom: var(--sp-6);">
        <div>
          <SectionTag label="Latest" />
          <h2 class="heading-accent">Latest Posts</h2>
          <p style="color:var(--ink-muted);margin-bottom:var(--sp-4);">
            Builds, guides, news, and patch notes for The Division Resurgence.
          </p>

          <!-- Tag Filter Bar -->
          <div class="filter-bar" id="tag-filters" style="margin-bottom: 0;">
            <button class="filter-btn is-active" data-tag="all">All</button>
            {filterTags.map((tag) => (
              <button class="filter-btn" data-tag={tag.value}>{tag.label}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- Posts Grid -->
      <div class="grid grid--3" id="posts-grid">
        {posts.map((post) => (
          <PostCard
            title={post.title}
            href={post.href}
            date={post.date}
            author={post.author}
            description={post.description}
            type={post.type}
            tags={post.tags}
            featuredImage={post.featuredImage}
            imageAlt={post.imageAlt}
          />
        ))}
      </div>

      <AdSenseUnit className="ad-slot--in-feed" format="fluid" />

      <!-- Pagination Controls -->
      <div id="pagination-controls" style="justify-content:center; align-items:center; gap:var(--sp-4); margin-top:var(--sp-8); display:none;">
        <button class="btn btn--outline" id="prev-page" disabled>Previous</button>
        <span id="page-info" style="color:var(--ink); font-family:var(--font-mono);">Page 1 of 1</span>
        <button class="btn btn--outline" id="next-page" disabled>Next</button>
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="no-results" style="display:none;text-align:center;padding:var(--sp-12) 0;">
        <p style="color:var(--ink-muted);font-size:var(--text-lg);">No posts match that filter.</p>
        <button class="btn btn--outline" id="clear-filter" style="margin-top:var(--sp-4);">Show All Posts</button>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:var(--max-width);margin:0 auto;" />

</BaseLayout>


<script>
  const filterBar = document.getElementById('tag-filters');
  const grid = document.getElementById('posts-grid');
  const noResults = document.getElementById('no-results');
  const clearBtn = document.getElementById('clear-filter');
  
  const paginationControls = document.getElementById('pagination-controls');
  const prevBtn = document.getElementById('prev-page');
  const nextBtn = document.getElementById('next-page');
  const pageInfo = document.getElementById('page-info');

  const ITEMS_PER_PAGE = 9;
  let currentPage = 1;
  let currentTag = 'all';

  function filterPosts() {
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.post-card'));
    let matchedCards: HTMLElement[] = [];

    // Filter cards
    cards.forEach((card) => {
      const cardType = card.dataset.type || '';
      if (currentTag === 'all' || cardType === currentTag) {
        matchedCards.push(card);
      } else {
        card.style.display = 'none';
      }
    });

    const totalPages = Math.ceil(matchedCards.length / ITEMS_PER_PAGE);
    
    // Ensure currentPage is valid
    if (currentPage > totalPages) currentPage = totalPages || 1;

    // Show/hide based on pagination
    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    matchedCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Update empty state
    if (noResults) {
      noResults.style.display = matchedCards.length === 0 ? '' : 'none';
    }

    // Update pagination UI
    if (paginationControls && prevBtn && nextBtn && pageInfo) {
      if (totalPages > 1) {
        paginationControls.style.display = 'flex';
        pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        
        if (currentPage === 1) {
          prevBtn.setAttribute('disabled', 'true');
        } else {
          prevBtn.removeAttribute('disabled');
        }

        if (currentPage === totalPages) {
          nextBtn.setAttribute('disabled', 'true');
        } else {
          nextBtn.removeAttribute('disabled');
        }
      } else {
        paginationControls.style.display = 'none';
      }
    }
  }

  function setActiveButton(activeBtn: Element) {
    filterBar?.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('is-active'));
    activeBtn.classList.add('is-active');
  }

  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn');
      if (!btn) return;
      setActiveButton(btn);
      currentTag = btn.getAttribute('data-tag') || 'all';
      currentPage = 1; // Reset to page 1 on filter change
      filterPosts();
    });
  }

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      const allBtn = filterBar?.querySelector('[data-tag="all"]');
      if (allBtn) setActiveButton(allBtn);
      currentTag = 'all';
      currentPage = 1;
      filterPosts();
    });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        filterPosts();
        document.getElementById('latest-posts-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      currentPage++;
      filterPosts();
      document.getElementById('latest-posts-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  // Initial render
  filterPosts();
</script>
